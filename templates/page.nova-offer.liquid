<style>
  /* ── Reset ──────────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  img, video { display: block; max-width: 100%; }
  button { cursor: pointer; font: inherit; }

  /* ── Design tokens ──────────────────────────────────────────────────── */
  :root {
    --ink:    #000000;
    --paper:  #ffffff;
    --muted:  rgba(255, 255, 255, 0.50);
    --border: rgba(255, 255, 255, 0.14);
    --fdisp:  'Barlow Condensed', sans-serif;
    --fbody:  'DM Sans', sans-serif;
  }

  /* ── Base ───────────────────────────────────────────────────────────── */
  html { scroll-behavior: smooth; }
  body {
    background: var(--ink);
    color: var(--paper);
    font-family: var(--fbody);
    font-size: 16px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Typography ─────────────────────────────────────────────────────── */
  .lp-eyebrow {
    font-family: var(--fbody);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 14px;
  }
  .lp-h1 {
    font-family: var(--fdisp);
    font-weight: 900;
    font-size: clamp(42px, 9vw, 96px);
    line-height: 0.94;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: #fff;
    white-space: pre-line;
    margin-bottom: 20px;
  }
  .lp-h2 {
    font-family: var(--fdisp);
    font-weight: 900;
    font-size: clamp(32px, 5.5vw, 64px);
    line-height: 0.96;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }
  .lp-h2--dark { color: var(--ink); }
  .lp-subhead {
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.80);
    max-width: 500px;
    margin-bottom: 36px;
  }
  .lp-body { font-size: 15px; line-height: 1.65; }
  .lp-body--muted { color: rgba(255,255,255,0.75); }
  .lp-body--dark-muted { color: rgba(0,0,0,0.60); }

  /* ── CTA button ─────────────────────────────────────────────────────── */
  .lp-cta {
    display: inline-block;
    background: #fff;
    color: #000;
    font-family: var(--fbody);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 20px 48px;
    border: none;
    transition: opacity 150ms;
  }
  .lp-cta:hover  { opacity: 0.88; }
  .lp-cta:active { opacity: 0.72; }
  .lp-cta:disabled { opacity: 0.5; cursor: wait; }

  /* ── Logo bar (branding only — NOT a link) ──────────────────────────── */
  .lp-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 3;
    padding: 22px 28px;
    display: flex;
    align-items: center;
  }
  @media (min-width: 768px) { .lp-bar { padding: 28px 56px; } }
  .lp-logo {
    font-family: var(--fdisp);
    font-weight: 900;
    font-size: 17px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
  }

  /* ── Hero ───────────────────────────────────────────────────────────── */
  .lp-hero {
    position: relative;
    min-height: 100svh;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background: #000;
  }
  .lp-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .lp-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.52);
    z-index: 1;
  }
  .lp-hero__content {
    position: relative;
    z-index: 2;
    padding: 48px 28px 56px;
    max-width: 720px;
  }
  @media (min-width: 768px) { .lp-hero__content { padding: 80px 56px 80px; } }

  /* ── Trust strip ────────────────────────────────────────────────────── */
  .lp-trust {
    background: #fff;
    color: #000;
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    border-top: 1px solid #000;
    border-bottom: 1px solid #000;
  }
  .lp-trust::-webkit-scrollbar { display: none; }
  .lp-trust__item {
    flex: 1 0 auto;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 14px 20px;
    font-family: var(--fbody);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    color: #000;
    border-right: 1px solid #000;
  }
  .lp-trust__item:last-child { border-right: 0; }

  /* ── Section wrapper ────────────────────────────────────────────────── */
  .lp-sec {
    padding: 80px 28px;
    max-width: 900px;
    margin: 0 auto;
  }
  @media (min-width: 768px) { .lp-sec { padding: 100px 56px; } }

  /* ── GSM proof block ────────────────────────────────────────────────── */
  .lp-gsm {
    background: #fff;
    color: #000;
    border-top: 1px solid #000;
    border-bottom: 1px solid #000;
  }
  .lp-gsm-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 80px 28px;
  }
  @media (min-width: 768px) { .lp-gsm-inner { padding: 100px 56px; } }
  .lp-gsm__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid #000;
    margin-top: 40px;
  }
  @media (max-width: 599px) { .lp-gsm__grid { grid-template-columns: repeat(2, 1fr); } }
  .lp-gsm__cell {
    padding: 24px 20px 28px;
    border-right: 1px solid #000;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .lp-gsm__cell:last-child { border-right: 0; }
  @media (max-width: 599px) {
    .lp-gsm__cell:nth-child(2n) { border-right: 0; }
    .lp-gsm__cell:nth-child(n+3) { border-top: 1px solid #000; }
  }
  .lp-gsm__cell--ours { background: #000; color: #fff; }
  .lp-gsm__tier {
    font-family: var(--fbody);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.45;
  }
  .lp-gsm__val {
    font-family: var(--fdisp);
    font-weight: 900;
    font-size: clamp(28px, 4vw, 48px);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .lp-gsm__name {
    font-family: var(--fbody);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ── Objection blocks ───────────────────────────────────────────────── */
  .lp-obj {
    border-top: 1px solid var(--border);
  }
  .lp-obj__item {
    padding: 40px 0;
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  @media (min-width: 700px) {
    .lp-obj__item {
      grid-template-columns: 5fr 7fr;
      gap: 56px;
      align-items: start;
    }
  }
  .lp-obj__q {
    font-family: var(--fdisp);
    font-weight: 700;
    font-size: clamp(20px, 2.8vw, 28px);
    line-height: 1.1;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }
  .lp-obj__a {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.80);
  }
  .lp-obj__a strong { color: #fff; font-weight: 700; }

  /* ── Bottom CTA section ─────────────────────────────────────────────── */
  .lp-bottom-cta {
    text-align: center;
    padding: 88px 28px 108px;
    border-top: 1px solid var(--border);
  }
  .lp-price-tag {
    font-family: var(--fdisp);
    font-weight: 900;
    font-size: clamp(56px, 12vw, 112px);
    letter-spacing: -0.02em;
    line-height: 1;
    color: #fff;
  }
  .lp-price-note {
    font-family: var(--fbody);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 10px 0 36px;
  }
</style>

<!-- ═══════════════════════════════════════════════════════════════════════
  SECTION 1 — HERO
  ═══════════════════════════════════════════════════════════════════════ -->
<section class="lp-hero" id="lp-hero">

  <div class="lp-bar">
    <span class="lp-logo">Polaris Car Care</span>
  </div>

  <video
    id="lp-hero-video"
    class="lp-hero__video"
    autoplay
    muted
    loop
    playsinline
    preload="none"
  ></video>

  <div class="lp-hero__overlay"></div>

  <div class="lp-hero__content">
    <p class="lp-eyebrow">Polaris Car Care &middot; The Nova</p>
    <h1 class="lp-h1" id="lp-hero-headline"><!-- set by hero variant JS --></h1>
    <p class="lp-subhead" id="lp-hero-subhead"><!-- set by hero variant JS --></p>
    <button class="lp-cta" id="lp-cta-hero">Buy Now &mdash; $29.99</button>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════
  TRUST STRIP
  ═══════════════════════════════════════════════════════════════════════ -->
<div class="lp-trust" aria-label="Trust signals">
  <div class="lp-trust__item">&#10022; Free shipping</div>
  <div class="lp-trust__item">&#10022; 30-day guarantee</div>
  <div class="lp-trust__item">&#10022; Paint-safe</div>
  <div class="lp-trust__item">&#10022; 4.9 stars</div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
  SECTION 2 — GSM PROOF BLOCK
  ═══════════════════════════════════════════════════════════════════════ -->
<div class="lp-gsm">
  <div class="lp-gsm-inner">
    <p class="lp-eyebrow" style="color:rgba(0,0,0,0.45);">Why GSM matters</p>
    <h2 class="lp-h2 lp-h2--dark">More Fiber.<br>Less Paint.</h2>
    <p class="lp-body lp-body--dark-muted" style="max-width:560px;margin-top:18px;">
      GSM measures how much microfiber is packed into every square meter of cloth.
      More fiber means more water absorbed per pass — and fewer drags across your clear coat.
      Most towels at the auto parts store run 200–400 GSM. They smear. They scratch.
      The Nova is 1300.
    </p>

    <div class="lp-gsm__grid" aria-label="GSM comparison">
      <div class="lp-gsm__cell">
        <span class="lp-gsm__tier">Gas station</span>
        <span class="lp-gsm__val">200</span>
        <span class="lp-gsm__name">GSM</span>
      </div>
      <div class="lp-gsm__cell">
        <span class="lp-gsm__tier">Standard</span>
        <span class="lp-gsm__val">400</span>
        <span class="lp-gsm__name">GSM</span>
      </div>
      <div class="lp-gsm__cell">
        <span class="lp-gsm__tier">Detailer twist</span>
        <span class="lp-gsm__val">800</span>
        <span class="lp-gsm__name">GSM</span>
      </div>
      <div class="lp-gsm__cell lp-gsm__cell--ours">
        <span class="lp-gsm__tier">The Nova</span>
        <span class="lp-gsm__val">1300</span>
        <span class="lp-gsm__name">GSM</span>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
  SECTION 3 — THREE OBJECTION BLOCKS
  ═══════════════════════════════════════════════════════════════════════ -->
<section class="lp-sec">
  <div class="lp-obj">

    <div class="lp-obj__item">
      <p class="lp-obj__q">Why pay $30 when Amazon has a 30-pack for the same?</p>
      <p class="lp-obj__a">
        Those are low-GSM utility towels — 200–400 GSM packed tight to look like value.
        They push water around instead of absorbing it, leave streaks on glass, and drag grit
        across your clear coat on every pass.
        <strong>The Nova dries a full sedan in one pass. One towel. No second run.</strong>
      </p>
    </div>

    <div class="lp-obj__item">
      <p class="lp-obj__q">I just use a bath towel.</p>
      <p class="lp-obj__a">
        Bath towels are made for skin. Cotton fiber has no lift — it smears water across
        the surface and micro-scratches your clear coat every time. Under direct light,
        you see the swirls. <strong>The Nova's 70/30 PA6 twisted loop lifts water away from
        the paint instead of dragging it.</strong>
      </p>
    </div>

    <div class="lp-obj__item">
      <p class="lp-obj__q">Is it safe for my paint?</p>
      <p class="lp-obj__a">
        Yes. The 1300 GSM twisted loop weave traps water and debris inside the pile — they
        never contact your clear coat on the way across. <strong>Safe on ceramic, PPF, and bare
        paint.</strong> If we wouldn't trust it on a paint-corrected car, we wouldn't sell it.
      </p>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════
  SECTION 4 — REPEAT CTA
  ═══════════════════════════════════════════════════════════════════════ -->
<div class="lp-bottom-cta">
  <p class="lp-price-tag">$29.99</p>
  <p class="lp-price-note">Free shipping &middot; Ships in 1&ndash;2 business days</p>
  <button class="lp-cta" id="lp-cta-bottom">Buy Now &mdash; Free Shipping</button>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
  HERO VARIANT JS
  ═══════════════════════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  var AD_VARIANTS = {

    pro: {
      videoSrc: '',   // TODO: paste Shopify CDN URL for the "pro" hero video
      headline: 'The Towel\nDetailers Use',
      subhead: '1300 GSM twisted loop. Dries a full car in one pass. Zero streaks, zero water spots, safe on clear coat.'
    },

    value: {
      videoSrc: '',   // TODO: paste Shopify CDN URL for the "value" hero video
      headline: 'Stop Scratching\nYour Paint',
      subhead: 'That $8 Amazon pack is 200 GSM. It streaks, it scratches, and it costs you a detail. The Nova is $29.99 and lasts for years.'
    }

  };

  var param   = new URLSearchParams(window.location.search).get('ad') || 'pro';
  var variant = AD_VARIANTS[param] || AD_VARIANTS['pro'];

  var video = document.getElementById('lp-hero-video');
  if (video && variant.videoSrc) {
    video.src = variant.videoSrc;
    video.load();
  }

  var headlineEl = document.getElementById('lp-hero-headline');
  var subheadEl  = document.getElementById('lp-hero-subhead');
  if (headlineEl) headlineEl.textContent = variant.headline;
  if (subheadEl)  subheadEl.textContent  = variant.subhead;

  var NOVA_VARIANT_ID = 46960872521859;

  function goToCheckout(btn) {
    var originalText = btn.textContent;
    btn.textContent = 'Adding…';
    btn.disabled = true;

    fetch('/cart/clear.js', { method: 'POST' })
      .then(function () {
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: NOVA_VARIANT_ID, quantity: 1 })
        });
      })
      .then(function () {
        window.location.href = '/checkout';
      })
      .catch(function () {
        btn.textContent = originalText;
        btn.disabled = false;
      });
  }

  var ctaHero   = document.getElementById('lp-cta-hero');
  var ctaBottom = document.getElementById('lp-cta-bottom');
  if (ctaHero)   ctaHero.addEventListener('click',   function () { goToCheckout(ctaHero); });
  if (ctaBottom) ctaBottom.addEventListener('click', function () { goToCheckout(ctaBottom); });

})();
</script>
