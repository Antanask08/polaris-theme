<!-- ═══ JS ════════════════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  /* ── Ad variant config ──────────────────────────────────────────────── */
  var AD_VARIANTS = {
    pro: {
      videoSrc: '',
      headline: 'The Towel\nDetailers Use',
      subhead: '1300 GSM twisted loop. Dries a full car in one pass. Zero streaks, zero water spots, safe on clear coat.'
    },
    value: {
      videoSrc: '',
      headline: 'Stop Scratching\nYour Paint',
      subhead: "That $8 Amazon pack is 200 GSM. It streaks, it scratches, and it costs you a detail. The Nova is $29.99 and lasts for years."
    }
  };

  var param   = new URLSearchParams(window.location.search).get('ad') || 'pro';
  var variant = AD_VARIANTS[param] || AD_VARIANTS['pro'];

  /* Set headline + subhead */
  var headlineEl = document.getElementById('lp-hero-headline');
  var subheadEl  = document.getElementById('lp-hero-subhead');
  if (headlineEl) headlineEl.textContent = variant.headline;
  if (subheadEl)  subheadEl.textContent  = variant.subhead;

  /* Swap video or keep fallback image */
  var videoEl = document.getElementById('lp-hero-video');
  var imgEl   = document.getElementById('lp-hero-img');
  if (variant.videoSrc && videoEl) {
    videoEl.src = variant.videoSrc;
    videoEl.load();
    videoEl.style.display = '';
    if (imgEl) imgEl.style.display = 'none';
  }

  /* ── Bundle / pack selection ────────────────────────────────────────── */
  var packBtns      = document.querySelectorAll('.lp-pack');
  var btnBuy        = document.getElementById('lp-btn-buy');
  var btnFinal      = document.getElementById('lp-btn-final');
  var finalPriceEl  = document.getElementById('lp-final-price');
  var selectedVariant = '46960868196483';

  packBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      packBtns.forEach(function (b) { b.classList.remove('lp-pack--on'); });
      btn.classList.add('lp-pack--on');

      selectedVariant = btn.dataset.variant;
      var price = '$' + btn.dataset.price;

      /* Update buy button label */
      if (btnBuy) btnBuy.innerHTML = btn.dataset.btn;

      /* Update final CTA price + label */
      if (finalPriceEl) finalPriceEl.textContent = price;
      var finalLabelEl = document.getElementById('lp-final-label');
      if (finalLabelEl) finalLabelEl.textContent = btn.dataset.finallabel || '';

      /* Update stock urgency */
      var stockEl = document.getElementById('lp-stock');
      if (stockEl) {
        stockEl.textContent = btn.dataset.stock || '';
        stockEl.classList.toggle('lp-stock--low', btn.dataset.variant === '46960868196483');
      }
    });
  });

  /* ── Checkout ───────────────────────────────────────────────────────── */
  function goToCheckout(btn) {
    var originalHTML = btn.innerHTML;
    btn.textContent = 'Adding…';
    btn.disabled = true;

    fetch('/cart/clear.js', { method: 'POST' })
      .then(function () {
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: parseInt(selectedVariant, 10), quantity: 1 })
        });
      })
      .then(function () {
        window.location.href = '/checkout';
      })
      .catch(function () {
        btn.innerHTML = originalHTML;
        btn.disabled = false;
      });
  }

  if (btnBuy)   btnBuy.addEventListener('click',   function () { goToCheckout(btnBuy); });
  if (btnFinal) btnFinal.addEventListener('click', function () { goToCheckout(btnFinal); });

})();
</script>
