{% if shop.password_enabled %}
  <h1 class="password-headline">{{ section.settings.headline }}</h1>
  <p class="password-subhead">{{ section.settings.subhead }}</p>

  {% if section.settings.show_email_capture %}
    <div class="password-email-form">
      <label class="password-email-label">{{ section.settings.email_label }}</label>
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter,launch-list">
        <div class="password-input-row">
          <input
            type="email"
            name="contact[email]"
            class="password-email-input"
            placeholder="{{ section.settings.email_placeholder }}"
            required
            autocomplete="email"
          >
          <button type="submit" class="password-submit">{{ section.settings.submit_text }}</button>
        </div>
      {% endform %}
    </div>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Password Page",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "SOMETHING GOOD IS COMING."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subheadline",
      "default": "We're putting the finishing touches on something premium. Check back soon."
    },
    {
      "type": "checkbox",
      "id": "show_email_capture",
      "label": "Show email capture",
      "default": true
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email field label",
      "default": "Get notified when we launch:"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "YOUR EMAIL ADDRESS"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Submit button text",
      "default": "NOTIFY ME"
    }
  ]
}
{% endschema %}
