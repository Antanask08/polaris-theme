<style>
  /* =============================================
     TERMS OF SERVICE — POLARIS CAR CARE
     ============================================= */

  .tos-hero {
    min-height: 40vh;
    background-color: #0a0a0a;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 80px 60px 60px;
    box-sizing: border-box;
  }

  .tos-hero__eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin: 0 0 18px;
  }

  .tos-hero__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(2.8rem, 6vw, 5rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1;
    margin: 0 0 24px;
  }

  .tos-hero__meta {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.35);
    margin: 0;
    text-transform: uppercase;
  }

  /* ---- Body ---- */

  .tos-body {
    background: #f5f5f5;
    padding: 80px 40px;
  }

  .tos-container {
    max-width: 780px;
    margin: 0 auto;
  }

  .tos-intro {
    font-family: 'Barlow', sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(0,0,0,0.6);
    margin-bottom: 56px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .tos-section {
    margin-bottom: 48px;
  }

  .tos-section h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #000000;
    margin: 0 0 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }

  .tos-section p,
  .tos-section li {
    font-family: 'Barlow', sans-serif;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(0,0,0,0.75);
    margin-bottom: 12px;
  }

  .tos-section li {
    margin-bottom: 8px;
  }

  .tos-section a {
    color: #000000;
    text-decoration: underline;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .tos-section a:hover {
    opacity: 1;
  }

  .tos-section ul {
    padding-left: 20px;
    list-style: disc;
    margin-bottom: 12px;
  }

  .tos-contact-block {
    margin-top: 64px;
    padding-top: 40px;
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  .tos-contact-block p {
    font-family: 'Barlow', sans-serif;
    font-size: 0.9rem;
    color: rgba(0,0,0,0.5);
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }

  .tos-contact-block a {
    color: #000;
    text-decoration: underline;
    opacity: 0.65;
  }

  /* ---- Responsive ---- */

  @media (max-width: 768px) {
    .tos-body {
      padding: 48px 24px;
    }
  }

  @media (max-width: 480px) {
    .tos-hero {
      padding: 48px 24px 40px;
    }

    .tos-hero__heading {
      font-size: 2.4rem;
    }
  }
</style>

<!-- HERO -->
<section class="tos-hero">
  <p class="tos-hero__eyebrow">Legal &mdash; Doc. 004</p>
  <h1 class="tos-hero__heading">Terms of Service</h1>
  <p class="tos-hero__meta">Last Updated: April 2025</p>
</section>

<!-- POLICY BODY -->
