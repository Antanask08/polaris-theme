<style>
  /* ─── Base ─── */
  .rv-wrap * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .rv-wrap {
    font-family: 'Barlow', sans-serif;
    color: #000;
    background: #fff;
  }

  .rv-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ─── Grid background pattern ─── */
  .rv-grid-bg {
    background-color: #000;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  /* ─── Section padding ─── */
  .rv-section {
    padding: 80px 60px;
  }

  /* ─── 1. HERO ─── */
  .rv-hero {
    min-height: 55vh;
    padding: 80px 60px 60px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }

  .rv-hero__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 32px;
  }

  .rv-hero__heading-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .rv-hero__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(64px, 10vw, 128px);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 12px;
  }

  .rv-hero__heading-ghost {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(64px, 10vw, 128px);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .rv-hero__stats {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: 48px;
  }

  /* ─── 2. FEATURED QUOTE ─── */
  .rv-quote {
    padding: 72px 60px;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .rv-quote__text {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 600;
    font-style: italic;
    line-height: 1.15;
    color: #fff;
    max-width: 900px;
    margin-bottom: 24px;
  }

  .rv-quote__attr {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
  }

  /* ─── 3. REVIEW GRID ─── */
  .rv-reviews {
    background: #f5f5f5;
    padding: 80px 60px;
  }

  .rv-reviews__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid #e0e0e0;
  }

  .rv-reviews__title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #000;
  }

  .rv-reviews__count {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: #888;
    letter-spacing: 0.08em;
  }

  .rv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: start;
  }

  /* ─── Review Card ─── */
  .rv-card {
    background: #fff;
    border-radius: 2px;
    padding: 28px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    gap: 14px;
    break-inside: avoid;
  }

  .rv-card__stars {
    font-size: 14px;
    color: #c9a84c;
    letter-spacing: 2px;
  }

  .rv-card__header {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .rv-card__name {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #000;
  }

  .rv-card__location {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #888;
    letter-spacing: 0.04em;
  }

  .rv-card__text {
    font-family: 'Barlow', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.65;
    color: #222;
  }

  .rv-card__badge {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    padding-top: 12px;
    border-top: 1px solid #f0f0f0;
    margin-top: auto;
  }

  .rv-card__badge::before {
    content: "✓  ";
    color: #000;
  }

  /* ─── 4. UGC CTA STRIP ─── */
  .rv-ugc {
    padding: 80px 60px;
    text-align: center;
  }

  .rv-ugc__label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 20px;
  }

  .rv-ugc__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 900;
    text-transform: uppercase;
    color: #fff;
    line-height: 0.95;
    margin-bottom: 20px;
  }

  .rv-ugc__sub {
    font-family: 'Barlow', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: rgba(255,255,255,0.5);
    max-width: 480px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .rv-ugc__buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .rv-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 28px;
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    background: transparent;
    transition: background 0.2s, border-color 0.2s;
    cursor: pointer;
  }

  .rv-btn:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.4);
  }

  .rv-btn svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
    flex-shrink: 0;
  }

  /* ─── 5. TRUST ROW ─── */
  .rv-trust {
    background: #f5f5f5;
    padding: 64px 60px;
  }

  .rv-trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: #e0e0e0;
    border: 1px solid #e0e0e0;
  }

  .rv-trust__box {
    background: #f5f5f5;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .rv-trust__stat {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 800;
    line-height: 1;
    color: #000;
    letter-spacing: -0.02em;
  }

  .rv-trust__label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #666;
    line-height: 1.4;
  }

  /* ─── 6. BOTTOM CTA ─── */
  .rv-cta {
    padding: 100px 60px;
    text-align: center;
  }

  .rv-cta__heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(40px, 6vw, 88px);
    font-weight: 900;
    text-transform: uppercase;
    color: #fff;
    line-height: 0.95;
    margin-bottom: 40px;
    letter-spacing: -0.01em;
  }

  .rv-btn--primary {
    background: #fff;
    color: #000;
    border-color: #fff;
    font-size: 13px;
    padding: 18px 40px;
  }

  .rv-btn--primary:hover {
    background: #f0f0f0;
    border-color: #f0f0f0;
    color: #000;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .rv-trust__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .rv-hero {
      padding: 60px 24px 48px;
      min-height: 50vh;
    }

    .rv-section,
    .rv-reviews,
    .rv-ugc,
    .rv-trust,
    .rv-cta,
    .rv-quote {
      padding: 48px 24px;
    }

    .rv-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .rv-reviews__header {
      flex-direction: column;
      gap: 8px;
    }
  }

  @media (max-width: 480px) {
    .rv-hero {
      padding: 48px 20px 40px;
    }

    .rv-section,
    .rv-reviews,
    .rv-ugc,
    .rv-trust,
    .rv-cta,
    .rv-quote {
      padding: 40px 20px;
    }

    .rv-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .rv-trust__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .rv-card {
      padding: 22px;
    }
  }
</style>

<div class="rv-wrap">

  <!-- ─── 1. HERO ─── -->
  <section class="rv-hero rv-grid-bg">
    <p class="rv-hero__eyebrow">Community &mdash; Est. 2025</p>
    <div class="rv-hero__heading-wrap">
      <h1 class="rv-hero__heading">Real Cars.<br>Real Results.</h1>
      <p class="rv-hero__heading-ghost">The Community Speaks.</p>
    </div>
    <p class="rv-hero__stats">50+ Happy Customers &nbsp;&middot;&nbsp; 4.9&#9733; Average Rating &nbsp;&middot;&nbsp; 100% Real Reviews</p>
  </section>

  <!-- ─── 2. FEATURED QUOTE ─── -->
  <section class="rv-quote rv-grid-bg">
    <div class="rv-container">
      <p class="rv-quote__text">&ldquo;I&rsquo;ve tried brands that charge $60 for a towel. This is better.&rdquo;</p>
      <p class="rv-quote__attr">&mdash; Marcus T., Chicago IL</p>
    </div>
  </section>

  <!-- ─── 3. REVIEW GRID ─── -->
  <section class="rv-reviews">
    <div class="rv-container">
      <div class="rv-reviews__header">
        <span class="rv-reviews__title">Customer Reviews</span>
        <span class="rv-reviews__count">Showing 9 of 50+ reviews</span>
      </div>
      <div class="rv-grid">

        <!-- Card 1 -->
        <div class="rv-card">
          <div class="rv-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="rv-card__header">
            <span class="rv-card__name">Jordan K.</span>
            <span class="rv-card__location">Chicago, IL</span>
          </div>
          <p class="rv-card__text">Saw this on my FYP, thought it was just hype. Ordered the Nova Towel and used it on my RSX last weekend — not a single scratch, no streaking, nothing. The 1300 GSM is real. This thing is absurdly soft for the price point. Throwing out every other microfiber I own.</p>
          <span class="rv-card__badge">Verified Purchase</span>
        </div>

        <!-- Card 2 -->
        <div class="rv-card">
          <div class="rv-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="rv-card__header">
            <span class="rv-card__name">Destiny R.</span>
            <span class="rv-card__location">Aurora, IL</span>
          </div>
          <p class="rv-card__text">I have black paint. Black. Paint. You know what that means — every towel shows every swirl. Used the Nova on my 3 Series after a wash and it was flawless. Zero marring. I&rsquo;m not easily impressed and I&rsquo;m genuinely impressed.</p>
          <span class="rv-card__badge">Verified Purchase</span>
        </div>

        <!-- Card 3 -->
        <div class="rv-card">
          <div class="rv-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="rv-card__header">
            <span class="rv-card__name">Trevor M.</span>
            <span class="rv-card__location">Naperville, IL</span>
          </div>
          <p class="rv-card__text">Got mine because a buddy in the Chicago detail community wouldn&rsquo;t stop talking about it. Now I&rsquo;m the one who won&rsquo;t shut up. The edge stitching is properly wrapped — zero chance of scratching. This is a detail towel done right.</p>
          <span class="rv-card__badge">Verified Purchase</span>
        </div>

        <!-- Card 4 -->
        <div class="rv-card">
          <div class="rv-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="rv-card__header">
            <span class="rv-card__name">Aaliyah S.</span>
            <span class="rv-card__location">Evanston, IL</span>
          </div>
          <p class="rv-card__text">Polaris popped up on my TikTok and I took a chance. Really glad I did. The towel feels premium from the moment you open it — and it performs exactly how they show in the videos. Fast shipping too.</p>
          <span class="rv-card__badge">Verified Purchase</span>
        </div>

        <!-- Card 5 -->
        <div class="rv-card">
          <div class="rv-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="rv-card__header">
            <span class="rv-card__name">Caleb W.</span>
            <span class="rv-card__location">Joliet, IL</span>
          </div>
          <p class="rv-card__text">I detail cars on the side and I&rsquo;ve been through every brand you can think of — big-box stuff, boutique stuff, all of it. The Nova Towel at this GSM for this price shouldn&rsquo;t be possible. I&rsquo;m stocking up before they sell out.</p>
          <span class="rv-card__badge">Verified Purchase</span>
        </div>

        <!-- Card 6 -->
        <div class="rv-card">
          <div class="rv-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="rv-card__header">
            <span class="rv-card__name">Priya N.</span>
            <span class="rv-card__location">Schaumburg, IL</span>
          </div>
          <p class="rv-card__text">Gift for my boyfriend who&rsquo;s obsessed with his car. He tested it immediately and said, and I quote: &ldquo;This is the best towel I&rsquo;ve ever used.&rdquo; He never compliments anything. Safe to say it&rsquo;s a hit.</p>
          <span class="rv-card__badge">Verified Purchase</span>
        </div>

        <!-- Card 7 -->
        <div class="rv-card">
          <div class="rv-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="rv-card__header">
            <span class="rv-card__name">Marcus T.</span>
            <span class="rv-card__location">Chicago, IL</span>
          </div>
          <p class="rv-card__text">Used this on a freshly coated hood. Not a single streak, not a single fiber left behind. I&rsquo;ve tried brands that charge $60 for a towel. This is better. The community is real and the product backs it up — no gimmicks here.</p>
          <span class="rv-card__badge">Verified Purchase</span>
        </div>

        <!-- Card 8 -->
        <div class="rv-card">
          <div class="rv-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="rv-card__header">
            <span class="rv-card__name">Nico F.</span>
            <span class="rv-card__location">Oak Park, IL</span>
          </div>
          <p class="rv-card__text">Honest review: was skeptical of a small brand. Ordered anyway. Packaging was clean, product was legit. The waffle weave side picks up water insanely fast — dried my whole WRX in two passes. Coming back for more.</p>
          <span class="rv-card__badge">Verified Purchase</span>
        </div>

        <!-- Card 9 -->
        <div class="rv-card">
          <div class="rv-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="rv-card__header">
            <span class="rv-card__name">Brianna L.</span>
            <span class="rv-card__location">Chicago, IL</span>
          </div>
          <p class="rv-card__text">Paint-safe, lint-free, and thick enough to actually feel like it&rsquo;s doing something. Polaris clearly put real thought into this. Followed them on TikTok for a month before buying and I&rsquo;m glad I finally pulled the trigger. Worth every penny.</p>
          <span class="rv-card__badge">Verified Purchase</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── 4. UGC CTA STRIP ─── -->
  <section class="rv-ugc rv-grid-bg">
    <div class="rv-container">
      <p class="rv-ugc__label">Your Turn</p>
      <h2 class="rv-ugc__heading">Share Your Results</h2>
      <p class="rv-ugc__sub">Tag us @polariscarcare on TikTok or @polaris.carcare on Instagram and you might be featured here.</p>
      <div class="rv-ugc__buttons">
        <a href="https://www.tiktok.com/@polariscarcare" target="_blank" rel="noopener" class="rv-btn">
          <!-- TikTok icon -->
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
          </svg>
          TikTok
        </a>
        <a href="https://www.instagram.com/polaris.carcare" target="_blank" rel="noopener" class="rv-btn">
          <!-- Instagram icon -->
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          Instagram
        </a>
      </div>
    </div>
  </section>

  <!-- ─── 5. TRUST ROW ─── -->
  <section class="rv-trust">
    <div class="rv-container">
      <div class="rv-trust__grid">
        <div class="rv-trust__box">
          <span class="rv-trust__stat">50+</span>
          <span class="rv-trust__label">Customers Served</span>
        </div>
        <div class="rv-trust__box">
          <span class="rv-trust__stat">4.9&#9733;</span>
          <span class="rv-trust__label">Average Rating</span>
        </div>
        <div class="rv-trust__box">
          <span class="rv-trust__stat">30</span>
          <span class="rv-trust__label">Day Returns — No Questions Asked</span>
        </div>
        <div class="rv-trust__box">
          <span class="rv-trust__stat">0%</span>
          <span class="rv-trust__label">Paid Ads &mdash; 100% Community Growth</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 6. BOTTOM CTA ─── -->
  <section class="rv-cta rv-grid-bg">
    <div class="rv-container">
      <h2 class="rv-cta__heading">Ready to Join<br>the Community?</h2>
      <a href="{{ section.settings.cta_url }}" class="rv-btn rv-btn--primary">{{ section.settings.cta_label }}</a>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Shop the Nova Towel"
    }
  ],
  "presets": [
    {
      "name": "Reviews"
    }
  ]
}
{% endschema %}
