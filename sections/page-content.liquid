<style>
  .page-content {
    background: #000;
    color: #fff;
    min-height: 60vh;
    padding: 96px 0;
  }
  .page-content__title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.5rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 48px;
    color: #fff;
  }
  .page-content__body {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: 800px;
    opacity: 0.9;
    color: #fff;
  }
  .page-content__body h1,
  .page-content__body h2,
  .page-content__body h3 {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 40px;
    margin-bottom: 16px;
    color: #fff;
  }
  .page-content__body p {
    margin-bottom: 20px;
  }
  .page-content__body a {
    color: #fff;
    text-decoration: underline;
  }
  .page-content__body ul,
  .page-content__body ol {
    padding-left: 24px;
    margin-bottom: 20px;
  }
  .page-content__body li {
    margin-bottom: 8px;
  }
</style>

<section class="page-content">
  <div class="container">
    <h1 class="page-content__title">{{ page.title }}</h1>
    <div class="page-content__body">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "settings": [],
  "presets": [
    {
      "name": "Page Content"
    }
  ]
}
{% endschema %}
