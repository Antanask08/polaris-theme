<div class="pw-right">

  <!-- Email capture -->
  <div>
    <span class="pw-field-label">Stay in the loop</span>
    {% form 'customer', id: 'PasswordNewsletter' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p class="pw-success">You're on the list. We'll be in touch when we launch.</p>
      {%- else -%}
        {%- if form.errors -%}
          <p style="color:rgba(255,80,80,0.9);font-size:11px;margin-bottom:8px;">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="pw-row">
          <input
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="Your email address"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            required
          >
          <button type="submit">Notify Me</button>
        </div>
        <p class="pw-fine">No spam. Unsubscribe anytime.</p>
      {%- endif -%}
    {% endform %}
  </div>

  <div class="pw-or">or enter with password</div>

  <!-- Store password -->
  <div>
    <span class="pw-field-label">Store password</span>
    {% form 'storefront_password' %}
      {%- if form.errors -%}
        <p style="color:rgba(255,80,80,0.9);font-size:11px;margin-bottom:8px;">Wrong password. Try again.</p>
      {%- endif -%}
      <div class="pw-row">
        <input type="password" name="password" placeholder="Password" autocomplete="current-password">
        <button type="submit">Enter</button>
      </div>
    {% endform %}
  </div>

</div>

{% schema %}
{
  "name": "Password form",
  "tag": "div",
  "settings": []
}
{% endschema %}
