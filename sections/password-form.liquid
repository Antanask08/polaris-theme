<div class="pw-right">

  <!-- Email capture -->
  <div>
    <span class="pw-field-label">Stay in the loop</span>
    {% form 'customer', id: 'PasswordNewsletter' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.errors -%}
        <p style="color:rgba(255,80,80,0.9);font-size:11px;margin-bottom:8px;">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="pw-row" id="pw-email-row">
        <input
          type="email"
          name="contact[email]"
          id="pw-email-input"
          value="{{ form.email }}"
          placeholder="Your email address"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          required
        >
        <button type="submit">Notify Me</button>
      </div>
      <p class="pw-fine" id="pw-fine">No spam. Unsubscribe anytime.</p>
    {% endform %}
    <p class="pw-success" id="pw-success" style="display:none;">You're on the list. We'll be in touch when we launch.</p>
  </div>

  <div class="pw-or">or enter with password</div>

    <!-- Store password -->
  <div>
    <span class="pw-field-label">Store password</span>
    {% form 'storefront_password' %}
      {%- if form.errors -%}
        <p style="color:rgba(255,80,80,0.9);font-size:11px;margin-bottom:8px;">Wrong password. Try again.</p>
      {%- endif -%}
      <div class="pw-row">
        <input type="password" name="password" placeholder="Password" autocomplete="current-password">
        <button type="submit">Enter</button>
      </div>
    {% endform %}
  </div>

</div>

<script>
  (function() {
    if (localStorage.getItem('pw_email_sent') === '1') {
      localStorage.removeItem('pw_email_sent');
      var row = document.getElementById('pw-email-row');
      var fine = document.getElementById('pw-fine');
      var success = document.getElementById('pw-success');
      var form = document.getElementById('PasswordNewsletter');
      if (row) row.style.display = 'none';
      if (fine) fine.style.display = 'none';
      if (success) success.style.display = 'block';
    }

    var form = document.getElementById('PasswordNewsletter');
    if (form) {
      form.addEventListener('submit', function() {
        var email = document.getElementById('pw-email-input');
        if (email && email.value.trim()) {
          localStorage.setItem('pw_email_sent', '1');
        }
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Password form",
  "tag": "div",
  "settings": []
}
{% endschema %}
