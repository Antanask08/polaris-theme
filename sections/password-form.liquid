<div class="pw-right">

  <!-- Email capture -->
  <div>
    <span class="pw-field-label">Stay in the loop</span>
    {% form 'customer', id: 'pw-email-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="pw-row">
        <input type="email" name="contact[email]" id="pw-email-input" placeholder="Your email address" autocomplete="email" required>
        <button type="submit">Notify Me</button>
      </div>
      <p class="pw-fine">No spam. Unsubscribe anytime.</p>
    {% endform %}
    <p class="pw-success" id="pw-success">You're on the list. We'll be in touch when we launch.</p>
  </div>

  <div class="pw-or">or enter with password</div>

  <!-- Store password -->
  <div>
    <span class="pw-field-label">Store password</span>
    <form action="/password" method="post">
      <input type="hidden" name="authenticity_token" value="{{ form_authenticity_token }}">
      <div class="pw-row">
        <input type="password" name="password" placeholder="Password" autocomplete="current-password">
        <button type="submit">Enter</button>
      </div>
    </form>
  </div>

</div>

{% schema %}
{
  "name": "Password form",
  "tag": "div",
  "settings": []
}
{% endschema %}
