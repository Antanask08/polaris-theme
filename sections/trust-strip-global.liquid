<style>
  .tsg-section {
    background: #000;
    border-top: 1px solid rgba(255,255,255,0.07);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 0 48px;
    font-family: 'DM Sans', sans-serif;
  }

  @media (max-width: 640px) {
    .tsg-section { padding: 0 24px; }
  }

  .tsg-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.07);
    max-width: 1400px;
    margin: 0 auto;
  }

  @media (max-width: 900px) {
    .tsg-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .tsg-grid { grid-template-columns: 1fr; }
  }

  .tsg-item {
    background: #000;
    padding: 28px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .tsg-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.65;
  }

  .tsg-icon svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: #fff;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tsg-label {
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 2px;
  }

  .tsg-sub {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
