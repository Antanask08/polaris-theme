<style>
  .why-polaris {
    background: #000;
    color: #fff;
    padding: 96px 0;
  }
  .why-polaris .section-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .why-polaris .section-header h2 {
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .comparison-table {
    border: 1px solid rgba(255, 255, 255, 0.2);
    width: 100%;
    overflow-x: auto;
  }
  .comparison-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    background: rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }
  .comparison-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .comparison-row:last-child {
    border-bottom: none;
  }
  .comparison-col {
    padding: 20px 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #fff;
  }
  .comparison-col--feature {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
  }
  .comparison-col--polaris {
    color: #fff;
    font-weight: 700;
    text-align: center;
  }
  .comparison-col--premium,
  .comparison-col--cheap {
    text-align: center;
    opacity: 0.6;
  }
  .comparison-header .comparison-col--polaris {
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-left: 1px solid rgba(255, 255, 255, 0.3);
    border-right: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.08);
  }
  .comparison-row .comparison-col--polaris {
    border-left: 1px solid rgba(255, 255, 255, 0.15);
    border-right: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.03);
  }
  @media (max-width: 640px) {
    .why-polaris { padding: 64px 0; }
    .why-polaris .section-header { margin-bottom: 40px; }
    .comparison-header,
    .comparison-row { grid-template-columns: 1.4fr 1fr 1fr 1fr; }
    .comparison-col { padding: 14px 8px; font-size: 12px; }
    .comparison-col--feature { font-size: 10px; letter-spacing: 0.04em; }
    .comparison-header .comparison-col { font-size: 9px; letter-spacing: 0.06em; }
    .comparison-header .comparison-col--polaris { font-size: 9px; letter-spacing: 0.06em; }
  }
</style>

<section class="why-polaris section--black fade-in">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="comparison-table" role="table" aria-label="{{ section.settings.heading }}">
      <div class="comparison-header" role="row">
        <div class="comparison-col comparison-col--feature" role="columnheader"></div>
        <div class="comparison-col comparison-col--polaris" role="columnheader">POLARIS CAR CARE</div>
        <div class="comparison-col comparison-col--premium" role="columnheader">PREMIUM BRANDS</div>
        <div class="comparison-col comparison-col--cheap" role="columnheader">CHEAP BRANDS</div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'row' %}
          <div class="comparison-row" role="row" {{ block.shopify_attributes }}>
            <div class="comparison-col comparison-col--feature" role="cell">{{ block.settings.feature }}</div>
            <div class="comparison-col comparison-col--polaris" role="cell">{{ block.settings.polaris_value }}</div>
            <div class="comparison-col comparison-col--premium" role="cell">{{ block.settings.premium_value }}</div>
            <div class="comparison-col comparison-col--cheap" role="cell">{{ block.settings.cheap_value }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Polaris Comparison",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "WHY POLARIS?"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Price"
        },
        {
          "type": "text",
          "id": "polaris_value",
          "label": "Polaris value",
          "default": "✓ $29.99"
        },
        {
          "type": "text",
          "id": "premium_value",
          "label": "Premium brand value",
          "default": "✗ $60-80+"
        },
        {
          "type": "text",
          "id": "cheap_value",
          "label": "Cheap brand value",
          "default": "✗ Poor Quality"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Polaris Comparison",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature": "Price",
            "polaris_value": "✓ $29.99",
            "premium_value": "✗ $60–80+",
            "cheap_value": "✗ $8–12"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "GSM Rating",
            "polaris_value": "✓ 1200 GSM",
            "premium_value": "✓ 800–1000 GSM",
            "cheap_value": "✗ 300–500 GSM"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Material Quality",
            "polaris_value": "✓ 70/30 Blend",
            "premium_value": "~ Varies",
            "cheap_value": "✗ Low Grade"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Shipping Cost",
            "polaris_value": "✓ Always Free",
            "premium_value": "✗ $8–15",
            "cheap_value": "~ Sometimes Free"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Community Tested",
            "polaris_value": "✓ Yes",
            "premium_value": "✗ Lab Only",
            "cheap_value": "✗ No"
          }
        },
        {
          "type": "row",
          "settings": {
            "feature": "Founder Accessible",
            "polaris_value": "✓ DM us anytime",
            "premium_value": "✗ Corporate",
            "cheap_value": "✗ No response"
          }
        }
      ]
    }
  ]
}
{% endschema %}
