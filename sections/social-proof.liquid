          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "Absolutely incredible towel. The 1200 GSM is a game changer on my ceramic coated car."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "March 2025"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video Slot",
      "limit": 6,
      "settings": [
        {
          "type": "textarea",
          "id": "embed_code",
          "label": "TikTok or Instagram embed code"
        },
        {
          "type": "text",
          "id": "mp4_url",
          "label": "MP4 video URL (alternative)"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Poster image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        }
      ]
    },
    {
      "type": "photo",
      "name": "Community Photo",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Proof (Reviews + Videos + Photos)",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "name": "Marcus T.",
            "stars": 5,
            "review_text": "Absolutely incredible towel. The 1200 GSM is a game changer on my ceramic coated car.",
            "date": "March 2025"
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Jordan K.",
            "stars": 5,
            "review_text": "Finally a drying towel that doesn't leave water spots. Polaris just earned a customer for life.",
            "date": "February 2025"
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Tyler M.",
            "stars": 5,
            "review_text": "These guys actually know cars. Product quality is insane for the price.",
            "date": "January 2025"
          }
        }
      ]
    }
  ]
}
{% endschema %}
