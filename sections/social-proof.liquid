<style>
  .sp-section {
    background: #000;
    padding: 96px 0;
    font-family: 'DM Sans', sans-serif;
    overflow: hidden;
  }

  @media (max-width: 640px) { .sp-section { padding: 64px 0; } }

  .sp-header {
    text-align: center;
    margin-bottom: 56px;
    padding: 0 24px;
  }

  .sp-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 16px;
  }

  .sp-rating {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    color: #fff;
    letter-spacing: 0.02em;
    line-height: 1;
    margin-bottom: 8px;
  }

  .sp-rating-sub {
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  /* Marquee */
  .sp-marquee-wrap {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .sp-marquee-wrap::before,
  .sp-marquee-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }
  .sp-marquee-wrap::before {
    left: 0;
    background: linear-gradient(to right, #000, transparent);
  }
  .sp-marquee-wrap::after {
    right: 0;
    background: linear-gradient(to left, #000, transparent);
  }

  .sp-track {
    display: flex;
    width: max-content;
    gap: 0;
  }

  .sp-card {
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.07);
    padding: 36px 32px;
    width: 320px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-right: 16px;
  }

  @media (max-width: 480px) {
    .sp-card {
      width: 280px;
      padding: 28px 24px;
    }
    .sp-marquee-wrap::before,
    .sp-marquee-wrap::after {
      width: 48px;
    }
  }

  .sp-card-top {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .sp-avatar {
    width: 36px;
    height: 36px;
    background: #fff;
    color: #000;
    font-weight: 700;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sp-name {
    font-weight: 700;
    font-size: 13px;
    color: #fff;
    letter-spacing: 0.03em;
  }

  .sp-date {
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    margin-top: 2px;
    letter-spacing: 0.05em;
  }

  .sp-stars {
    color: #fff;
    font-size: 12px;
    letter-spacing: 3px;
  }

  .sp-text {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.55);
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=Barlow:wght@300&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<section class="sp-section fade-in">

  <div class="sp-header">
    <p class="sp-eyebrow">{{ section.settings.rating_subtext }}</p>
    <div class="sp-rating">{{ section.settings.avg_rating }} ★★★★★</div>
    <p class="sp-rating-sub">Verified customer reviews</p>
  </div>

  <div class="sp-marquee-wrap">
    <div class="sp-track" id="sp-track">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <div class="sp-card" {{ block.shopify_attributes }}>
            <div class="sp-card-top">
              <div class="sp-avatar">{{ block.settings.name | slice: 0, 1 }}</div>
              <div>
                <div class="sp-name">{{ block.settings.name }}</div>
                <div class="sp-date">{{ block.settings.date }}</div>
              </div>
            </div>
            {% assign star_count = block.settings.stars | default: 5 %}
            <div class="sp-stars">{% for i in (1..star_count) %}★{% endfor %}</div>
            <p class="sp-text">{{ block.settings.review_text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

</section>

<script>
(function () {
  var track = document.getElementById('sp-track');
  if (!track) return;
  var GAP = 0;
  var origCards = Array.from(track.querySelectorAll('.sp-card'));
  if (!origCards.length) return;

  function cloneSet() {
    origCards.forEach(function (card) {
      var clone = card.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      track.appendChild(clone);
    });
  }

  cloneSet();
  while (track.scrollWidth < window.innerWidth * 2.5) { cloneSet(); }

  var origWidth = 0;
  origCards.forEach(function (card) {
    origWidth += card.offsetWidth + 16; /* 16px margin-right matches CSS */
  });

  var styleEl = document.createElement('style');
  styleEl.textContent = '@keyframes sp-infinite{from{transform:translateX(0)}to{transform:translateX(-' + origWidth + 'px)}}';
  document.head.appendChild(styleEl);

  track.style.animation = 'sp-infinite 40s linear infinite';

  track.addEventListener('mouseenter', function () { track.style.animationPlayState = 'paused'; });
  track.addEventListener('mouseleave', function () { track.style.animationPlayState = 'running'; });
  track.addEventListener('touchstart', function () { track.style.animationPlayState = 'paused'; }, { passive: true });
  track.addEventListener('touchend', function () { track.style.animationPlayState = 'running'; }, { passive: true });
})();
</script>

{% schema %}
{
  "name": "Social Proof",
  "settings": [
    {
      "type": "text",
      "id": "avg_rating",
      "label": "Star rating display",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "rating_subtext",
      "label": "Rating subtext",
      "default": "From the Polaris community"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Marcus T."
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "Absolutely incredible towel. The 1200 GSM is a game changer on my ceramic coated car."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "March 2025"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Proof"
    }
  ]
}
{% endschema %}
