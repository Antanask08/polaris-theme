<style>
  .sp-section {
    background: #000;
    padding: 96px 48px;
    font-family: 'DM Sans', sans-serif;
  }

  @media (max-width: 640px) { .sp-section { padding: 64px 24px; } }

  .sp-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .sp-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 20px;
  }

  .sp-rating {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 5rem);
    color: #fff;
    letter-spacing: 0.02em;
    line-height: 1;
    margin-bottom: 8px;
  }

  .sp-rating-sub {
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  .sp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.08);
  }

  @media (max-width: 900px) {
    .sp-grid {
      grid-template-columns: 1fr;
    }
  }

  .sp-card {
    background: #000;
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sp-card-top {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .sp-avatar {
    width: 38px;
    height: 38px;
    background: #fff;
    color: #000;
    font-weight: 700;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sp-name {
    font-weight: 700;
    font-size: 13px;
    color: #fff;
    letter-spacing: 0.03em;
  }

  .sp-date {
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    margin-top: 2px;
    letter-spacing: 0.05em;
  }

  .sp-stars {
    color: #fff;
    font-size: 13px;
    letter-spacing: 3px;
  }

  .sp-text {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.6);
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=Barlow:wght@300&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<section class="sp-section fade-in">

  <div class="sp-header">
    <p class="sp-eyebrow">From the Polaris community</p>
    <div class="sp-rating">{{ section.settings.avg_rating }} ★★★★★</div>
    <p class="sp-rating-sub">{{ section.settings.rating_subtext }}</p>
  </div>

  <div class="sp-grid">
    {% for block in section.blocks %}
      {% if block.type == 'review' %}
        <div class="sp-card" {{ block.shopify_attributes }}>
          <div class="sp-card-top">
            <div class="sp-avatar">{{ block.settings.name | slice: 0, 1 }}</div>
            <div>
              <div class="sp-name">{{ block.settings.name }}</div>
              <div class="sp-date">{{ block.settings.date }}</div>
            </div>
          </div>
          <div class="sp-stars">{% for i in (1..block.settings.stars) %}★{% endfor %}</div>
          <p class="sp-text">{{ block.settings.review_text }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>

</section>

{% schema %}
{
  "name": "Social Proof",
  "settings": [
    {
      "type": "text",
      "id": "avg_rating",
      "label": "Star rating display",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "rating_subtext",
      "label": "Rating subtext",
      "default": "Verified reviews"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Marcus T."
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "Absolutely incredible towel. The 1200 GSM is a game changer on my ceramic coated car."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "March 2025"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Proof"
    }
  ]
}
{% endschema %}
