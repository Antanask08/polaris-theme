            <div class="dp-step-content">
              <div class="dp-step-label">Water & Cycle</div>
              <div class="dp-step-desc">Set washer to cold or warm water, gentle cycle. Works in standard and HE machines.</div>
            </div>
          </div>
          <div class="dp-step">
            <div class="dp-step-num">03</div>
            <div class="dp-step-content">
              <div class="dp-step-label">Dry</div>
              <div class="dp-step-desc">Air dry or tumble dry on low heat. Never use fabric softener or dryer sheets.</div>
            </div>
          </div>
          <div class="dp-step">
            <div class="dp-step-num">04</div>
            <div class="dp-step-content">
              <div class="dp-step-label">Keep Separate</div>
              <div class="dp-step-desc">Wash microfiber on its own — never with cotton towels. Lint transfer degrades fiber performance.</div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  {%- comment -%} ── PAIR WITH NOVA CTA ── {%- endcomment -%}
  <div class="dp-pair-section">
    <div>
      <p class="dp-pair-eyebrow">Complete the Setup</p>
      <h2 class="dp-pair-heading">Designed to<br>Pair with<br>The Nova.</h2>
      <p class="dp-pair-body">One detergent, one towel — built together from the same philosophy. Clean it right, protect your paint, and make both last longer.</p>
    </div>
    <a href="/products/the-nova" class="dp-pair-cta">Shop The Nova →</a>
  </div>

</div>

<script>
(function () {
  /* ── Arrow + thumbnail gallery ── */
  var slidesWrap = document.getElementById('dp-slides');
  var prevBtn = document.getElementById('dp-prev');
  var nextBtn = document.getElementById('dp-next');
  var thumbBtns = Array.prototype.slice.call(document.querySelectorAll('.dp-thumb'));
  if (slidesWrap) {
    var slides = Array.prototype.slice.call(slidesWrap.querySelectorAll('.dp-main-img'));
    var current = 0;
    function showSlide(idx) {
      slides.forEach(function (s) { s.classList.add('dp-slide-hidden'); });
      if (slides[idx]) slides[idx].classList.remove('dp-slide-hidden');
      current = idx;
      if (prevBtn) prevBtn.hidden = current === 0;
      if (nextBtn) nextBtn.hidden = current === slides.length - 1;
      thumbBtns.forEach(function (t, i) { t.classList.toggle('is-active', i === current); });
    }
    if (prevBtn) prevBtn.addEventListener('click', function () { if (current > 0) showSlide(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { if (current < slides.length - 1) showSlide(current + 1); });
    thumbBtns.forEach(function (t, i) { t.addEventListener('click', function () { showSlide(i); }); });
    showSlide(0);
  }

  /* ── Purchase section v2 ── */
  var VARIANT_MAP   = { 1: 46963596230787, 2: 46963596263555, 3: 46963596296323 };
  var OT_PRICES     = { 1: '16.99', 2: '29.99', 3: '41.99' };
  var SUB_PRICES    = { 1: '15.29', 2: '26.99', 3: '37.79' };
  var OT_FREE_SHIP  = { 1: false,   2: true,    3: true    };
  var OT_SAVE       = { 1: '',      2: 'Save $4', 3: 'Save $9 — Best Value' };

  var priceEl       = document.getElementById('dp-price-display');
  var priceMeta     = document.getElementById('dp-price-meta');
  var freqEl        = document.getElementById('dp-frequency');
  var perkEl        = document.getElementById('dp-sub-perk');
  var qtyWrap       = document.getElementById('dp-quantity-wrap');
  var qtyInput      = document.getElementById('dp-qty-input');
  var variantInput  = document.querySelector('#dp-form input[name="id"]');
  var sellingPlanEl = document.getElementById('dp-selling-plan-input');
  var btnOnetime    = document.getElementById('dp-btn-onetime');
  var btnSubscribe  = document.getElementById('dp-btn-subscribe');
  var ctaBtn        = document.getElementById('dp-cta-btn');
  var ctaLabel      = document.getElementById('dp-cta-label');
  var ctaPrice      = document.getElementById('dp-cta-price');
  var isSubscribe   = false;
  var selectedPlan  = '{{ section.settings.selling_plan_30 }}';
  var currentPack   = 1;
  var currentVariantId = VARIANT_MAP[1];

  function renderPriceMeta(freeShip, saveText, extraBadge) {
    if (!priceMeta) return;
    priceMeta.innerHTML = '';
    if (freeShip) {
      var fs = document.createElement('span');
      fs.className = 'dp-badge dp-badge--free-ship';
      fs.textContent = 'Free Shipping';
      priceMeta.appendChild(fs);
    } else {
      var sh = document.createElement('span');
      sh.className = 'dp-badge dp-badge--shipping';
      sh.textContent = '+ Shipping';
      priceMeta.appendChild(sh);
    }
    if (saveText) {
      var sv = document.createElement('span');
      sv.className = 'dp-badge dp-badge--save';
      sv.textContent = saveText;
      priceMeta.appendChild(sv);
    }
    if (extraBadge) {
      var eb = document.createElement('span');
      eb.className = 'dp-badge dp-badge--save';
      eb.textContent = extraBadge;
      priceMeta.appendChild(eb);
    }
  }

  function applyVariant(packSize) {
    currentPack      = packSize;
    currentVariantId = VARIANT_MAP[packSize];
    if (variantInput) variantInput.value = currentVariantId;
    if (qtyInput) qtyInput.value = 1;
  }

  /* One-time pack buttons */
  document.querySelectorAll('.dp-qty-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.dp-qty-btn').forEach(function (b) { b.classList.remove('is-selected'); });
      btn.classList.add('is-selected');
      var pack = parseInt(btn.dataset.pack, 10);
      applyVariant(pack);
      var price = OT_PRICES[pack];
      if (priceEl) priceEl.textContent = '$' + price;
      if (ctaPrice) ctaPrice.textContent = '$' + price;
      renderPriceMeta(OT_FREE_SHIP[pack], OT_SAVE[pack]);
    });
  });

  /* Subscribe pack buttons */
  document.querySelectorAll('.dp-sub-pack-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.dp-sub-pack-btn').forEach(function (b) { b.classList.remove('is-selected'); });
      btn.classList.add('is-selected');
      var pack = parseInt(btn.dataset.pack, 10);
      applyVariant(pack);
      var price = SUB_PRICES[pack];
      if (priceEl) priceEl.textContent = '$' + price;
      if (ctaPrice) ctaPrice.textContent = '$' + price;
      renderPriceMeta(true, 'Save 10%');
    });
  });

  function setOneTime() {
    isSubscribe = false;
    btnOnetime.classList.add('is-selected');
    btnSubscribe.classList.remove('is-selected');
    if (qtyWrap) qtyWrap.style.display = '';
    freqEl.style.display = 'none';
    perkEl.style.display = 'none';
    sellingPlanEl.value = '';
    /* Restore one-time state from selected pack btn */
    var activeOT = document.querySelector('.dp-qty-btn.is-selected');
    if (activeOT) {
      var pack = parseInt(activeOT.dataset.pack, 10);
      applyVariant(pack);
      var price = OT_PRICES[pack];
      if (priceEl) priceEl.textContent = '$' + price;
      if (ctaPrice) ctaPrice.textContent = '$' + price;
      renderPriceMeta(OT_FREE_SHIP[pack], OT_SAVE[pack]);
    }
  }

  function setSubscribe() {
    isSubscribe = true;
    btnSubscribe.classList.add('is-selected');
    btnOnetime.classList.remove('is-selected');
    if (qtyWrap) qtyWrap.style.display = 'none';
    freqEl.style.display = '';
    perkEl.style.display = '';
    sellingPlanEl.value = selectedPlan;
    /* Use selected subscribe pack btn */
    var activeSub = document.querySelector('.dp-sub-pack-btn.is-selected');
    if (activeSub) {
      var pack = parseInt(activeSub.dataset.pack, 10);
      applyVariant(pack);
      var price = SUB_PRICES[pack];
      if (priceEl) priceEl.textContent = '$' + price;
      if (ctaPrice) ctaPrice.textContent = '$' + price;
    } else {
      applyVariant(1);
      if (priceEl) priceEl.textContent = '$' + SUB_PRICES[1];
      if (ctaPrice) ctaPrice.textContent = '$' + SUB_PRICES[1];
    }
    renderPriceMeta(true, 'Save 10%');
  }

  btnOnetime   && btnOnetime.addEventListener('click', setOneTime);
  btnSubscribe && btnSubscribe.addEventListener('click', setSubscribe);

  /* Frequency buttons */
  document.querySelectorAll('.dp-freq-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.dp-freq-btn').forEach(function (b) { b.classList.remove('is-selected'); });
      btn.classList.add('is-selected');
      selectedPlan = btn.dataset.plan || '';
      if (isSubscribe) sellingPlanEl.value = selectedPlan;
    });
  });

  /* Init default one-time state */
  (function () {
    var firstOT = document.querySelector('.dp-qty-btn.is-selected');
    if (firstOT) {
      var pack = parseInt(firstOT.dataset.pack, 10) || 1;
      applyVariant(pack);
      if (priceEl) priceEl.textContent = '$' + OT_PRICES[pack];
      if (ctaPrice) ctaPrice.textContent = '$' + OT_PRICES[pack];
      renderPriceMeta(OT_FREE_SHIP[pack], OT_SAVE[pack]);
    }
  })();

  /* CTA — cart add */
  ctaBtn && ctaBtn.addEventListener('click', function () {
    var body = { id: currentVariantId, quantity: 1 };
    if (isSubscribe && sellingPlanEl.value) body.selling_plan = sellingPlanEl.value;

    var orig = ctaLabel.textContent;
    ctaLabel.textContent = 'Adding…';
    ctaBtn.disabled = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      ctaLabel.textContent = 'Added ✓';
      document.dispatchEvent(new CustomEvent('cart:open'));
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      setTimeout(function () {
        ctaLabel.textContent = orig;
        ctaBtn.disabled = false;
      }, 2200);
    })
    .catch(function () {
      ctaLabel.textContent = orig;
      ctaBtn.disabled = false;
    });
  });
  /* ── Tabs ── */
  (function () {
    var tabBtns = document.querySelectorAll('.dp-tab-btn');
    var tabPanels = document.querySelectorAll('.dp-tab-panel');
    tabBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var target = btn.getAttribute('data-tab');
        tabBtns.forEach(function (b) { b.classList.remove('is-active'); });
        tabPanels.forEach(function (p) { p.classList.remove('is-active'); });
        btn.classList.add('is-active');
        var panel = document.getElementById('dp-tab-' + target);
        if (panel) panel.classList.add('is-active');
      });
    });
  })();

  /* ── Reviews — continuous infinite scroll ── */
  (function () {
    var track = document.getElementById('dp-reviews-track');
    if (!track) return;
    /* Clone all cards so we have original + copy = seamless loop */
    Array.from(track.querySelectorAll('.dp-review')).forEach(function (c) {
      track.appendChild(c.cloneNode(true));
    });
    /* Pause on hover */
    var wrap = track.closest('.dp-reviews-track-wrap') || track.parentElement;
    wrap.addEventListener('mouseenter', function () { track.classList.add('is-paused'); });
    wrap.addEventListener('mouseleave', function () { track.classList.remove('is-paused'); });
    /* Hide arrow buttons — not needed for continuous mode */
    var arrowEl = document.querySelector('.dp-rev-arrows');
    if (arrowEl) arrowEl.style.display = 'none';
  })();
})();
</script>

