        { "type": "spec", "settings": { "label": "Wash Cycle", "value": "Gentle" } },
        { "type": "spec", "settings": { "label": "Dry Method", "value": "Air / Tumble Low" } },
        { "type": "spec", "settings": { "label": "pH Range", "value": "6.5–8 Neutral" } },
        { "type": "spec", "settings": { "label": "Scent", "value": "Unscented" } },
        { "type": "spec", "settings": { "label": "Bottle Size", "value": "16 oz" } },
        { "type": "spec", "settings": { "label": "Yield", "value": "15–20 Washes" } }
      ]
    }
  ]
}
