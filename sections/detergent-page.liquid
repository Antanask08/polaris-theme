<script>
(function () {
  /* ── Arrow + thumbnail gallery ── */
  var slidesWrap = document.getElementById('dp-slides');
  var prevBtn = document.getElementById('dp-prev');
  var nextBtn = document.getElementById('dp-next');
  var thumbBtns = Array.prototype.slice.call(document.querySelectorAll('.dp-thumb'));
  if (slidesWrap) {
    var slides = Array.prototype.slice.call(slidesWrap.querySelectorAll('.dp-main-img'));
    var current = 0;
    function showSlide(idx) {
      slides.forEach(function (s) { s.classList.add('dp-slide-hidden'); });
      if (slides[idx]) slides[idx].classList.remove('dp-slide-hidden');
      current = idx;
      if (prevBtn) prevBtn.hidden = current === 0;
      if (nextBtn) nextBtn.hidden = current === slides.length - 1;
      thumbBtns.forEach(function (t, i) { t.classList.toggle('is-active', i === current); });
    }
    if (prevBtn) prevBtn.addEventListener('click', function () { if (current > 0) showSlide(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { if (current < slides.length - 1) showSlide(current + 1); });
    thumbBtns.forEach(function (t, i) { t.addEventListener('click', function () { showSlide(i); }); });
    showSlide(0);
  }

  var ONE_TIME_PRICE  = '${{ one_time_price }}';
  var SUBSCRIBE_PRICE = '${{ subscribe_price }}';

  var priceEl       = document.getElementById('dp-price-display');
  var priceNoteEl   = document.getElementById('dp-price-note');
  var freqEl        = document.getElementById('dp-frequency');
  var perkEl        = document.getElementById('dp-sub-perk');
  var sellingPlanEl = document.getElementById('dp-selling-plan-input');
  var btnOnetime    = document.getElementById('dp-btn-onetime');
  var btnSubscribe  = document.getElementById('dp-btn-subscribe');
  var ctaBtn        = document.getElementById('dp-cta-btn');
  var ctaLabel      = document.getElementById('dp-cta-label');
  var ctaPrice      = document.getElementById('dp-cta-price');
  var isSubscribe   = false;
  var selectedPlan  = '{{ section.settings.selling_plan_30 }}';
  var qty           = 1;

  function setOneTime() {
    isSubscribe = false;
    btnOnetime.classList.add('is-selected');
    btnSubscribe.classList.remove('is-selected');
    priceEl.textContent    = ONE_TIME_PRICE;
    priceNoteEl.textContent = 'One-time purchase';
    freqEl.style.display   = 'none';
    perkEl.style.display   = 'none';
    sellingPlanEl.value    = '';
    if (ctaPrice) ctaPrice.textContent = ONE_TIME_PRICE;
  }

  function setSubscribe() {
    isSubscribe = true;
    btnSubscribe.classList.add('is-selected');
    btnOnetime.classList.remove('is-selected');
    priceEl.textContent     = SUBSCRIBE_PRICE;
    priceNoteEl.textContent = 'Subscribe & Save — cancel anytime';
    if (ctaPrice) ctaPrice.textContent = SUBSCRIBE_PRICE;
    freqEl.style.display    = '';
    perkEl.style.display    = '';
    sellingPlanEl.value     = selectedPlan;
  }

  btnOnetime  && btnOnetime.addEventListener('click', setOneTime);
  btnSubscribe && btnSubscribe.addEventListener('click', setSubscribe);

  /* Frequency buttons */
  document.querySelectorAll('.dp-freq-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.dp-freq-btn').forEach(function (b) { b.classList.remove('is-selected'); });
      btn.classList.add('is-selected');
      selectedPlan = btn.dataset.plan || '';
      if (isSubscribe) sellingPlanEl.value = selectedPlan;
    });
  });

  /* CTA — cart add */
  ctaBtn && ctaBtn.addEventListener('click', function () {
    var variantId = {{ product.first_available_variant.id }};
    var body = { id: variantId, quantity: qty };
    if (isSubscribe && sellingPlanEl.value) body.selling_plan = sellingPlanEl.value;

    var orig = ctaLabel.textContent;
    ctaLabel.textContent = 'Adding…';
    ctaBtn.disabled = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      ctaLabel.textContent = 'Added ✓';
      document.dispatchEvent(new CustomEvent('cart:open'));
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      setTimeout(function () {
        ctaLabel.textContent = orig;
        ctaBtn.disabled = false;
      }, 2200);
    })
    .catch(function () {
      ctaLabel.textContent = orig;
      ctaBtn.disabled = false;
    });
  });
})();
</script>

