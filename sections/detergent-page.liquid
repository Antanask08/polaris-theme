<style>
  /* ── Reset & base ─────────────────────────────────────── */
  .dp-wrap * { box-sizing: border-box; }

  /* ── Top section: 2-col grid ──────────────────────────── */
  .dp-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #fff;
  }
  @media (max-width: 900px) {
    .dp-top { grid-template-columns: 1fr; }
  }

  /* ── Image column ─────────────────────────────────────── */
  /* Sticky wrapper — fills the grid cell height, enables scroll-sticky */
  .dp-gallery-stick {
    position: sticky;
    top: calc(var(--announcement-height, 40px) + var(--header-height, 60px));
    align-self: start;
    background: #fff;
  }
  @media (max-width: 900px) {
    .dp-gallery-stick { position: relative; top: auto; }
  }
  /* Image box */
  .dp-gallery {
    width: 100%;
  }
  .dp-main-img-wrap {
    width: 100%;
    height: clamp(280px, 36vw, 520px);
    overflow: hidden;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
  }
  @media (max-width: 900px) {
    .dp-main-img-wrap { height: clamp(240px, 70vw, 440px); padding: 20px; }
  }
  .dp-main-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .dp-slide-hidden { display: none; }
  .dp-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    color: rgba(0,0,0,0.15);
    background: #f0f0f0;
  }
  .dp-img-placeholder svg {
    width: 48px;
    height: 48px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1;
  }
  .dp-img-placeholder span {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  /* Arrow navigation */
  .dp-main-img-wrap { position: relative; }
  .dp-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.85);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background 120ms, opacity 120ms;
    box-shadow: 0 1px 6px rgba(0,0,0,0.15);
  }
  .dp-arrow:hover { background: #fff; }
  .dp-arrow svg { display: block; }
  .dp-arrow-prev { left: 12px; }
  .dp-arrow-next { right: 12px; }
  .dp-arrow[hidden] { display: none; }
  /* Thumbnail strip */
  .dp-thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
  }
  .dp-thumb {
    background: none;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 200ms;
    width: 96px;
    height: 96px;
    flex-shrink: 0;
  }
  .dp-thumb.is-active,
  .dp-thumb:hover { border-color: #000; }
  .dp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    background: #fff;
  }

  /* ── Info column ──────────────────────────────────────── */
  .dp-info {
    padding: 48px 52px 32px;
    display: flex;
    flex-direction: column;
    align-self: start;
  }
  @media (max-width: 1100px) { .dp-info { padding: 44px 40px 28px; } }
  @media (max-width: 900px)  { .dp-info { padding: 36px 24px 24px; } }
  @media (max-width: 480px)  { .dp-info { padding: 28px 20px 20px; } }

  /* Coming Soon badge */
  .dp-coming-soon {
    display: inline-block;
    align-self: flex-start;
    font-family: 'DM Sans', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: #000;
    color: #fff;
    padding: 4px 10px;
    margin-bottom: 10px;
  }

  .dp-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
    margin-bottom: 10px;
  }

  .dp-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1;
    color: #000;
    margin-bottom: 20px;
  }

  /* Price row */
  .dp-price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }
  .dp-price {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1.9rem;
    color: #000;
    line-height: 1;
  }
  .dp-price-note {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    color: rgba(0,0,0,0.4);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .dp-divider {
    width: 100%;
    height: 1px;
    background: rgba(0,0,0,0.08);
    margin-bottom: 20px;
  }

  .dp-short-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(0,0,0,0.65);
    margin-bottom: 20px;
  }

  /* Spec pills */
  .dp-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }
  .dp-spec-pill {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 1px solid rgba(0,0,0,0.15);
    color: #000;
    background: #fff;
  }

  /* ── Subscription toggle ──────────────────────────────── */
  .dp-purchase-type {
    margin-bottom: 16px;
  }
  .dp-purchase-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.45);
    margin-bottom: 10px;
    display: block;
  }
  .dp-toggle {
    display: flex;
    border: 1px solid rgba(0,0,0,0.18);
    width: 100%;
  }
  .dp-toggle-btn {
    flex: 1;
    padding: 12px 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    background: #fff;
    color: rgba(0,0,0,0.45);
    cursor: pointer;
    transition: background 160ms, color 160ms;
  }
  .dp-toggle-btn.is-selected {
    background: #000;
    color: #fff;
  }
  .dp-toggle-btn:first-child {
    border-right: 1px solid rgba(0,0,0,0.18);
  }

  /* ── Frequency selector ───────────────────────────────── */
  .dp-frequency {
    margin-bottom: 14px;
    animation: dp-fade-in 180ms ease;
  }
  @keyframes dp-fade-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .dp-freq-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.45);
    margin-bottom: 8px;
    display: block;
  }
  .dp-freq-opts {
    display: flex;
    gap: 8px;
  }
  .dp-freq-btn {
    flex: 1;
    padding: 9px 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgba(0,0,0,0.18);
    background: #fff;
    color: rgba(0,0,0,0.5);
    cursor: pointer;
    transition: border-color 160ms, background 160ms, color 160ms;
    white-space: nowrap;
  }
  .dp-freq-btn.is-selected {
    border-color: #000;
    border-width: 2px;
    background: #000;
    color: #fff;
  }

  /* ── Subscribe free shipping callout ─────────────────── */
  .dp-sub-perk {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
    background: rgba(0,0,0,0.04);
    padding: 10px 14px;
    margin-bottom: 16px;
    border-left: 3px solid #000;
    animation: dp-fade-in 180ms ease;
  }
  .dp-sub-perk svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: #000;
    stroke-width: 2;
    flex-shrink: 0;
  }

  /* ── Price badges ─────────────────────────────────────── */
  .dp-price-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .dp-badge {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
  }
  .dp-badge--shipping {
    color: rgba(0,0,0,0.4);
    border: 1px solid rgba(0,0,0,0.12);
  }
  .dp-badge--free-ship {
    background: #000;
    color: #fff;
  }
  .dp-badge--save {
    background: rgba(0,0,0,0.06);
    color: #000;
    border: 1px solid rgba(0,0,0,0.12);
  }

  /* ── Quantity selector ────────────────────────────────── */
  .dp-quantity-wrap {
    margin-bottom: 14px;
    animation: dp-fade-in 180ms ease;
  }
  .dp-qty-opts {
    display: flex;
    gap: 8px;
  }
  .dp-qty-btn {
    flex: 1;
    padding: 9px 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgba(0,0,0,0.18);
    background: #fff;
    color: rgba(0,0,0,0.5);
    cursor: pointer;
    transition: border-color 160ms, background 160ms, color 160ms;
    white-space: nowrap;
  }
  .dp-qty-btn.is-selected {
    border-color: #000;
    border-width: 2px;
    background: #000;
    color: #fff;
  }

  .dp-sub-pack-btn {
    flex: 1;
    padding: 9px 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgba(0,0,0,0.18);
    background: #fff;
    color: rgba(0,0,0,0.5);
    cursor: pointer;
    transition: border-color 160ms, background 160ms, color 160ms;
    white-space: nowrap;
  }
  .dp-sub-pack-btn.is-selected {
    border-color: #000;
    border-width: 2px;
    background: #000;
    color: #fff;
  }

  .dp-sub-cancel-note {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-style: italic;
    color: rgba(0,0,0,0.38);
    margin-top: 14px;
    margin-bottom: 10px;
    line-height: 1.5;
  }
  .dp-sub-trust-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .dp-sub-trust-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.38);
  }
  .dp-sub-trust-item svg {
    width: 12px;
    height: 12px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    flex-shrink: 0;
  }

  /* ── CTA ──────────────────────────────────────────────── */
  .dp-cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 17px 24px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: #000;
    color: #fff;
    border: 2px solid #000;
    cursor: pointer;
    transition: background 180ms, color 180ms;
    margin-bottom: 14px;
  }
  .dp-cta-btn:hover { background: #222; }
  .dp-cta-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .dp-preorder-note {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.35);
    text-align: center;
    margin-bottom: 16px;
  }

  /* ── Trust row ────────────────────────────────────────── */
  .dp-trust-row {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .dp-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.55);
  }
  .dp-trust-item svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    flex-shrink: 0;
  }

  /* Guarantee */
  .dp-guarantee {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: rgba(0,0,0,0.5);
    line-height: 1.5;
    margin-bottom: 0;
  }
  .dp-guarantee svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: #000;
    stroke-width: 1.5;
    flex-shrink: 0;
    margin-top: 1px;
    opacity: 0.5;
  }

  /* ── Below fold: description sections ────────────────── */
  .dp-desc-section {
    background: #000;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
  }
  .dp-desc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  @media (max-width: 768px) {
    .dp-desc-grid { grid-template-columns: 1fr; }
  }
  .dp-desc-left {
    padding: 56px 56px 56px 60px;
    border-right: 1px solid rgba(255,255,255,0.06);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .dp-desc-right {
    padding: 56px 60px 56px 56px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  @media (max-width: 900px) {
    .dp-desc-left, .dp-desc-right { padding: 40px 24px; }
    .dp-desc-left { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
  }

  /* ── Tabbed specs ────────────────────────────────────── */
  .dp-tabs-block {
    background: #000;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .dp-tabs-nav {
    display: flex;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 0 60px;
  }
  @media (max-width: 900px) { .dp-tabs-nav { padding: 0 24px; } }
  .dp-tab-btn {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 18px 0;
    margin-right: 36px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    transition: color 150ms, border-color 150ms;
    margin-bottom: -1px;
  }
  .dp-tab-btn.is-active { color: #fff; border-bottom-color: #fff; }
  .dp-tab-panel { display: none; padding: 0 60px; }
  .dp-tab-panel.is-active { display: block; }
  @media (max-width: 900px) { .dp-tab-panel { padding: 0 24px; } }
  /* Table rows */
  .dp-spec-table { padding: 0; }
  @media (max-width: 900px) { .dp-spec-table { padding: 0; } }
  .dp-spec-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .dp-spec-row:last-child { border-bottom: none; }
  .dp-spec-key {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.45);
  }
  .dp-spec-val {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    text-align: right;
  }
  /* Steps */
  .dp-steps { padding: 8px 60px 8px 48px; }
  @media (max-width: 900px) { .dp-steps { padding: 0 24px 32px; } }
  .dp-step {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    padding: 20px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .dp-step:last-child { border-bottom: none; }
  .dp-step-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    color: rgba(255,255,255,0.15);
    letter-spacing: 0.05em;
    flex-shrink: 0;
    width: 28px;
    padding-top: 2px;
  }
  .dp-step-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    margin-bottom: 4px;
  }
  .dp-step-desc {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.88rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.45);
  }
  .dp-section-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.2);
    margin-bottom: 16px;
  }
  .dp-section-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: 0.01em;
    color: #fff;
    margin-bottom: 0;
    flex: 1;
  }
  .dp-section-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    margin-top: 28px;
    line-height: 1.8;
    color: rgba(255,255,255,0.55);
    max-width: 420px;
  }

  /* Formula checklist */
  .dp-checklist {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .dp-check-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .dp-check-item:last-child { border-bottom: none; }
  .dp-check-mark {
    width: 20px;
    height: 20px;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
    font-size: 10px;
    color: #fff;
    font-weight: 700;
  }
  .dp-check-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 2px;
  }
  .dp-check-desc {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
  }

  /* ── Reviews ─────────────────────────────────────────── */
  .dp-reviews-section {
    background: #000;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 56px 60px;
  }
  @media (max-width: 900px) { .dp-reviews-section { padding: 40px 24px; } }
  .dp-reviews-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .dp-reviews-stars-summary {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: 0.02em;
  }
  .dp-reviews-stars-summary span { color: rgba(255,255,255,0.4); font-size: 12px; }
  .dp-rev-arrows { display: flex; gap: 6px; }
  .dp-rev-arrow {
    width: 32px; height: 32px;
    border: 1px solid rgba(255,255,255,0.2);
    background: transparent;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: border-color 150ms, background 150ms;
  }
  .dp-rev-arrow:hover { border-color: #fff; background: rgba(255,255,255,0.06); }
  .dp-reviews-track-wrap {
    overflow: hidden;
  }
  .dp-reviews-track {
    display: flex;
    animation: dp-rev-scroll 22s linear infinite;
    will-change: transform;
  }
  .dp-reviews-track.is-paused { animation-play-state: paused; }
  @keyframes dp-rev-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .dp-review {
    min-width: calc(100% / 3);
    background: #000;
    border: 1px solid rgba(255,255,255,0.06);
    border-left: none;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
