<style>
  /* ── Reset & base ─────────────────────────────────────── */
  .dp-wrap * { box-sizing: border-box; }

  /* ── Top section: 2-col grid ──────────────────────────── */
  .dp-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #fff;
  }
  @media (max-width: 900px) {
    .dp-top { grid-template-columns: 1fr; }
  }

  /* ── Image column ─────────────────────────────────────── */
  /* Sticky wrapper — fills the grid cell height, enables scroll-sticky */
  .dp-gallery-stick {
    position: sticky;
    top: calc(var(--announcement-height, 40px) + var(--header-height, 60px));
    align-self: start;
    background: #fff;
  }
  @media (max-width: 900px) {
    .dp-gallery-stick { position: relative; top: auto; }
  }
  /* Image box */
  .dp-gallery {
    width: 100%;
  }
  .dp-main-img-wrap {
    width: 100%;
    height: clamp(280px, 36vw, 520px);
    overflow: hidden;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
  }
  @media (max-width: 900px) {
    .dp-main-img-wrap { height: clamp(240px, 70vw, 440px); padding: 20px; }
  }
  .dp-main-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .dp-slide-hidden { display: none; }
  .dp-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    color: rgba(0,0,0,0.15);
    background: #f0f0f0;
  }
  .dp-img-placeholder svg {
    width: 48px;
    height: 48px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1;
  }
  .dp-img-placeholder span {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  /* Arrow navigation */
  .dp-main-img-wrap { position: relative; }
  .dp-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.85);
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background 120ms, opacity 120ms;
    box-shadow: 0 1px 6px rgba(0,0,0,0.15);
  }
  .dp-arrow:hover { background: #fff; }
  .dp-arrow svg { display: block; }
  .dp-arrow-prev { left: 12px; }
  .dp-arrow-next { right: 12px; }
  .dp-arrow[hidden] { display: none; }
  /* Thumbnail strip */
  .dp-thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
  }
  .dp-thumb {
    background: none;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 200ms;
    width: 96px;
    height: 96px;
    flex-shrink: 0;
  }
  .dp-thumb.is-active,
  .dp-thumb:hover { border-color: #000; }
  .dp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    background: #fff;
  }

  /* ── Info column ──────────────────────────────────────── */
  .dp-info {
    padding: 48px 52px 32px;
    display: flex;
    flex-direction: column;
    align-self: start;
  }
  @media (max-width: 1100px) { .dp-info { padding: 44px 40px 28px; } }
  @media (max-width: 900px)  { .dp-info { padding: 36px 24px 24px; } }
  @media (max-width: 480px)  { .dp-info { padding: 28px 20px 20px; } }

  /* Coming Soon badge */
  .dp-coming-soon {
    display: inline-block;
    align-self: flex-start;
    font-family: 'DM Sans', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: #000;
    color: #fff;
    padding: 4px 10px;
    margin-bottom: 10px;
  }

  .dp-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
    margin-bottom: 10px;
  }

  .dp-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1;
    color: #000;
    margin-bottom: 20px;
  }

  /* Price row */
  .dp-price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }
  .dp-price {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1.9rem;
    color: #000;
    line-height: 1;
  }
  .dp-price-note {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    color: rgba(0,0,0,0.4);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .dp-divider {
    width: 100%;
    height: 1px;
    background: rgba(0,0,0,0.08);
    margin-bottom: 20px;
  }

  .dp-short-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(0,0,0,0.65);
    margin-bottom: 20px;
  }

  /* Spec pills */
  .dp-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }
  .dp-spec-pill {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 1px solid rgba(0,0,0,0.15);
    color: #000;
    background: #fff;
  }

  /* ── Subscription toggle ──────────────────────────────── */
  .dp-purchase-type {
    margin-bottom: 16px;
  }
  .dp-purchase-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.45);
    margin-bottom: 10px;
    display: block;
  }
  .dp-toggle {
    display: flex;
    border: 1px solid rgba(0,0,0,0.18);
    width: 100%;
  }
  .dp-toggle-btn {
    flex: 1;
    padding: 12px 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    background: #fff;
    color: rgba(0,0,0,0.45);
    cursor: pointer;
    transition: background 160ms, color 160ms;
  }
  .dp-toggle-btn.is-selected {
    background: #000;
    color: #fff;
  }
  .dp-toggle-btn:first-child {
    border-right: 1px solid rgba(0,0,0,0.18);
  }

  /* ── Frequency selector ───────────────────────────────── */
  .dp-frequency {
    margin-bottom: 14px;
    animation: dp-fade-in 180ms ease;
  }
  @keyframes dp-fade-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .dp-freq-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.45);
    margin-bottom: 8px;
    display: block;
  }
  .dp-freq-opts {
    display: flex;
    gap: 8px;
  }
  .dp-freq-btn {
    flex: 1;
    padding: 9px 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgba(0,0,0,0.18);
    background: #fff;
    color: rgba(0,0,0,0.5);
    cursor: pointer;
    transition: border-color 160ms, background 160ms, color 160ms;
    white-space: nowrap;
  }
  .dp-freq-btn.is-selected {
    border-color: #000;
    border-width: 2px;
    background: #000;
    color: #fff;
  }

  /* ── Subscribe free shipping callout ─────────────────── */
  .dp-sub-perk {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
    background: rgba(0,0,0,0.04);
    padding: 10px 14px;
    margin-bottom: 16px;
    border-left: 3px solid #000;
    animation: dp-fade-in 180ms ease;
  }
  .dp-sub-perk svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: #000;
    stroke-width: 2;
    flex-shrink: 0;
  }

  /* ── CTA ──────────────────────────────────────────────── */
  .dp-cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 17px 24px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: #000;
    color: #fff;
    border: 2px solid #000;
    cursor: pointer;
    transition: background 180ms, color 180ms;
    margin-bottom: 14px;
  }
  .dp-cta-btn:hover { background: #222; }
  .dp-cta-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .dp-preorder-note {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.35);
    text-align: center;
    margin-bottom: 16px;
  }

  /* ── Trust row ────────────────────────────────────────── */
  .dp-trust-row {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .dp-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.55);
  }
  .dp-trust-item svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    flex-shrink: 0;
  }

  /* Guarantee */
  .dp-guarantee {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: rgba(0,0,0,0.5);
    line-height: 1.5;
    margin-bottom: 0;
  }
  .dp-guarantee svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: #000;
    stroke-width: 1.5;
    flex-shrink: 0;
    margin-top: 1px;
    opacity: 0.5;
  }

  /* ── Below fold: description sections ────────────────── */
  .dp-desc-section {
    background: #000;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
  }
  .dp-desc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  @media (max-width: 768px) {
    .dp-desc-grid { grid-template-columns: 1fr; }
  }
  .dp-desc-left {
    padding: 56px 56px 56px 60px;
    border-right: 1px solid rgba(255,255,255,0.06);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .dp-desc-right {
    padding: 56px 60px 56px 56px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  @media (max-width: 900px) {
    .dp-desc-left, .dp-desc-right { padding: 40px 24px; }
    .dp-desc-left { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
  }

  /* ── Usage specs section ──────────────────────────────── */
  .dp-usage-section {
    background: #000;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 56px 60px;
  }
  @media (max-width: 900px) { .dp-usage-section { padding: 40px 24px; } }
  .dp-usage-header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .dp-usage-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.6rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
  }
  .dp-usage-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.07);
  }
  @media (max-width: 900px) { .dp-usage-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .dp-usage-grid { grid-template-columns: 1fr 1fr; } }
  .dp-usage-tile {
    background: #000;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .dp-usage-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }
  .dp-usage-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.35rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: #fff;
    line-height: 1.1;
  }
  .dp-section-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.2);
    margin-bottom: 16px;
  }
  .dp-section-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: 0.01em;
    color: #fff;
    margin-bottom: 0;
    flex: 1;
  }
  .dp-section-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    margin-top: 28px;
    line-height: 1.8;
    color: rgba(255,255,255,0.55);
    max-width: 420px;
  }

  /* Formula checklist */
  .dp-checklist {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .dp-check-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .dp-check-item:last-child { border-bottom: none; }
  .dp-check-mark {
    width: 20px;
    height: 20px;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
    font-size: 10px;
    color: #fff;
    font-weight: 700;
  }
  .dp-check-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 2px;
  }
  .dp-check-desc {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
  }

  /* ── Reviews ─────────────────────────────────────────── */
  .dp-reviews-section {
    background: #000;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 56px 60px;
  }
  @media (max-width: 900px) { .dp-reviews-section { padding: 40px 24px; } }
  .dp-reviews-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .dp-reviews-stars-summary {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: 0.02em;
  }
  .dp-reviews-stars-summary span { color: rgba(255,255,255,0.4); font-size: 12px; }
  .dp-reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.06);
  }
  @media (max-width: 768px) { .dp-reviews-grid { grid-template-columns: 1fr; } }
  .dp-review {
    background: #000;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .dp-review-stars {
    color: #fff;
    font-size: 13px;
    letter-spacing: 2px;
  }
  .dp-review-text {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.65);
    flex: 1;
  }
  .dp-review-author { margin-top: auto; }
  .dp-review-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 3px;
  }
  .dp-review-date {
    font-size: 10px;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.05em;
  }

  /* ── Statement + stat row (section 02) ───────────────── */
  .dp-statement-section {
    background: #000;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 72px 60px;
    text-align: center;
  }
  @media (max-width: 900px) { .dp-statement-section { padding: 48px 24px; } }
  .dp-statement-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.2);
    margin-bottom: 24px;
  }
  .dp-statement-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 5.5rem);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: 0.01em;
    color: #fff;
    margin-bottom: 20px;
  }
  .dp-statement-muted { color: rgba(255,255,255,0.3); }
  .dp-statement-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.45);
    max-width: 560px;
    margin: 0 auto 52px;
  }
  .dp-stat-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
    border: 1px solid rgba(255,255,255,0.08);
    max-width: 760px;
    margin: 0 auto;
  }
  .dp-stat {
    flex: 1;
    min-width: 140px;
    padding: 28px 24px;
  }
  .dp-stat-divider {
    width: 1px;
    height: 56px;
    background: rgba(255,255,255,0.08);
    flex-shrink: 0;
  }
  @media (max-width: 600px) {
    .dp-stat-divider { display: none; }
    .dp-stat { min-width: 50%; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .dp-stat:last-child, .dp-stat:nth-last-child(2) { border-bottom: none; }
  }
  .dp-stat-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.6rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    margin-bottom: 4px;
  }
  .dp-stat-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  /* Warning section */
  .dp-warning {
    background: #111;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 40px 60px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 24px;
    align-items: flex-start;
  }
  @media (max-width: 900px) { .dp-warning { padding: 32px 24px; grid-template-columns: 1fr; gap: 12px; } }
  .dp-warning-icon {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .dp-warning-icon svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: #fff;
    stroke-width: 2;
  }
  .dp-warning-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 8px;
  }
  .dp-warning-text {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.55);
  }
  .dp-warning-text strong {
    font-weight: 600;
    color: #fff;
  }

  /* ── Pair with Nova CTA ───────────────────────────────── */
  .dp-pair-section {
    background: #0a0a0a;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 72px 60px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 60px;
  }
  @media (max-width: 768px) {
    .dp-pair-section {
      grid-template-columns: 1fr;
      padding: 48px 24px;
      gap: 32px;
    }
  }
  .dp-pair-eyebrow {
