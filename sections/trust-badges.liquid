<style>
  .tb-section {
    background: #000;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 48px;
    font-family: 'DM Sans', sans-serif;
  }

  @media (max-width: 640px) { .tb-section { padding: 40px 24px; } }

  .tb-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.08);
  }

  @media (max-width: 768px) {
    .tb-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .tb-item {
    background: #000;
    padding: 32px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .tb-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tb-icon svg {
    width: 28px;
    height: 28px;
    fill: none;
    stroke: #fff;
    stroke-width: 1.5;
    opacity: 0.7;
  }

  .tb-text {}

  .tb-label {
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 3px;
  }

  .tb-sub {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.05em;
  }
</style>

<section class="tb-section fade-in">
  <div class="tb-grid">
    {% for block in section.blocks %}
      {% if block.type == 'badge' %}
        <div class="tb-item" {{ block.shopify_attributes }}>
          <div class="tb-icon">{{ block.settings.icon_svg }}</div>
          <div class="tb-text">
            <div class="tb-label">{{ block.settings.label }}</div>
            <div class="tb-sub">{{ block.settings.subtext }}</div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "limit": 4,
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG",
          "default": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"/><path d=\"m16 8 5 0 3 5v3h-8z\"/><circle cx=\"6\" cy=\"19\" r=\"2\"/><circle cx=\"19\" cy=\"19\" r=\"2\"/></svg>"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Badge title",
          "default": "FREE SHIPPING"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Badge subtext",
          "default": "Every single order"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges"
    }
  ]
}
{% endschema %}
