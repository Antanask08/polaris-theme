<style>
.trust-badges {
  background: #fff;
  padding: 64px 0;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

.badges-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}

.badge-item {
  text-align: center;
  padding: 24px 16px;
}

.badge-icon {
  margin-bottom: 16px;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 48px;
}

.badge-icon svg {
  width: 36px;
  height: 36px;
  fill: none;
  stroke: #000;
  stroke-width: 1.5;
}

.badge-label {
  font-family: 'DM Sans', sans-serif;
  font-weight: 700;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 6px;
  color: #000;
}

.badge-subtext {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  opacity: 0.6;
  line-height: 1.5;
  color: #000;
}

@media (max-width: 768px) {
  .badges-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
}

@media (max-width: 480px) {
  .badges-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>

<section class="trust-badges section--white fade-in">
  <div class="container">
    <div class="badges-grid">
      {% for block in section.blocks %}
        {% if block.type == 'badge' %}
          <div class="badge-item" {{ block.shopify_attributes }}>
            <div class="badge-icon">{{ block.settings.icon_svg }}</div>
            <div class="badge-label">{{ block.settings.label }}</div>
            <div class="badge-subtext">{{ block.settings.subtext }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

