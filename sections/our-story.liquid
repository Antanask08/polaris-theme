  <!-- ══ ACCORDION ══ -->
  <section class="ns-accordion-section ns-fade">
    <div class="ns-container">
      <div class="ns-accordion-header">
        <span class="ns-eyebrow ns-accordion-eyebrow">Our Approach</span>
        <h2 class="ns-accordion-title">What Makes<br>Us Different?</h2>
      </div>
      <div class="ns-accordion">
        <div class="ns-accordion-item">
          <button class="ns-accordion-trigger" aria-expanded="false">
            <span class="ns-accordion-trigger-title">Tested on Real Vehicles</span>
            <span class="ns-accordion-icon" aria-hidden="true"></span>
          </button>
          <div class="ns-accordion-body">
            <div class="ns-accordion-body-inner">
              <p class="ns-accordion-body-text">Every product is tested on the founders' own cars before it gets anywhere near a customer. Jacob's professional detailing background means nothing ships that doesn't perform under real conditions — not just in a controlled environment.</p>
            </div>
          </div>
        </div>
        <div class="ns-accordion-item">
          <button class="ns-accordion-trigger" aria-expanded="false">
            <span class="ns-accordion-trigger-title">Community Before Advertising</span>
            <span class="ns-accordion-icon" aria-hidden="true"></span>
          </button>
          <div class="ns-accordion-body">
            <div class="ns-accordion-body-inner">
              <p class="ns-accordion-body-text">We launched with a community ride-out where 50+ cars showed up for a brand nobody had heard of yet. That's the proof of concept — growth from inside the car community, not from paid media. We build with people, not at them.</p>
            </div>
          </div>
        </div>
        <div class="ns-accordion-item">
          <button class="ns-accordion-trigger" aria-expanded="false">
            <span class="ns-accordion-trigger-title">Honest Pricing, Always</span>
            <span class="ns-accordion-icon" aria-hidden="true"></span>
          </button>
          <div class="ns-accordion-body">
            <div class="ns-accordion-body-inner">
              <p class="ns-accordion-body-text">We reverse-engineer from the customer backward. What performance do you actually need? What's a fair price to deliver it? We refuse to inflate margins at the expense of making the hobby accessible to the next generation of enthusiasts.</p>
            </div>
          </div>
        </div>
        <div class="ns-accordion-item">
          <button class="ns-accordion-trigger" aria-expanded="false">
            <span class="ns-accordion-trigger-title">Obsessed with Consistency</span>
            <span class="ns-accordion-icon" aria-hidden="true"></span>
          </button>
          <div class="ns-accordion-body">
            <div class="ns-accordion-body-inner">
              <p class="ns-accordion-body-text">Every unit performs the same as the sample. No batch variance. No "this one was a bad run." If our standard drops, we don't ship it. Quality is non-negotiable — not a marketing claim.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ VALUES ══ -->
  <section class="ns-values ns-fade">
    <div class="ns-container">
      <div class="ns-values-header">
        <span class="ns-eyebrow ns-values-eyebrow">What We Stand For</span>
        <h2 class="ns-values-title">The Polaris<br>Standard.</h2>
      </div>
      <div class="ns-values-grid">
        <div class="ns-value-card">
          <span class="ns-value-num">01</span>
          <h3 class="ns-value-title">Community First</h3>
          <p class="ns-value-body">We started in the car scene, not a boardroom. Every product decision starts with what the community actually needs — not what looks good on a margin sheet.</p>
        </div>
        <div class="ns-value-card">
          <span class="ns-value-num">02</span>
          <h3 class="ns-value-title">Tested on Ours</h3>
          <p class="ns-value-body">Every product goes on our own cars before it goes on yours. If it doesn't pass that test, it doesn't ship. No exceptions, no shortcuts.</p>
        </div>
        <div class="ns-value-card">
          <span class="ns-value-num">03</span>
          <h3 class="ns-value-title">Priced Honestly</h3>
          <p class="ns-value-body">We price from what's fair, not what the market will tolerate. Quality shouldn't require a justification. Premium gear should be for everyone who cares.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FOUNDERS ══ -->
  <section class="ns-founders ns-fade">
    <div class="ns-container">
      <div class="ns-founders-header">
        <span class="ns-eyebrow ns-founders-eyebrow">The People Behind It</span>
        <h2 class="ns-founders-title">The Founders.</h2>
      </div>
      <div class="ns-founders-grid">
        {% assign founder_count = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'founder' %}
            {% assign founder_count = founder_count | plus: 1 %}
            <div class="ns-founder-card" {{ block.shopify_attributes }}>
              {% if block.settings.photo != blank %}
                <img src="{{ block.settings.photo | image_url: width: 600 }}" alt="{{ block.settings.name }}" class="ns-founder-photo" loading="lazy">
              {% else %}
                <div class="ns-founder-photo-placeholder">
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/></svg>
                </div>
              {% endif %}
              <div class="ns-founder-info">
                <div class="ns-founder-name">{{ block.settings.name }}</div>
                <div class="ns-founder-role">{{ block.settings.role }}</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="ns-founders-quote">
        <p class="ns-founders-quote-text">"Our goal isn't to be the cheapest brand. It's to be the most honest one."</p>
        <p class="ns-founders-quote-attr">— Antanas &amp; Jacob, Co-Founders · Chicago, 2025</p>
      </div>
    </div>
  </section>

  <!-- ══ CTA ══ -->
  <section class="ns-cta">
    <span class="ns-eyebrow ns-cta-eyebrow">Polaris Car Care</span>
    <h2 class="ns-cta-heading">{{ section.settings.vision_headline | default: "Built for People Like Us." }}</h2>
    <p class="ns-cta-sub">{{ section.settings.vision_subtext | default: "The Nova is the first chapter. Follow along as we build the rest." }}</p>
    <div class="ns-cta-btns">
      <a href="{{ section.settings.vision_cta1_url | default: '/collections/all' }}" class="ns-btn ns-btn--white">{{ section.settings.vision_cta1_text | default: 'Shop The Nova →' }}</a>
      {% if section.settings.vision_cta2_url != blank %}
        <a href="{{ section.settings.vision_cta2_url }}" class="ns-btn ns-btn--outline" target="_blank" rel="noopener">{{ section.settings.vision_cta2_text | default: 'Follow on TikTok →' }}</a>
      {% else %}
        <a href="https://www.tiktok.com/@polariscarcare" class="ns-btn ns-btn--outline" target="_blank" rel="noopener">Follow on TikTok →</a>
      {% endif %}
    </div>
  </section>

</div>

<script>
(function () {
  /* ── Fade-in ── */
  if ('IntersectionObserver' in window) {
    var fadeObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); fadeObs.unobserve(e.target); }
      });
    }, { threshold: 0.06 });
    document.querySelectorAll('.ns-fade').forEach(function (el) { fadeObs.observe(el); });
  } else {
    document.querySelectorAll('.ns-fade').forEach(function (el) { el.classList.add('is-visible'); });
  }

  /* ── Sticky scroll story ── */
  var chapters = document.querySelectorAll('.ns-story-chapter');
  var images   = document.querySelectorAll('.ns-story-img');
  var dots     = document.querySelectorAll('.ns-story-dot');

  function activateChapter(idx) {
    images.forEach(function (img) { img.classList.remove('is-active'); });
    dots.forEach(function (dot)   { dot.classList.remove('is-active'); });
    if (images[idx]) images[idx].classList.add('is-active');
    if (dots[idx])   dots[idx].classList.add('is-active');
  }

  if ('IntersectionObserver' in window && chapters.length && images.length) {
    var chapterObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var idx = parseInt(entry.target.getAttribute('data-chapter'), 10);
          activateChapter(idx);
        }
      });
    }, {
      threshold: 0.5   /* trigger when chapter is 50% visible */
    });
    chapters.forEach(function (ch) { chapterObs.observe(ch); });
  }

  /* ── Accordion ── */
  document.querySelectorAll('.ns-accordion-trigger').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item   = btn.closest('.ns-accordion-item');
      var body   = item.querySelector('.ns-accordion-body');
      var isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.ns-accordion-item.is-open').forEach(function (open) {
        open.classList.remove('is-open');
        open.querySelector('.ns-accordion-body').style.maxHeight = '0';
        open.querySelector('.ns-accordion-trigger').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('is-open');
        body.style.maxHeight = body.scrollHeight + 'px';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
})();
</script>

