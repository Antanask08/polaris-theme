      <div class="ns-stat">
        <div class="ns-stat-num">50+</div>
        <div class="ns-stat-label">Cars at Launch Event</div>
      </div>
      <div class="ns-stat">
        <div class="ns-stat-num">4.9★</div>
        <div class="ns-stat-label">Average Rating</div>
      </div>
      <div class="ns-stat">
        <div class="ns-stat-num">$0</div>
        <div class="ns-stat-label">Paid Ads to Start</div>
