          <div class="os-check-item os-check--pass">
            <span class="os-check-mark">✓</span>
            <div>
              <div class="os-check-name">Honest Price</div>
              <div class="os-check-desc">Premium quality at a price that doesn't require a justification</div>
            </div>
          </div>
        </div>

        <div class="os-standard-stamp-row">
          <div class="os-stamp">
            <span class="os-stamp-text">REAL WORLD</span>
            <span class="os-stamp-text--big">TESTED</span>
            <span class="os-stamp-text">✓ APPROVED</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ── FOUNDERS — CORK BOARD ── {%- endcomment -%}
