        <!-- Progress dots -->
        <div class="ns-story-dots" id="ns-story-dots">
          <div class="ns-story-dot is-active" data-dot="0"></div>
          <div class="ns-story-dot" data-dot="1"></div>
          <div class="ns-story-dot" data-dot="2"></div>
        </div>

      </div><!-- /ns-story-right -->
