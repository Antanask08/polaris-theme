    { "type": "image_picker", "id": "image_founders", "label": "Chapter 2 — The Founders image" },
    { "type": "image_picker", "id": "image_standard", "label": "Chapter 3 — The Standard image" },
    { "type": "header", "content": "Vision CTA" },
