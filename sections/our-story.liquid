<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@300;400&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.ns-wrap { font-family: 'DM Sans', sans-serif; overflow: hidden; }

.ns-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 48px;
}
@media (max-width: 640px) { .ns-container { padding: 0 24px; } }

.ns-eyebrow {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  margin-bottom: 20px;
}

.ns-fade {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.ns-fade.is-visible { opacity: 1; transform: translateY(0); }


/* ══════════════════════════════════════════
   HERO
══════════════════════════════════════════ */
.ns-hero {
  position: relative;
  background: #000;
  min-height: 85vh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
.ns-hero-bg {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  opacity: 0.25;
}
.ns-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.15) 60%, transparent 100%);
}
.ns-hero-content {
  position: relative;
  z-index: 2;
  padding: 80px 48px;
  max-width: 900px;
}
.ns-hero-eyebrow { color: rgba(255,255,255,0.4); }
.ns-hero-headline {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(3.5rem, 8vw, 8rem);
  text-transform: uppercase;
  line-height: 0.9;
  letter-spacing: -0.01em;
  color: #fff;
  margin-bottom: 28px;
}
.ns-hero-sub {
  font-family: 'Barlow', sans-serif;
  font-weight: 300;
  font-size: clamp(1rem, 1.6vw, 1.2rem);
  line-height: 1.7;
  color: rgba(255,255,255,0.6);
  max-width: 560px;
}
@media (max-width: 640px) {
  .ns-hero { min-height: 70vh; }
  .ns-hero-content { padding: 60px 24px; }
}


/* ══════════════════════════════════════════
   SCROLL STORY — sticky image + scrolling chapters
══════════════════════════════════════════ */
.ns-story {
  /* nothing — overflow handled by children */
}

.ns-story-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: start;   /* critical for sticky to work in a grid */
}

/* ── LEFT: scrolling text chapters ── */
.ns-story-left { /* normal flow — chapters stack */ }

.ns-story-chapter {
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 100px 72px;
}
.ns-chapter--dark  { background: #000; }
.ns-chapter--light { background: #fff; }
.ns-chapter--off   { background: #f5f5f5; }

.ns-chapter-eyebrow-dark  { color: rgba(255,255,255,0.35); }
.ns-chapter-eyebrow-light { color: rgba(0,0,0,0.35); }

.ns-chapter-rule {
  width: 40px; height: 2px;
  margin-bottom: 28px;
}
.ns-chapter--dark  .ns-chapter-rule { background: rgba(255,255,255,0.15); }
.ns-chapter--light .ns-chapter-rule,
.ns-chapter--off   .ns-chapter-rule { background: rgba(0,0,0,0.12); }

.ns-chapter-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(2.2rem, 3.5vw, 3.2rem);
  text-transform: uppercase;
  line-height: 0.95;
  letter-spacing: 0.01em;
  margin-bottom: 24px;
}
.ns-chapter--dark  .ns-chapter-heading { color: #fff; }
.ns-chapter--light .ns-chapter-heading,
.ns-chapter--off   .ns-chapter-heading { color: #000; }

.ns-chapter-body {
  font-family: 'Barlow', sans-serif;
  font-weight: 300;
  font-size: 1rem;
  line-height: 1.85;
}
.ns-chapter--dark  .ns-chapter-body { color: rgba(255,255,255,0.58); }
.ns-chapter--light .ns-chapter-body,
.ns-chapter--off   .ns-chapter-body { color: rgba(0,0,0,0.58); }

.ns-chapter-body + .ns-chapter-body { margin-top: 16px; }

/* ── RIGHT: sticky image panel ── */
.ns-story-right {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: hidden;
  background: #0a0a0a;
}

/* Each image sits absolutely, fills the panel */
.ns-story-img {
  position: absolute;
  inset: 0;
  /* Start clipped from the bottom — hidden below */
  clip-path: inset(100% 0 0 0);
  transition: clip-path 0.85s cubic-bezier(0.76, 0, 0.24, 1);
  will-change: clip-path;
}

/* Active image flips up to reveal fully */
.ns-story-img.is-active {
  clip-path: inset(0% 0 0 0);
}

.ns-story-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ns-story-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #111;
}
.ns-story-img-placeholder svg {
  width: 48px; height: 48px;
  stroke: rgba(255,255,255,0.08);
  fill: none; stroke-width: 1;
}

/* Progress dots */
.ns-story-dots {
  position: absolute;
  right: 20px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 10px;
  z-index: 10;
}
.ns-story-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  transition: background 300ms, transform 300ms;
}
.ns-story-dot.is-active {
  background: #fff;
  transform: scale(1.4);
}

/* ── MOBILE: no sticky, just normal stacked cards ── */
@media (max-width: 900px) {
  .ns-story-inner {
    grid-template-columns: 1fr;
  }
  /* On mobile, images come BEFORE their chapter text */
  .ns-story-right {
    position: relative;
    height: auto;
    display: none; /* hide sticky panel — mobile shows images inline */
  }
  .ns-story-chapter {
    min-height: unset;
    padding: 56px 32px;
    flex-direction: column;
  }
  /* Show inline images per chapter on mobile */
  .ns-chapter-img-mobile {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    margin-bottom: 40px;
  }
  .ns-chapter-img-mobile-placeholder {
    display: flex;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #111;
    align-items: center;
    justify-content: center;
    margin-bottom: 40px;
  }
  .ns-story-dots { display: none; }
}

@media (min-width: 901px) {
  .ns-chapter-img-mobile,
  .ns-chapter-img-mobile-placeholder { display: none; }
}

@media (max-width: 480px) {
  .ns-story-chapter { padding: 40px 24px; }
}


/* ══════════════════════════════════════════
   STATS
══════════════════════════════════════════ */
.ns-stats {
  background: #000;
  border-top: 1px solid rgba(255,255,255,0.07);
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.ns-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.07);
}
@media (max-width: 640px) { .ns-stats-grid { grid-template-columns: 1fr; } }
.ns-stat { background: #000; padding: 52px 40px; text-align: center; }
.ns-stat-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(3rem, 5vw, 5rem);
  color: #fff; line-height: 1;
  margin-bottom: 10px;
  letter-spacing: -0.02em;
}
.ns-stat-label {
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
}


/* ══════════════════════════════════════════
   ACCORDION
══════════════════════════════════════════ */
.ns-accordion-section {
  background: #fff;
  padding: 100px 0;
  border-top: 1px solid rgba(0,0,0,0.06);
}
@media (max-width: 640px) { .ns-accordion-section { padding: 64px 0; } }
.ns-accordion-header { margin-bottom: 64px; }
.ns-accordion-eyebrow { color: rgba(0,0,0,0.35); }
.ns-accordion-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  text-transform: uppercase;
  line-height: 0.92;
  color: #000;
}
.ns-accordion { border-top: 1px solid rgba(0,0,0,0.1); }
.ns-accordion-item { border-bottom: 1px solid rgba(0,0,0,0.1); }
.ns-accordion-trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28px 0;
  background: none; border: none;
  cursor: pointer; text-align: left; gap: 24px;
}
.ns-accordion-trigger-title {
  font-weight: 700;
  font-size: clamp(1rem, 1.5vw, 1.15rem);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #000;
  transition: opacity 200ms;
}
.ns-accordion-trigger:hover .ns-accordion-trigger-title { opacity: 0.4; }
.ns-accordion-icon {
  width: 28px; height: 28px;
  flex-shrink: 0;
  border: 1px solid rgba(0,0,0,0.2);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  transition: background 200ms, border-color 200ms;
}
.ns-accordion-icon::before,
.ns-accordion-icon::after {
  content: '';
  position: absolute;
  background: #000;
  transition: transform 250ms, opacity 250ms;
}
.ns-accordion-icon::before { width: 10px; height: 1.5px; }
.ns-accordion-icon::after  { width: 1.5px; height: 10px; }
.ns-accordion-item.is-open .ns-accordion-icon { background: #000; border-color: #000; }
.ns-accordion-item.is-open .ns-accordion-icon::before { background: #fff; }
.ns-accordion-item.is-open .ns-accordion-icon::after  { background: #fff; transform: rotate(90deg); opacity: 0; }
.ns-accordion-body { overflow: hidden; max-height: 0; transition: max-height 350ms ease; }
.ns-accordion-body-inner { padding: 0 0 32px; max-width: 680px; }
.ns-accordion-body-text {
  font-family: 'Barlow', sans-serif;
  font-weight: 300;
  font-size: 1rem;
  line-height: 1.85;
  color: rgba(0,0,0,0.58);
}


/* ══════════════════════════════════════════
   VALUES
══════════════════════════════════════════ */
.ns-values { background: #000; padding: 100px 0; }
@media (max-width: 640px) { .ns-values { padding: 64px 0; } }
.ns-values-header { margin-bottom: 60px; }
.ns-values-eyebrow { color: rgba(255,255,255,0.3); }
.ns-values-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  text-transform: uppercase;
  line-height: 0.92; color: #fff;
}
.ns-values-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.07);
}
@media (max-width: 900px) { .ns-values-grid { grid-template-columns: 1fr; } }
.ns-value-card {
  background: #000;
  padding: 48px 40px;
  display: flex; flex-direction: column; gap: 16px;
}
@media (max-width: 480px) { .ns-value-card { padding: 36px 24px; } }
.ns-value-num {
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.2em; color: rgba(255,255,255,0.2);
  text-transform: uppercase;
}
.ns-value-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900; font-size: 1.8rem;
  text-transform: uppercase; color: #fff; line-height: 0.95;
}
.ns-value-body {
  font-family: 'Barlow', sans-serif;
  font-weight: 300; font-size: 0.95rem;
  line-height: 1.8; color: rgba(255,255,255,0.5);
}


/* ══════════════════════════════════════════
   FOUNDERS
══════════════════════════════════════════ */
.ns-founders { background: #f5f5f5; padding: 100px 0; }
@media (max-width: 640px) { .ns-founders { padding: 64px 0; } }
.ns-founders-header { margin-bottom: 60px; }
.ns-founders-eyebrow { color: rgba(0,0,0,0.35); }
.ns-founders-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  text-transform: uppercase; line-height: 0.92; color: #000;
}
.ns-founders-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32px; max-width: 760px;
}
@media (max-width: 640px) {
  .ns-founders-grid { grid-template-columns: 1fr; max-width: 360px; }
}
.ns-founder-card { background: #fff; }
.ns-founder-photo { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; }
.ns-founder-photo-placeholder {
  width: 100%; aspect-ratio: 3/4;
  background: #e0e0e0;
  display: flex; align-items: center; justify-content: center;
}
.ns-founder-photo-placeholder svg {
  width: 40px; height: 40px;
  stroke: rgba(0,0,0,0.2); fill: none; stroke-width: 1.5;
}
.ns-founder-info {
  padding: 20px 24px 24px;
  border-top: 1px solid rgba(0,0,0,0.07);
}
.ns-founder-name {
  font-weight: 700; font-size: 14px;
  letter-spacing: 0.06em; text-transform: uppercase;
  color: #000; margin-bottom: 4px;
}
.ns-founder-role {
  font-size: 12px; letter-spacing: 0.08em;
  text-transform: uppercase; color: rgba(0,0,0,0.4);
}
.ns-founders-quote {
  margin-top: 56px; max-width: 680px;
  padding-left: 28px; border-left: 3px solid #000;
}
.ns-founders-quote-text {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  text-transform: uppercase; line-height: 1.2;
  color: #000; margin-bottom: 14px;
}
.ns-founders-quote-attr {
  font-size: 12px; letter-spacing: 0.15em;
  text-transform: uppercase; color: rgba(0,0,0,0.4);
}


/* ══════════════════════════════════════════
   FINAL CTA
══════════════════════════════════════════ */
.ns-cta {
  background: #000;
  padding: 120px 48px;
  text-align: center;
  position: relative; overflow: hidden;
}
@media (max-width: 640px) { .ns-cta { padding: 80px 24px; } }
.ns-cta::before {
  content: 'POLARIS';
  position: absolute;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900; font-size: 22vw;
  color: rgba(255,255,255,0.03);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  white-space: nowrap; pointer-events: none;
  letter-spacing: -0.02em;
}
.ns-cta-eyebrow { color: rgba(255,255,255,0.3); margin-bottom: 20px; }
.ns-cta-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(3rem, 6vw, 6rem);
  text-transform: uppercase; color: #fff;
  line-height: 0.92; margin-bottom: 24px; position: relative;
}
.ns-cta-sub {
  font-family: 'Barlow', sans-serif;
  font-weight: 300; font-size: 1.05rem;
  color: rgba(255,255,255,0.5); line-height: 1.7;
  max-width: 440px; margin: 0 auto 48px; position: relative;
}
.ns-cta-btns {
  display: flex; gap: 14px;
  justify-content: center; flex-wrap: wrap; position: relative;
}
.ns-btn {
  font-weight: 700; font-size: 12px;
  letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none; padding: 16px 36px;
  display: inline-block;
  transition: background 200ms, color 200ms, border-color 200ms;
}
.ns-btn--white   { background: #fff; color: #000; }
.ns-btn--white:hover { background: #e8e8e8; }
.ns-btn--outline { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.25); }
.ns-btn--outline:hover { border-color: #fff; }
</style>

<div class="ns-wrap">

  <!-- ══ HERO ══ -->
  <section class="ns-hero">
    {% if section.settings.hero_image != blank %}
      <img src="{{ section.settings.hero_image | image_url: width: 1800 }}" alt="Our Story" class="ns-hero-bg" loading="eager">
    {% endif %}
    <div class="ns-hero-overlay"></div>
    <div class="ns-hero-content">
      <span class="ns-eyebrow ns-hero-eyebrow">Our Story / Polaris Car Care — Chicago, IL</span>
      <h1 class="ns-hero-headline">{{ section.settings.hero_headline | default: 'Why Polaris Exists.' }}</h1>
      <p class="ns-hero-sub">{{ section.settings.hero_subhead | default: 'Two guys from Chicago who got tired of paying $40 for a towel — and decided to build something better.' }}</p>
    </div>
  </section>

  <!-- ══ SCROLL STORY ══ -->
  <section class="ns-story" id="ns-story">
    <div class="ns-story-inner">

      <!-- Left: text chapters (scroll normally) -->
      <div class="ns-story-left">

        <!-- Chapter 1: The Problem -->
        <div class="ns-story-chapter ns-chapter--dark" data-chapter="0">
          <!-- mobile-only inline image -->
          {% if section.settings.image_problem != blank %}
            <img src="{{ section.settings.image_problem | image_url: width: 800 }}" alt="The Problem" class="ns-chapter-img-mobile" loading="lazy">
          {% else %}
            <div class="ns-chapter-img-mobile-placeholder">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            </div>
          {% endif %}
          <div>
            <span class="ns-eyebrow ns-chapter-eyebrow-dark">01 — The Problem</span>
            <div class="ns-chapter-rule"></div>
            <h2 class="ns-chapter-heading">Why Does Premium Mean Overpriced?</h2>
            <p class="ns-chapter-body">We were buying products from well-known brands and couldn't stop asking the same question: why does a microfiber towel cost nearly $40 before shipping?</p>
            <p class="ns-chapter-body">The cheap stuff falls apart after 3 washes. The expensive stuff is marked up beyond reason. Nobody was building for people like us — young enthusiasts who love cars but can't justify $40 per towel. So we did.</p>
          </div>
        </div>

        <!-- Chapter 2: The Founders -->
        <div class="ns-story-chapter ns-chapter--light" data-chapter="1">
          {% if section.settings.image_founders != blank %}
            <img src="{{ section.settings.image_founders | image_url: width: 800 }}" alt="The Founders" class="ns-chapter-img-mobile" loading="lazy">
          {% else %}
            <div class="ns-chapter-img-mobile-placeholder" style="background:#f0f0f0;">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            </div>
          {% endif %}
          <div>
            <span class="ns-eyebrow ns-chapter-eyebrow-light">02 — The Founders</span>
            <div class="ns-chapter-rule"></div>
            <h2 class="ns-chapter-heading">Built by Enthusiasts. Tested on Ours.</h2>
            <p class="ns-chapter-body">Founded by <strong>Antanas Kubilius and Jacob Klepacki</strong>, Polaris Car Care was born from a simple realization — quality automotive detailing tools shouldn't be a luxury.</p>
            <p class="ns-chapter-body">Jacob brings real professional detailing experience, having worked alongside detailers who service exotic and luxury vehicles. Antanas handles brand strategy and operations. Different skills, same obsession.</p>
          </div>
        </div>

        <!-- Chapter 3: The Standard -->
        <div class="ns-story-chapter ns-chapter--off" data-chapter="2">
          {% if section.settings.image_standard != blank %}
            <img src="{{ section.settings.image_standard | image_url: width: 800 }}" alt="The Standard" class="ns-chapter-img-mobile" loading="lazy">
          {% else %}
            <div class="ns-chapter-img-mobile-placeholder" style="background:#e8e8e8;">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            </div>
          {% endif %}
          <div>
            <span class="ns-eyebrow ns-chapter-eyebrow-light">03 — The Standard</span>
            <div class="ns-chapter-rule"></div>
            <h2 class="ns-chapter-heading">If It Doesn't Pass Jacob's Test, It Doesn't Ship.</h2>
            <p class="ns-chapter-body">Every Polaris product is first tested on the founders' own vehicles. Then trusted voices in the local car community put it through real conditions. Only after it clears both rounds does it get listed for sale.</p>
            <p class="ns-chapter-body">No shortcuts. No marketing fluff. No batch variance. Just honest gear that performs the same every single time.</p>
          </div>
        </div>

      </div><!-- /ns-story-left -->

      <!-- Right: sticky image panel (desktop only) -->
      <div class="ns-story-right" id="ns-story-right">

        <!-- Image 0: Problem -->
        <div class="ns-story-img is-active" data-img="0">
          {% if section.settings.image_problem != blank %}
            <img src="{{ section.settings.image_problem | image_url: width: 900 }}" alt="The Problem" loading="eager">
          {% else %}
            <div class="ns-story-img-placeholder">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            </div>
          {% endif %}
        </div>

        <!-- Image 1: Founders -->
        <div class="ns-story-img" data-img="1">
          {% if section.settings.image_founders != blank %}
            <img src="{{ section.settings.image_founders | image_url: width: 900 }}" alt="The Founders" loading="lazy">
          {% else %}
            <div class="ns-story-img-placeholder">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            </div>
          {% endif %}
        </div>

        <!-- Image 2: Standard -->
        <div class="ns-story-img" data-img="2">
          {% if section.settings.image_standard != blank %}
            <img src="{{ section.settings.image_standard | image_url: width: 900 }}" alt="The Standard" loading="lazy">
          {% else %}
