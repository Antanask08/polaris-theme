<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    background: #000;
  }
  .hero-bg-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 120%;
    object-fit: cover;
    will-change: transform;
  }
  .hero-bg-placeholder {
    background: #111;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 0 24px;
  }
  .hero-headline {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 7rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 24px;
    opacity: 0;
    transform: translateY(20px);
    animation: hero-in 0.8s ease 0.2s forwards;
  }
  .hero-subhead {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    max-width: 600px;
    margin: 0 auto 40px;
    line-height: 1.6;
    opacity: 0;
    animation: hero-in 0.8s ease 0.4s forwards;
  }
  .hero-cta {
    opacity: 0;
    animation: hero-in 0.8s ease 0.6s forwards;
  }
  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .hero-bg video {
    object-fit: cover;
    width: 100%;
    height: 100%;
  }
</style>

<section class="hero" id="hero">
  <div class="hero-bg-wrap">
    {% if section.settings.bg_type == 'video' and section.settings.video_url != blank %}
      <video class="hero-bg hero-parallax" autoplay muted loop playsinline>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% elsif section.settings.image != blank %}
      <img
        class="hero-bg hero-parallax"
        src="{{ section.settings.image | img_url: 'master' }}"
        alt="Hero background"
        loading="eager"
      >
    {% else %}
      <div class="hero-bg hero-parallax hero-bg-placeholder"></div>
    {% endif %}
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content container">
    <h1 class="hero-headline">{{ section.settings.headline }}</h1>
    <p class="hero-subhead">{{ section.settings.subheadline }}</p>
    <a href="{{ section.settings.cta_url }}" class="btn btn--primary hero-cta">
      {{ section.settings.cta_text }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "select",
      "id": "bg_type",
      "label": "Background type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "placeholder": "https://"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "BUILT FOR THE ONES WHO CARE"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Premium detailing tools for the car community. Founded in Tempe, Arizona."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "SHOP THE NOVA →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Hero"
    }
  ]
}
{% endschema %}
