<style>
/* ─── Nova PDP ─────────────────────────────────────────────────────────────── */
.nova-pdp {
  --pdp-ink: #000;
  --pdp-paper: #fff;
  --pdp-muted: rgba(0,0,0,0.42);
  --pdp-line: #e5e5e5;
  --pdp-fdisp: 'DM Sans', sans-serif;
  --pdp-fbody: 'DM Sans', sans-serif;
  --pdp-fmono: 'DM Mono', monospace;
  --pdp-ease: cubic-bezier(0.16, 1, 0.3, 1);
  color: #000; background: #fff;
}

/* Type */
.pdp-h1 { font-family: var(--pdp-fdisp) !important; font-weight: 900 !important; font-size: clamp(34px,7vw,88px) !important; letter-spacing: -0.035em !important; line-height: 0.98 !important; text-transform: uppercase; margin: 0; }
.pdp-h2 { font-family: var(--pdp-fdisp) !important; font-weight: 900 !important; font-size: clamp(26px,4.5vw,56px) !important; letter-spacing: -0.03em !important; line-height: 1.02 !important; text-transform: uppercase; margin: 0 0 24px; text-wrap: pretty; }
.pdp-eyebrow { font-family: var(--pdp-fdisp); font-weight: 600; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; line-height: 1; }
.pdp-lead { font-family: var(--pdp-fbody); font-size: 17px; line-height: 1.55; margin: 0; }
.pdp-body { font-family: var(--pdp-fbody); font-size: 16px; line-height: 1.55; margin: 0; }
.pdp-small { font-family: var(--pdp-fbody); font-size: 14px; line-height: 1.5; }
.pdp-mono { font-family: var(--pdp-fmono); font-size: 12px; letter-spacing: 0.02em; }
.pdp-muted-c { color: var(--pdp-muted); }
.pdp-subtitle { font-family: var(--pdp-fdisp); font-weight: 600; font-size: 16px; letter-spacing: -0.01em; text-transform: uppercase; color: rgba(0,0,0,0.55); }
.pdp-italic { font-style: italic; color: #5b5b5b; }

/* Layout */
.pdp-wrap { max-width: 1920px; margin: 0 auto; padding: 0 28px; }
.pdp-wide { width: 100%; padding: 0 28px; }
@media (min-width: 900px) { .pdp-wrap, .pdp-wide { padding: 0 32px; } }
@media (min-width: 1600px) { .pdp-wrap, .pdp-wide { padding: 0 48px; } }
@media (max-width: 599px) {
  .pdp-h1 { font-size: 24px !important; line-height: 1.05 !important; }
  .pdp-h2 { font-size: 20px !important; line-height: 1.1 !important; }
  .pdp-lead { font-size: 14px !important; }
  .pdp-body { font-size: 14px !important; }
  .pdp-price { font-size: 20px !important; }
  .pdp-subtitle { font-size: 12px !important; }
  .pdp-info { gap: 12px !important; }
  .pdp-sec { padding: 56px 0 !important; }
  .pdp-specs-sec { margin-top: 72px !important; }
  .pdp-pack-btn__qty { font-size: 16px !important; }
  .pdp-info__tags { display: none !important; }
}

/* Buttons */
.pdp-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 18px 28px; font-family: var(--pdp-fdisp); font-weight: 600; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; border: 1px solid #000; background: #000; color: #fff; transition: background 240ms var(--pdp-ease), color 240ms var(--pdp-ease); cursor: pointer; text-align: center; text-decoration: none; }
.pdp-btn:hover { background: #fff; color: #000; }
.pdp-btn--sec { background: #fff; color: #000; }
.pdp-btn--sec:hover { background: #000; color: #fff; }
.pdp-btn--full { width: 100%; }
.pdp-btn--lg { padding: 22px 32px; font-size: 13px; }
.pdp-btn--sm { padding: 10px 16px; font-size: 11px; }

/* Tags */
.pdp-tag { display: inline-block; font-family: var(--pdp-fdisp); font-weight: 600; font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; padding: 6px 10px; border: 1px solid #000; line-height: 1; }
.pdp-tag--solid { background: #000; color: #fff; }
.pdp-tag--dot::before { content: "● "; margin-right: 2px; }

/* Link underline */
.pdp-ulink { position: relative; display: inline-block; padding-bottom: 2px; cursor: pointer; color: inherit; text-decoration: none; }
.pdp-ulink::after { content: ""; position: absolute; left: 0; bottom: 0; height: 1px; width: 100%; background: currentColor; transform-origin: left; transform: scaleX(0); transition: transform 240ms var(--pdp-ease); }
.pdp-ulink:hover::after { transform: scaleX(1); }

/* Breadcrumb */
.pdp-breadcrumb-bar { padding-top: 20px; }
.pdp-breadcrumb { display: flex; gap: 8px; flex-wrap: wrap; font-family: var(--pdp-fdisp); font-weight: 600; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--pdp-muted); }
.pdp-breadcrumb a { color: inherit; text-decoration: none; }
.pdp-breadcrumb a:hover { color: #000; }
.pdp-breadcrumb .pdp-cur { color: #000; }

/* Hero */
.pdp-hero-wrap { padding-top: 24px; }
.pdp-hero { display: grid; grid-template-columns: 1fr; gap: 32px; }
@media (min-width: 900px) { .pdp-hero { grid-template-columns: 7fr 5fr; gap: 56px; } }
@media (min-width: 1200px) { .pdp-hero { grid-template-columns: 8fr 4fr; gap: 72px; } }

/* Gallery */
.pdp-gallery { display: grid; gap: 12px; grid-template-columns: 1fr; }
@media (min-width: 900px) { .pdp-gallery { grid-template-columns: 88px 1fr; gap: 16px; } }
.pdp-gallery__thumbs { display: flex; gap: 8px; order: 2; overflow-x: auto; scrollbar-width: none; }
.pdp-gallery__thumbs::-webkit-scrollbar { display: none; }
@media (min-width: 900px) { .pdp-gallery__thumbs { flex-direction: column; order: 0; overflow: visible; } }
.pdp-gallery__thumb { flex: 0 0 72px; width: 72px; height: 88px; border: 1px solid #000; padding: 0; cursor: pointer; position: relative; opacity: 0.55; transition: opacity 240ms var(--pdp-ease); background: #f4f4f4; overflow: hidden; }
.pdp-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
@media (min-width: 900px) { .pdp-gallery__thumb { width: 88px; height: 110px; flex: 0 0 auto; } }
.pdp-gallery__thumb--on { opacity: 1; }
.pdp-gallery__thumb--on::after { content: ""; position: absolute; inset: 0; border: 2px solid #000; pointer-events: none; }
.pdp-gallery__main { border: 1px solid #000; aspect-ratio: 1/1; order: 1; position: relative; overflow: hidden; background: #fff; }
@media (min-width: 900px) { .pdp-gallery__main { aspect-ratio: 1/1.1; } }
.pdp-gallery__slide { position: absolute; inset: 0; }
.pdp-gallery__slide img { width: 100%; height: 100%; object-fit: contain; display: block; padding: 6%; box-sizing: border-box; }
.pdp-gallery__slide--off { display: none; }
.pdp-gallery__nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.9); border: 1px solid #000; width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center; z-index: 2; cursor: pointer; transition: background 120ms; }
.pdp-gallery__nav--prev { left: 12px; }
.pdp-gallery__nav--next { right: 12px; }
.pdp-gallery__nav:hover { background: #000; color: #fff; }
.pdp-gallery__counter { position: absolute; bottom: 14px; right: 14px; font-family: var(--pdp-fmono); font-size: 11px; background: #fff; border: 1px solid #000; padding: 4px 8px; z-index: 2; }

/* Info column */
.pdp-info { display: flex; flex-direction: column; gap: 18px; }
@media (min-width: 900px) { .pdp-info { position: sticky; top: 100px; align-self: start; } }
.pdp-info__tags { display: flex; gap: 8px; flex-wrap: wrap; }
.pdp-meta-row { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }
.pdp-price { font-family: var(--pdp-fdisp); font-weight: 700; font-size: 28px; letter-spacing: -0.01em; }

/* Qty */
.pdp-qty-wrap { display: flex; flex-direction: column; gap: 8px; }
.pdp-qty { display: inline-flex; border: 1px solid #000; }
.pdp-qty__btn { width: 48px; height: 56px; display: inline-flex; align-items: center; justify-content: center; border: 0; background: none; cursor: pointer; color: inherit; font: inherit; transition: background 120ms; }
.pdp-qty__btn:hover { background: #000; color: #fff; }
.pdp-qty__count { width: 56px; height: 56px; display: inline-flex; align-items: center; justify-content: center; font-family: var(--pdp-fdisp); font-weight: 700; font-size: 16px; border-left: 1px solid #000; border-right: 1px solid #000; }

/* CTA */
.pdp-cta-stack { display: flex; flex-direction: column; gap: 10px; }
.pdp-cta-stack .shopify-payment-button { margin: 0; }
.pdp-cta-stack .shopify-payment-button__button { border-radius: 0 !important; min-height: 60px !important; font-family: var(--pdp-fdisp) !important; font-weight: 600 !important; font-size: 13px !important; letter-spacing: 0.12em !important; text-transform: uppercase !important; }

/* Pack selector */
.pdp-packs { display: flex; flex-direction: column; gap: 10px; }
.pdp-packs__label { display: flex; justify-content: space-between; align-items: baseline; }
.pdp-packs__opts { display: flex; gap: 0; border: 1px solid #000; }
.pdp-pack-btn { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; padding: 20px 10px; cursor: pointer; background: none; border: 0; border-right: 1px solid #000; font: inherit; color: inherit; transition: background 160ms; position: relative; min-height: 80px; }
.pdp-pack-btn:last-child { border-right: 0; }
.pdp-pack-btn:hover { background: #f4f4f4; }
.pdp-pack-btn--on { background: #000; color: #fff; }
.pdp-pack-btn--on:hover { background: #111; }
.pdp-pack-btn__qty { font-family: var(--pdp-fdisp); font-weight: 900; font-size: 18px; letter-spacing: -0.01em; }
.pdp-pack-btn__price { font-family: var(--pdp-fmono); font-size: 11px; opacity: 0.7; }
.pdp-pack-btn__per { display: block; font-family: var(--pdp-fmono); font-size: 10px; color: rgba(0,0,0,0.5); margin-top: 1px; }
.pdp-pack-btn--on .pdp-pack-btn__per { color: rgba(0,0,0,0.65); }
.pdp-urgency { font-family: var(--pdp-fdisp); font-weight: 600; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(0,0,0,0.55); }
.pdp-trust-row { display: flex; flex-wrap: wrap; gap: 8px 16px; margin-top: 10px; font-family: var(--pdp-fmono); font-size: 11px; color: var(--pdp-muted); }
.pdp-trust-row span { white-space: nowrap; }
.pdp-pack-btn__save { position: absolute; top: -9px; left: 50%; transform: translateX(-50%); background: #000; color: #fff; font-family: var(--pdp-fdisp); font-weight: 700; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 6px; white-space: nowrap; }
.pdp-pack-btn--on .pdp-pack-btn__save { background: #fff; color: #000; }

/* Meta details grid */
.pdp-details { display: grid; grid-template-columns: auto 1fr; gap: 10px 20px; border-top: 1px solid #e5e5e5; padding-top: 20px; }
.pdp-details .pdp-eyebrow { padding-top: 2px; }

/* Specs */
.pdp-specs-sec { margin-top: 120px; }
.pdp-specs { display: grid; grid-template-columns: repeat(2,1fr); border-top: 1px solid #000; border-bottom: 1px solid #000; }
@media (min-width: 700px) { .pdp-specs { grid-template-columns: repeat(3,1fr); } }
@media (min-width: 1000px) { .pdp-specs { grid-template-columns: repeat(5,1fr); } }
.pdp-specs__cell { padding: 28px 20px 32px; border-right: 1px solid #000; border-bottom: 1px solid #000; min-height: 140px; display: flex; flex-direction: column; gap: 10px; }
@media (min-width: 1000px) { .pdp-specs__cell { border-bottom: 0; padding: 36px 24px 40px; min-height: 180px; } }
.pdp-specs__cell:last-child { border-right: 0; }
@media (max-width: 999px) { .pdp-specs__cell:nth-child(2n) { border-right: 0; } }
@media (min-width: 700px) and (max-width: 999px) { .pdp-specs__cell:nth-child(2n) { border-right: 1px solid #000; } .pdp-specs__cell:nth-child(3n) { border-right: 0; } }
.pdp-specs__idx { font-family: var(--pdp-fmono); font-size: 11px; color: var(--pdp-muted); }
.pdp-specs__val { font-family: var(--pdp-fdisp); font-weight: 900; font-size: clamp(22px,3vw,40px); letter-spacing: -0.02em; line-height: 1; }
.pdp-specs__unit { font-family: var(--pdp-fdisp); font-weight: 600; font-size: 14px; letter-spacing: 0.04em; margin-left: 6px; }
.pdp-specs__label { font-family: var(--pdp-fdisp); font-weight: 600; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; }

/* Section head */
.pdp-sec-head { display: flex; flex-direction: column; gap: 16px; padding-bottom: 32px; }
.pdp-sec-head__row { display: flex; justify-content: space-between; align-items: baseline; gap: 24px; flex-wrap: wrap; }

/* Section rhythm */
.pdp-sec { padding: 80px 0; }
@media (min-width: 900px) { .pdp-sec { padding: 120px 0; } }

/* Why GSM */
.pdp-why { display: grid; grid-template-columns: 1fr; gap: 48px; }
@media (min-width: 900px) { .pdp-why { grid-template-columns: 5fr 7fr; gap: 72px; align-items: start; } }
.pdp-why-copy p + p { margin-top: 14px; }

/* Compare visual */
.pdp-compare { border: 1px solid #000; background: #fff; }
.pdp-compare__row { display: grid; grid-template-columns: 140px 1fr; border-top: 1px solid #000; align-items: stretch; }
.pdp-compare__row:first-child { border-top: 0; }
.pdp-compare__lbl { padding: 24px 20px; border-right: 1px solid #000; display: flex; flex-direction: column; gap: 6px; justify-content: center; }
.pdp-compare__lbl-name { font-family: var(--pdp-fdisp); font-weight: 800; font-size: 14px; letter-spacing: 0.02em; text-transform: uppercase; }
.pdp-compare__lbl-gsm { font-family: var(--pdp-fmono); font-size: 11px; color: #5b5b5b; }
.pdp-compare__fiber { position: relative; overflow: hidden; background: #f4f4f4; min-height: 56px; }
.pdp-compare__row--ours .pdp-compare__fiber { background: #000; }
.pdp-pile { position: absolute; bottom: 0; left: 0; right: 0; display: flex; align-items: flex-end; gap: 2px; padding: 0 8px; height: 100%; }
.pdp-pile span { flex: 1; background: #5b5b5b; opacity: 0.8; }
.pdp-compare__row--ours .pdp-pile span { background: #fff; }

/* Marquee bar */
.pdp-mq-bar { background: #000; color: #fff; padding: 14px 0; border-top: 1px solid #000; border-bottom: 1px solid #000; overflow: hidden; }
.pdp-mq-track { display: inline-block; white-space: nowrap; font-family: var(--pdp-fdisp); font-weight: 900; font-size: 28px; letter-spacing: -0.04em; line-height: 0.92; text-transform: uppercase; animation: pdp-mq 60s linear infinite; }
@keyframes pdp-mq { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* Founder */
.pdp-founder { display: grid; grid-template-columns: 1fr; border-top: 1px solid #000; border-bottom: 1px solid #000; }
@media (min-width: 900px) { .pdp-founder { grid-template-columns: 1fr 1fr; } }
.pdp-founder__media { aspect-ratio: 4/3; border-bottom: 1px solid #000; overflow: hidden; position: relative; background: #111; }
.pdp-founder__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
@media (min-width: 900px) { .pdp-founder__media { border-bottom: 0; border-right: 1px solid #000; aspect-ratio: auto; min-height: 620px; } }
.pdp-founder__body { padding: 40px 24px; display: flex; flex-direction: column; gap: 20px; }
@media (min-width: 900px) { .pdp-founder__body { padding: 72px 56px; } }
.pdp-founder__sig { display: flex; gap: 24px; align-items: center; flex-wrap: wrap; }
.pdp-founder-ph-label { font-family: var(--pdp-fdisp); font-weight: 900; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; position: absolute; bottom: 12px; left: 12px; right: 12px; color: rgba(255,255,255,0.5); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* UGC Carousel — portrait infinite marquee */
.pdp-ugc-outer { overflow: hidden; width: 100%; background: #000; -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%); mask-image: linear-gradient(to right, transparent 0%, #000 8%, #000 92%, transparent 100%); }
.pdp-ugc { display: flex; flex-wrap: nowrap; gap: 2px; will-change: transform; }
.pdp-ugc__tile { flex: 0 0 220px; aspect-ratio: 9/16; position: relative; overflow: hidden; cursor: pointer; background: #1a1a1a; opacity: var(--ugc-opacity, 1); transition: opacity 300ms; }
.pdp-ugc__tile:hover { opacity: 1; }
@media (min-width: 700px) { .pdp-ugc__tile { flex: 0 0 280px; } }
.pdp-ugc__tile img, .pdp-ugc__tile video { width: 100%; height: 100%; object-fit: cover; display: block; }
.pdp-ugc__meta { position: absolute; bottom: 10px; left: 12px; right: 12px; display: flex; justify-content: space-between; align-items: flex-end; color: #fff; font-family: var(--pdp-fmono); font-size: 11px; mix-blend-mode: difference; }
.pdp-ugc__handle { font-family: var(--pdp-fdisp); font-weight: 600; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; }

/* FAQ */
.pdp-faq__item { border-top: 1px solid #000; }
.pdp-faq__item:last-child { border-bottom: 1px solid #000; }
.pdp-faq__btn { display: flex; justify-content: space-between; align-items: center; width: 100%; padding: 28px 0; text-align: left; gap: 24px; cursor: pointer; background: none; border: 0; font: inherit; color: inherit; }
.pdp-faq__q { font-family: var(--pdp-fdisp); font-weight: 700; font-size: clamp(18px,2vw,22px); letter-spacing: -0.01em; line-height: 1.2; }
.pdp-faq__icon { flex-shrink: 0; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; transition: transform 240ms var(--pdp-ease); }
.pdp-faq__item--open .pdp-faq__icon { transform: rotate(45deg); }
.pdp-faq__body { max-height: 0; overflow: hidden; transition: max-height 400ms var(--pdp-ease); }
.pdp-faq__item--open .pdp-faq__body { max-height: 600px; }
.pdp-faq__inner { padding: 0 0 28px; max-width: 640px; font-family: var(--pdp-fbody); font-size: 16px; line-height: 1.6; color: #222; }

/* Reviews carousel */
.pdp-rev-wrap { overflow: hidden; }
.pdp-rev-track { display: flex; gap: 16px; animation: pdp-rev 22s linear infinite; will-change: transform; }
.pdp-rev-track:hover { animation-play-state: paused; }
@keyframes pdp-rev { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.pdp-rev-card { flex: 0 0 300px; border: 1px solid #000; padding: 24px; display: flex; flex-direction: column; gap: 12px; }
@media (min-width: 700px) { .pdp-rev-card { flex: 0 0 360px; } }
.pdp-rev-card__stars { color: #000; font-size: 14px; letter-spacing: 2px; }
.pdp-rev-card__text { font-family: var(--pdp-fbody); font-size: 15px; line-height: 1.55; color: #222; flex: 1; }
.pdp-rev-card__meta { display: flex; justify-content: space-between; gap: 8px; flex-wrap: wrap; }
.pdp-rev-card__name { font-family: var(--pdp-fdisp); font-weight: 700; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; }
.pdp-rev-card__date { font-family: var(--pdp-fmono); font-size: 11px; color: var(--pdp-muted); }
@media (max-width: 699px) {
  .pdp-rev-wrap { overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .pdp-rev-wrap::-webkit-scrollbar { display: none; }
  .pdp-rev-track { animation: none !important; padding: 0 24px 0 0; }
  .pdp-rev-card { flex: 0 0 calc(100vw - 80px); scroll-snap-align: start; }
}

/* Sticky ATB */
.pdp-satb { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-top: 1px solid #000; padding: 12px 16px; display: flex; gap: 12px; align-items: center; z-index: 50; transform: translateY(100%); transition: transform 400ms var(--pdp-ease); }
.pdp-satb--on { transform: translateY(0); }
.pdp-satb__info { flex: 1; display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.pdp-satb__name { font-family: var(--pdp-fdisp); font-weight: 700; font-size: 13px; letter-spacing: -0.005em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.pdp-satb__price { font-family: var(--pdp-fdisp); font-weight: 600; font-size: 12px; color: #5b5b5b; }
@media (min-width: 900px) { .pdp-satb { display: none; } }

/* Scroll reveal */
.pdp-reveal { opacity: 0; transform: translateY(12px); transition: opacity 600ms var(--pdp-ease), transform 600ms var(--pdp-ease); }
.pdp-reveal--in { opacity: 1; transform: none; }
:root { --ugc-opacity: {{ section.settings.ugc_opacity | default: 100 | divided_by: 100.0 }}; }
</style>

<div class="nova-pdp" id="nova-pdp">

  {%- comment -%}── Breadcrumb ──{%- endcomment -%}
  <div class="pdp-wrap pdp-breadcrumb-bar">
    <nav class="pdp-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}" class="pdp-ulink">Home</a>
      <span>/</span>
      <a href="{{ routes.all_products_collection_url }}" class="pdp-ulink">Shop</a>
      <span>/</span>
      <span class="pdp-cur">The Nova</span>
    </nav>
  </div>

  {%- comment -%}── Hero ──{%- endcomment -%}
  <section class="pdp-wrap pdp-hero-wrap" id="pdp-hero">
    <div class="pdp-hero">

      {%- comment -%} Gallery {%- endcomment -%}
      <div class="pdp-gallery">
        <div class="pdp-gallery__thumbs" role="tablist">
          {%- assign gallery_idx = 0 -%}
          {%- for media in product.media -%}
            {%- if media.media_type == 'image' -%}
              <button class="pdp-gallery__thumb{% if gallery_idx == 0 %} pdp-gallery__thumb--on{% endif %}"
                data-gidx="{{ gallery_idx }}" role="tab"
                aria-selected="{% if gallery_idx == 0 %}true{% else %}false{% endif %}"
                aria-label="Image {{ gallery_idx | plus: 1 }}">
                {{ media | image_url: width: 160 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;display:block' }}
              </button>
              {%- assign gallery_idx = gallery_idx | plus: 1 -%}
            {%- endif -%}
