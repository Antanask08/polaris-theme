{{ 'cart-drawer.css' | asset_url | stylesheet_tag }}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@300;400&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  /* ─── Reset / Base ─────────────────────────────────────────────────────────── */
  .pp {
    font-family: 'DM Sans', sans-serif;
    background: #fff;
    color: #000;
  }

  .pp-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media (max-width: 640px) { .pp-container { padding: 0 20px; } }

  /* ─── Breadcrumb ───────────────────────────────────────────────────────────── */
  .pp-breadcrumb {
    padding: 16px 0 0;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.35);
  }
  .pp-breadcrumb a { color: inherit; text-decoration: none; }
  .pp-breadcrumb a:hover { color: #000; }
  .pp-breadcrumb span { margin: 0 6px; }

  /* ─── Top Layout ───────────────────────────────────────────────────────────── */
  .pp-top {
    padding: 32px 0 80px;
  }

  .pp-layout {
    display: grid;
    grid-template-columns: 55% 1fr;
    gap: 72px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .pp-layout { grid-template-columns: 1fr; gap: 40px; }
    .pp-top { padding: 24px 0 60px; }
  }

  /* ─── Gallery ──────────────────────────────────────────────────────────────── */
  .pp-gallery {
    position: sticky;
    top: 80px;
  }

  @media (max-width: 900px) { .pp-gallery { position: static; } }

  .pp-gallery-main {
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
    margin-bottom: 12px;
  }

  .pp-gallery-main img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    transition: opacity 180ms ease;
  }

  .pp-gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
  }

  .pp-thumb {
    background: none;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 200ms;
    aspect-ratio: 1/1;
  }

  .pp-thumb.is-active,
  .pp-thumb:hover {
    border-color: #000;
  }

  .pp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ─── Info Column ──────────────────────────────────────────────────────────── */
  .pp-info {}

  .pp-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.35);
    margin-bottom: 10px;
  }

  .pp-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: 0.01em;
    color: #000;
    margin-bottom: 20px;
  }

  /* Rating row */
  .pp-rating {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
  }
  .pp-stars { font-size: 14px; letter-spacing: 2px; color: #000; }
  .pp-rating-text { font-size: 13px; color: rgba(0,0,0,0.5); }
  .pp-rating-sep { width: 1px; height: 14px; background: rgba(0,0,0,0.15); }

  /* Price */
  .pp-price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 6px;
  }
  .pp-price {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 2.4rem;
    color: #000;
    letter-spacing: 0.02em;
  }
  .pp-price-compare {
    font-size: 1rem;
    color: rgba(0,0,0,0.35);
    text-decoration: line-through;
  }
  .pp-price-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: #000;
    color: #fff;
    padding: 3px 8px;
  }

  .pp-shipping-note {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
    margin-bottom: 24px;
  }

  /* Divider */
  .pp-divider {
    height: 1px;
    background: rgba(0,0,0,0.08);
    margin: 24px 0;
  }

  /* Short desc */
  .pp-short-desc {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(0,0,0,0.65);
    margin-bottom: 24px;
  }

  /* Spec pills */
  .pp-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }
  .pp-spec-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(0,0,0,0.15);
    padding: 7px 14px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
  }
  .pp-spec-pill-icon { font-size: 13px; }

  /* Variant selector */
  .pp-variants { margin-bottom: 20px; }
  .pp-variant-group { margin-bottom: 14px; }
  .pp-variant-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 10px;
    color: rgba(0,0,0,0.5);
  }
  .pp-variant-opts { display: flex; gap: 8px; flex-wrap: wrap; }
  .pp-variant-btn {
    padding: 9px 20px;
    border: 1px solid rgba(0,0,0,0.2);
    background: transparent;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    transition: background 180ms, border-color 180ms, color 180ms;
    color: #000;
  }
  .pp-variant-btn:hover,
  .pp-variant-btn.is-selected {
    background: #000;
    color: #fff;
    border-color: #000;
  }

  /* Qty + ATC row */
  .pp-atc-row {
    display: flex;
    gap: 12px;
    margin-bottom: 14px;
  }

  .pp-qty {
    display: flex;
    align-items: center;
    border: 1px solid rgba(0,0,0,0.2);
    flex-shrink: 0;
  }
  .pp-qty-btn {
    width: 42px;
    height: 56px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 20px;
    font-weight: 300;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms;
  }
  .pp-qty-btn:hover { background: rgba(0,0,0,0.05); }
  .pp-qty-num {
    width: 36px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    border: none;
    outline: none;
    background: transparent;
    pointer-events: none;
  }

  .pp-atc-btn {
    flex: 1;
    height: 56px;
    background: #000;
    color: #fff;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: background 200ms;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .pp-atc-btn:hover { background: #1a1a1a; }
  .pp-atc-btn:active { background: #333; }

  /* Trust row */
  .pp-trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 14px 0;
    border-top: 1px solid rgba(0,0,0,0.07);
    border-bottom: 1px solid rgba(0,0,0,0.07);
    margin-bottom: 20px;
  }
  .pp-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.5);
  }
  .pp-trust-item svg {
    width: 14px; height: 14px;
    stroke: rgba(0,0,0,0.4);
    fill: none;
    stroke-width: 2;
    flex-shrink: 0;
  }

  /* Guarantee line */
  .pp-guarantee {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    background: #f8f8f8;
    border-left: 3px solid #000;
    font-size: 13px;
    font-weight: 500;
    color: rgba(0,0,0,0.7);
  }
  .pp-guarantee svg {
    width: 18px; height: 18px;
    stroke: #000;
    fill: none;
    stroke-width: 2;
    flex-shrink: 0;
  }

  /* ─── Feature Strip ────────────────────────────────────────────────────────── */
  .pp-feature-strip {
    background: #000;
    padding: 0;
  }
  .pp-feature-strip-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  @media (max-width: 768px) {
    .pp-feature-strip-inner { grid-template-columns: repeat(2, 1fr); }
  }
  .pp-feature-item {
    padding: 40px 32px;
    border-right: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .pp-feature-item:last-child { border-right: none; }
  .pp-feature-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2.8rem;
    color: #fff;
    line-height: 1;
    margin-bottom: 6px;
  }
  .pp-feature-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  /* ─── Description Blocks ───────────────────────────────────────────────────── */
  .pp-desc-block {
    padding: 100px 0;
  }
  .pp-desc-block:nth-child(even) { background: #f9f9f9; }

  .pp-desc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  @media (max-width: 768px) {
    .pp-desc-grid { grid-template-columns: 1fr; gap: 40px; }
    .pp-desc-block { padding: 64px 0; }
    .pp-desc-block--reverse .pp-desc-img { order: -1; }
  }

  .pp-desc-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin-bottom: 14px;
  }
  .pp-desc-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #000;
    margin-bottom: 20px;
  }
  .pp-desc-rule {
    width: 36px; height: 2px;
    background: rgba(0,0,0,0.15);
    margin-bottom: 20px;
  }
  .pp-desc-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(0,0,0,0.6);
  }
  .pp-desc-img img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }
  .pp-desc-img-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #e8e8e8;
  }

  /* ─── GSM Dark Section ─────────────────────────────────────────────────────── */
  .pp-gsm {
    background: #000;
    padding: 100px 0;
    text-align: center;
  }
  @media (max-width: 768px) { .pp-gsm { padding: 64px 0; } }

  .pp-gsm-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 16px;
  }
  .pp-gsm-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 56px;
    line-height: 0.95;
  }
  .pp-gsm-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    max-width: 760px;
    margin: 0 auto;
    background: rgba(255,255,255,0.1);
  }
  @media (max-width: 600px) { .pp-gsm-cards { grid-template-columns: 1fr; } }
  .pp-gsm-card {
    background: #000;
    padding: 48px 32px;
  }
  .pp-gsm-card--polaris {
    background: #fff;
  }
  .pp-gsm-val {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2.8rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: 8px;
    line-height: 1;
  }
  .pp-gsm-card--polaris .pp-gsm-val { color: #000; }
  .pp-gsm-lbl {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }
  .pp-gsm-card--polaris .pp-gsm-lbl { color: rgba(0,0,0,0.5); }

  /* ─── Reviews ──────────────────────────────────────────────────────────────── */
  .pp-reviews {
    background: #fff;
    padding: 100px 0;
    border-top: 1px solid rgba(0,0,0,0.07);
  }
  @media (max-width: 768px) { .pp-reviews { padding: 64px 0; } }

  .pp-reviews-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .pp-reviews-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin-bottom: 16px;
  }
  .pp-reviews-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    text-transform: uppercase;
    color: #000;
    margin-bottom: 12px;
    line-height: 0.95;
  }
  .pp-reviews-rating {
    font-size: 13px;
    color: rgba(0,0,0,0.4);
    letter-spacing: 0.05em;
  }

  /* Reviews carousel */
  .pp-reviews-carousel { position: relative; }
  .pp-reviews-track-wrap { overflow: hidden; }
  .pp-reviews-track {
    display: flex;
    will-change: transform;
    cursor: grab;
    user-select: none;
  }
  .pp-reviews-track:active { cursor: grabbing; }
  .pp-review-card {
    flex: 0 0 33.333%;
    min-width: 0;
    background: #fff;
    padding: 40px 36px;
    border-right: 1px solid rgba(0,0,0,0.07);
    border-bottom: 1px solid rgba(0,0,0,0.07);
    box-sizing: border-box;
  }
  @media (max-width: 900px) { .pp-review-card { flex: 0 0 80%; } }
  @media (max-width: 540px)  { .pp-review-card { flex: 0 0 92%; } }

  .pp-reviews-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-top: 32px;
  }
  .pp-reviews-btn {
    width: 40px; height: 40px;
    border: 1px solid rgba(0,0,0,0.15);
    background: none;
    cursor: pointer;
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
    transition: background 150ms, border-color 150ms, color 150ms;
    flex-shrink: 0;
    line-height: 1;
  }
  .pp-reviews-btn:hover { background: #000; color: #fff; border-color: #000; }
  .pp-reviews-dots { display: flex; gap: 6px; align-items: center; }
  .pp-reviews-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: rgba(0,0,0,0.15);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 200ms, width 200ms, border-radius 200ms;
  }
  .pp-reviews-dot.is-active { background: #000; width: 20px; border-radius: 3px; }

  /* UGC carousel */
  .pp-ugc {
    background: #000;
    padding: 80px 0;
    overflow: hidden;
  }
  @media (max-width: 640px) { .pp-ugc { padding: 56px 0; } }
  .pp-ugc-header {
    text-align: center;
    margin-bottom: 40px;
    padding: 0 40px;
  }
  .pp-ugc-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 14px;
  }
  .pp-ugc-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3rem);
    text-transform: uppercase;
    color: #fff;
    line-height: 0.95;
  }
  .pp-ugc-track-wrap { overflow: hidden; padding: 0 40px; }
  @keyframes pp-ugc-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .pp-ugc-track {
    display: flex;
    gap: 10px;
    width: max-content;
    animation: pp-ugc-scroll 35s linear infinite;
  }
  .pp-ugc-track:hover { animation-play-state: paused; }
  .pp-ugc-item {
    flex-shrink: 0;
    width: 220px;
    aspect-ratio: 9 / 16;
    position: relative;
    overflow: hidden;
    background: #111;
  }
  @media (max-width: 640px) { .pp-ugc-item { width: 160px; } }
  .pp-ugc-item img,
  .pp-ugc-item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pp-ugc-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 28px 12px 10px;
    background: linear-gradient(to top, rgba(0,0,0,0.72), transparent);
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.75);
  }
  .pp-ugc-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 10px;
    color: rgba(255,255,255,0.15);
    border: 1px dashed rgba(255,255,255,0.1);
  }
  .pp-ugc-placeholder svg { width: 26px; height: 26px; fill: none; stroke: currentColor; stroke-width: 1.5; }
  .pp-ugc-placeholder span { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; }
  .pp-review-top {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }
  .pp-review-avatar {
    width: 40px; height: 40px;
    background: #000;
    color: #fff;
    font-weight: 700;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-transform: uppercase;
  }
  .pp-review-name {
    font-weight: 700;
    font-size: 13px;
    color: #000;
    letter-spacing: 0.02em;
  }
  .pp-review-date {
    font-size: 11px;
    color: rgba(0,0,0,0.35);
    margin-top: 2px;
    letter-spacing: 0.05em;
  }
  .pp-review-stars {
    font-size: 13px;
    letter-spacing: 2px;
    color: #000;
    margin-bottom: 14px;
  }
  .pp-review-text {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(0,0,0,0.6);
    margin: 0;
  }

  /* ─── FAQ ──────────────────────────────────────────────────────────────────── */
  .pp-faq {
    padding: 100px 0;
    background: #f9f9f9;
    border-top: 1px solid rgba(0,0,0,0.07);
  }
  @media (max-width: 768px) { .pp-faq { padding: 64px 0; } }

  .pp-faq-inner { max-width: 720px; margin: 0 auto; }
  .pp-faq-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    text-transform: uppercase;
    color: #000;
    margin-bottom: 48px;
    text-align: center;
    line-height: 0.95;
  }
  .pp-faq-item {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .pp-faq-q {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    text-align: left;
    color: #000;
  }
  .pp-faq-icon {
    font-size: 22px;
    font-weight: 300;
    transition: transform 300ms;
    flex-shrink: 0;
    margin-left: 16px;
    color: rgba(0,0,0,0.4);
    line-height: 1;
  }
  .pp-faq-item.is-open .pp-faq-icon { transform: rotate(45deg); }
  .pp-faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 400ms ease;
  }
  .pp-faq-item.is-open .pp-faq-a { max-height: 500px; }
  .pp-faq-a-inner {
    padding: 0 0 24px;
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 15px;
    line-height: 1.8;
    color: rgba(0,0,0,0.6);
  }

  /* ─── Sticky Mobile ATC ────────────────────────────────────────────────────── */
  .pp-sticky {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    z-index: 900;
    transform: translateY(100%);
    transition: transform 300ms ease;
    gap: 16px;
  }
  .pp-sticky.is-visible { transform: translateY(0); }
  .pp-sticky-info { display: flex; flex-direction: column; min-width: 0; }
  .pp-sticky-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pp-sticky-price { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 2px; }
  .pp-sticky-btn {
    background: #fff;
    color: #000;
    border: none;
    padding: 13px 24px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 200ms;
  }
  .pp-sticky-btn:hover { opacity: 0.85; }
  @media (min-width: 901px) { .pp-sticky { display: none !important; } }

  /* ─── Fade-in ──────────────────────────────────────────────────────────────── */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 600ms ease, transform 600ms ease;
  }
  .fade-in.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div class="pp">

  {%- comment -%} Breadcrumb {%- endcomment -%}
  <div class="pp-container">
    <nav class="pp-breadcrumb">
      <a href="/">Home</a><span>/</span>
      <a href="/collections/all">Shop</a><span>/</span>
      {{ product.title }}
    </nav>
  </div>

  {%- comment -%} ── TOP: Gallery + Info ── {%- endcomment -%}
  <section class="pp-top">
    <div class="pp-container">
      <div class="pp-layout">

        {%- comment -%} Gallery {%- endcomment -%}
        <div class="pp-gallery">
          <div class="pp-gallery-main">
            {% if product.featured_image %}
              <img
                id="pp-main-img"
                src="{{ product.featured_image | image_url: width: 1000 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="eager"
                width="1000"
              >
            {% else %}
              <div style="aspect-ratio:1/1;background:#f0f0f0;"></div>
            {% endif %}
          </div>
          {% if product.images.size > 1 %}
            <div class="pp-gallery-thumbs">
              {% for image in product.images limit: 5 %}
                <button
                  class="pp-thumb {% if forloop.first %}is-active{% endif %}"
                  data-src="{{ image | image_url: width: 1000 }}"
                  data-alt="{{ image.alt | escape }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}">
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {%- comment -%} Info {%- endcomment -%}
        <div class="pp-info">
          <p class="pp-eyebrow">{{ section.settings.eyebrow | default: 'Premium Microfiber' }}</p>
          <h1 class="pp-title">{{ product.title }}</h1>

          {% if section.settings.show_rating %}
            <div class="pp-rating">
              <span class="pp-stars">★★★★★</span>
              <span class="pp-rating-sep"></span>
              <span class="pp-rating-text">{{ section.settings.avg_rating }} · {{ section.settings.review_count }} reviews</span>
            </div>
          {% endif %}

          <div class="pp-price-row">
            <span class="pp-price">{{ product.price | money }}</span>
            {% if section.settings.compare_price != blank %}
              <span class="pp-price-compare">{{ section.settings.compare_price }}</span>
              <span class="pp-price-badge">BEST VALUE</span>
            {% endif %}
          </div>
          <p class="pp-shipping-note">Free shipping on every order · No minimum</p>

          <div class="pp-divider"></div>

          <div class="pp-short-desc">{{ section.settings.short_description }}</div>

          {%- comment -%} Spec pills {%- endcomment -%}
          {% assign has_specs = false %}
          {% for block in section.blocks %}
            {% if block.type == 'spec' %}{% assign has_specs = true %}{% endif %}
          {% endfor %}
          {% if has_specs %}
            <div class="pp-specs">
              {% for block in section.blocks %}
                {% if block.type == 'spec' %}
                  <div class="pp-spec-pill" {{ block.shopify_attributes }}>
                    {% if block.settings.icon != blank %}<span class="pp-spec-pill-icon">{{ block.settings.icon }}</span>{% endif %}
                    {{ block.settings.label }}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

          {%- comment -%} Variants {%- endcomment -%}
          {% if product.variants.size > 1 %}
            <div class="pp-variants">
              {% for option in product.options_with_values %}
                <div class="pp-variant-group">
                  <label class="pp-variant-label">{{ option.name }}</label>
                  <div class="pp-variant-opts">
                    {% for value in option.values %}
                      <button
                        class="pp-variant-btn {% if forloop.first %}is-selected{% endif %}"
                        data-option="{{ option.position }}"
                        data-value="{{ value }}"
                      >{{ value }}</button>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          {%- comment -%} Qty + ATC {%- endcomment -%}
          {% form 'product', product, id: 'pp-product-form' %}
            <input type="hidden" name="id" id="pp-selected-variant" value="{{ product.first_available_variant.id }}">
            <div class="pp-atc-row">
              <div class="pp-qty">
                <button type="button" class="pp-qty-btn" id="pp-qty-minus" aria-label="Decrease quantity">−</button>
                <span class="pp-qty-num" id="pp-qty-display">1</span>
                <button type="button" class="pp-qty-btn" id="pp-qty-plus" aria-label="Increase quantity">+</button>
              </div>
              <button
                type="button"
                id="pp-atc-btn"
                class="pp-atc-btn"
                data-variant-id="{{ product.first_available_variant.id }}"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Add to Cart — {{ product.price | money }}
              </button>
            </div>
          {% endform %}

          {%- comment -%} Trust row {%- endcomment -%}
          <div class="pp-trust-row">
            <div class="pp-trust-item">
              <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><path d="m16 8 5 0 3 5v3h-8z"/><circle cx="6" cy="19" r="2"/><circle cx="19" cy="19" r="2"/></svg>
              Free Shipping
            </div>
            <div class="pp-trust-item">
              <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Secure Checkout
            </div>
            <div class="pp-trust-item">
              <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Ships in 1–3 Days
            </div>
          </div>

          <div class="pp-guarantee">
            <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            <span>30-day satisfaction guarantee. Not happy? We'll make it right.</span>
          </div>

        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Sticky Mobile ATC {%- endcomment -%}
  <div id="pp-sticky" class="pp-sticky">
    <div class="pp-sticky-info">
      <span class="pp-sticky-title">{{ product.title }}</span>
      <span class="pp-sticky-price">{{ product.price | money }}</span>
    </div>
    <button class="pp-sticky-btn btn-atc" data-variant-id="{{ product.first_available_variant.id }}">
      Add to Cart
    </button>
  </div>

  {%- comment -%} ── FEATURE STRIP ── {%- endcomment -%}
  <div class="pp-feature-strip">
    <div class="pp-feature-strip-inner">
      {% for block in section.blocks %}
        {% if block.type == 'feature_stat' %}
          <div class="pp-feature-item" {{ block.shopify_attributes }}>
            <div class="pp-feature-num">{{ block.settings.stat }}</div>
            <div class="pp-feature-label">{{ block.settings.stat_label }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {%- comment -%} ── DESCRIPTION BLOCKS ── {%- endcomment -%}

  <div class="pp-desc-block fade-in">
    <div class="pp-container">
      <div class="pp-desc-grid">
        <div class="pp-desc-text">
          <p class="pp-desc-eyebrow">The Nova</p>
          <h2 class="pp-desc-heading">{{ section.settings.desc1_heading }}</h2>
          <div class="pp-desc-rule"></div>
          <div class="pp-desc-body">{{ section.settings.desc1_body }}</div>
        </div>
        <div class="pp-desc-img">
          {% if section.settings.desc1_image != blank %}
            <img src="{{ section.settings.desc1_image | image_url: width: 900 }}" alt="{{ section.settings.desc1_heading }}" loading="lazy">
          {% else %}
            <div class="pp-desc-img-placeholder"></div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} GSM Dark Block {%- endcomment -%}
  <div class="pp-gsm fade-in">
    <div class="pp-container">
      <p class="pp-gsm-eyebrow">Why it matters</p>
      <h2 class="pp-gsm-heading">{{ section.settings.gsm_heading }}</h2>
      <div class="pp-gsm-cards">
        {% for block in section.blocks %}
          {% if block.type == 'gsm_card' %}
            <div class="pp-gsm-card {% if block.settings.is_featured %}pp-gsm-card--polaris{% endif %}" {{ block.shopify_attributes }}>
              <div class="pp-gsm-val">{{ block.settings.gsm_value }}</div>
              <div class="pp-gsm-lbl">{{ block.settings.gsm_label }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="pp-desc-block pp-desc-block--reverse fade-in">
    <div class="pp-container">
      <div class="pp-desc-grid">
        <div class="pp-desc-img">
          {% if section.settings.desc3_image != blank %}
            <img src="{{ section.settings.desc3_image | image_url: width: 900 }}" alt="{{ section.settings.desc3_heading }}" loading="lazy">
          {% else %}
            <div class="pp-desc-img-placeholder"></div>
          {% endif %}
        </div>
        <div class="pp-desc-text">
          <p class="pp-desc-eyebrow">Real World Tested</p>
          <h2 class="pp-desc-heading">{{ section.settings.desc3_heading }}</h2>
          <div class="pp-desc-rule"></div>
          <div class="pp-desc-body">{{ section.settings.desc3_body }}</div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ── REVIEWS ── {%- endcomment -%}
  <section class="pp-reviews fade-in">
    <div class="pp-container">
      <div class="pp-reviews-header">
        <p class="pp-reviews-eyebrow">Social Proof</p>
        <h2 class="pp-reviews-heading">{{ section.settings.reviews_heading }}</h2>
        <p class="pp-reviews-rating">{{ section.settings.avg_rating }} ★★★★★ · {{ section.settings.review_count }} verified reviews</p>
      </div>
      <div class="pp-reviews-carousel">
        <div class="pp-reviews-track-wrap">
          <div class="pp-reviews-track" id="pp-reviews-track">
            {% for block in section.blocks %}
              {% if block.type == 'review' %}
                <div class="pp-review-card" {{ block.shopify_attributes }}>
                  <div class="pp-review-top">
                    <div class="pp-review-avatar">{{ block.settings.name | slice: 0, 1 }}</div>
                    <div>
                      <div class="pp-review-name">{{ block.settings.name }}</div>
                      <div class="pp-review-date">{{ block.settings.date }}</div>
                    </div>
                  </div>
                  <div class="pp-review-stars">{% for i in (1..block.settings.stars) %}★{% endfor %}</div>
                  <p class="pp-review-text">{{ block.settings.review_text }}</p>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        <div class="pp-reviews-nav">
          <button class="pp-reviews-btn pp-reviews-prev" aria-label="Previous">&#8249;</button>
          <div class="pp-reviews-dots" id="pp-reviews-dots"></div>
          <button class="pp-reviews-btn pp-reviews-next" aria-label="Next">&#8250;</button>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ── UGC CAROUSEL ── {%- endcomment -%}
  {% assign ugc_blocks = section.blocks | where: "type", "ugc_item" %}
  {% if ugc_blocks.size > 0 %}
  <section class="pp-ugc fade-in">
    <div class="pp-ugc-header">
      {% if section.settings.ugc_eyebrow != blank %}
        <p class="pp-ugc-eyebrow">{{ section.settings.ugc_eyebrow }}</p>
      {% endif %}
      <h2 class="pp-ugc-heading">{{ section.settings.ugc_heading }}</h2>
    </div>
    <div class="pp-ugc-track-wrap">
      <div class="pp-ugc-track" id="pp-ugc-track">
        {% for block in section.blocks %}
          {% if block.type == 'ugc_item' %}
            <div class="pp-ugc-item" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.caption | default: 'Community photo' }}" loading="lazy">
              {% elsif block.settings.video_url != blank %}
                <video src="{{ block.settings.video_url }}" autoplay muted loop playsinline></video>
              {% else %}
                <div class="pp-ugc-placeholder">
                  <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                  <span>Add photo or video</span>
                </div>
              {% endif %}
              {% if block.settings.caption != blank %}
                <div class="pp-ugc-caption">{{ block.settings.caption }}</div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
        {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
        {% for block in section.blocks %}
          {% if block.type == 'ugc_item' %}
            <div class="pp-ugc-item" aria-hidden="true">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="" loading="lazy">
              {% elsif block.settings.video_url != blank %}
                <video src="{{ block.settings.video_url }}" autoplay muted loop playsinline></video>
              {% else %}
                <div class="pp-ugc-placeholder">
                  <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                  <span>Add photo or video</span>
                </div>
              {% endif %}
              {% if block.settings.caption != blank %}
                <div class="pp-ugc-caption">{{ block.settings.caption }}</div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  {%- comment -%} ── FAQ ── {%- endcomment -%}
  <section class="pp-faq fade-in">
    <div class="pp-container">
      <div class="pp-faq-inner">
        <h2 class="pp-faq-heading">{{ section.settings.faq_heading }}</h2>
        {% for block in section.blocks %}
          {% if block.type == 'faq' %}
            <div class="pp-faq-item" {{ block.shopify_attributes }}>
              <button class="pp-faq-q">
                <span>{{ block.settings.question }}</span>
                <span class="pp-faq-icon">+</span>
              </button>
              <div class="pp-faq-a">
                <div class="pp-faq-a-inner">{{ block.settings.answer }}</div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

</div>

<script>
(function () {
  /* ── Gallery ──────────────────────────────────────── */
  var mainImg = document.getElementById('pp-main-img');
  document.querySelectorAll('.pp-thumb').forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(function () {
          mainImg.src = thumb.dataset.src;
          mainImg.alt = thumb.dataset.alt;
          mainImg.style.opacity = '1';
        }, 150);
      }
      document.querySelectorAll('.pp-thumb').forEach(function (t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
    });
  });

  /* ── Quantity ─────────────────────────────────────── */
  var qtyDisplay = document.getElementById('pp-qty-display');
  var qty = 1;
  document.getElementById('pp-qty-plus') && document.getElementById('pp-qty-plus').addEventListener('click', function () {
    qty = Math.min(qty + 1, 99);
    qtyDisplay.textContent = qty;
  });
  document.getElementById('pp-qty-minus') && document.getElementById('pp-qty-minus').addEventListener('click', function () {
    qty = Math.max(qty - 1, 1);
    qtyDisplay.textContent = qty;
  });

  /* ── Variant selection ────────────────────────────── */
  document.querySelectorAll('.pp-variant-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var optPos = btn.dataset.option;
      document.querySelectorAll('.pp-variant-btn[data-option="' + optPos + '"]').forEach(function (b) {
        b.classList.remove('is-selected');
      });
      btn.classList.add('is-selected');
    });
  });

  /* ── ATC ──────────────────────────────────────────── */
  function handleAtc(btn) {
    var variantId = btn.dataset.variantId;
    if (!variantId) return;
    var origText = btn.textContent;
    btn.textContent = 'Adding…';
    btn.disabled = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty || 1 })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      btn.textContent = 'Added ✓';
      document.dispatchEvent(new CustomEvent('cart:open'));
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      setTimeout(function () {
        btn.textContent = origText;
        btn.disabled = false;
      }, 2000);
    })
    .catch(function (err) {
      console.error('ATC error', err);
      btn.textContent = origText;
      btn.disabled = false;
    });
  }

  var mainAtcBtn = document.getElementById('pp-atc-btn');
  if (mainAtcBtn) mainAtcBtn.addEventListener('click', function () { handleAtc(mainAtcBtn); });

  document.querySelectorAll('.pp-sticky-btn').forEach(function (btn) {
    btn.addEventListener('click', function () { handleAtc(btn); });
  });

  /* ── Sticky visibility ────────────────────────────── */
  var stickyBar = document.getElementById('pp-sticky');
  var topSection = document.querySelector('.pp-top');
  if (stickyBar && topSection) {
    new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        stickyBar.classList.toggle('is-visible', !e.isIntersecting);
      });
    }, { threshold: 0 }).observe(topSection);
  }

  /* ── FAQ ──────────────────────────────────────────── */
  document.querySelectorAll('.pp-faq-q').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.pp-faq-item');
      item.classList.toggle('is-open');
    });
  });

  /* ── Fade-in ──────────────────────────────────────── */
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(function (el) { obs.observe(el); });
  } else {
    document.querySelectorAll('.fade-in').forEach(function (el) { el.classList.add('is-visible'); });
  }

  /* ── Reviews Carousel ────────────────────────────── */
  (function () {
    var track = document.getElementById('pp-reviews-track');
    if (!track) return;
    var wrap = track.parentElement;

    var origCards = Array.from(track.querySelectorAll('.pp-review-card'));
    var total = origCards.length;
    if (total < 2) return;

    // Prepend clones (for seamless backward wrap)
    var prepFrag = document.createDocumentFragment();
    origCards.forEach(function (card) { prepFrag.appendChild(card.cloneNode(true)); });
    track.insertBefore(prepFrag, track.firstChild);

    // Append clones (for seamless forward wrap)
    origCards.forEach(function (card) { track.appendChild(card.cloneNode(true)); });

    // Layout: [clones_before | originals | clones_after]
    // Real cards start at index `total`
    var current = total;
    var transitioning = false;
    var autoTimer = null;

    var dotsEl = document.getElementById('pp-reviews-dots');
    var dots = [];

    for (var i = 0; i < total; i++) {
      var dot = document.createElement('button');
      dot.className = 'pp-reviews-dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('aria-label', 'Review ' + (i + 1));
      (function (idx) {
        dot.addEventListener('click', function () { resetTimer(); goTo(total + idx); });
      })(i);
      if (dotsEl) dotsEl.appendChild(dot);
      dots.push(dot);
    }

    function perPage() { return window.innerWidth <= 900 ? 1 : 3; }
    function cardWidth() { return wrap.getBoundingClientRect().width / perPage(); }

    function updateDots() {
      var realIdx = ((current - total) % total + total) % total;
      dots.forEach(function (d, i) { d.classList.toggle('is-active', i === realIdx); });
    }

    function goTo(idx, instant) {
      if (transitioning && !instant) return;
      current = idx;
      var offset = current * cardWidth();
      track.style.transition = instant ? 'none' : 'transform 420ms ease';
      track.style.transform = 'translateX(-' + offset + 'px)';
      updateDots();
      if (!instant) transitioning = true;
    }

    track.addEventListener('transitionend', function () {
      transitioning = false;
      if (current >= total * 2) { goTo(current - total, true); }
      else if (current < total)  { goTo(current + total, true); }
    });

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }
    function startTimer() { autoTimer = setInterval(next, 4000); }
    function stopTimer()  { clearInterval(autoTimer); }
    function resetTimer() { stopTimer(); startTimer(); }

    var prevBtn = document.querySelector('.pp-reviews-prev');
    var nextBtn = document.querySelector('.pp-reviews-next');
    if (prevBtn) prevBtn.addEventListener('click', function () { resetTimer(); prev(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { resetTimer(); next(); });

    var carousel = document.querySelector('.pp-reviews-carousel');
    if (carousel) {
      carousel.addEventListener('mouseenter', stopTimer);
      carousel.addEventListener('mouseleave', startTimer);
    }

    goTo(current, true);
    startTimer();
  })();

  /* ── UGC touch pause ─────────────────────────────── */
  (function () {
    var ugcTrack = document.getElementById('pp-ugc-track');
    if (!ugcTrack) return;
    ugcTrack.addEventListener('touchstart', function () {
      ugcTrack.style.animationPlayState = 'paused';
    }, { passive: true });
    ugcTrack.addEventListener('touchend', function () {
      ugcTrack.style.animationPlayState = 'running';
    }, { passive: true });
  })();

})();
</script>

{% schema %}
{
  "name": "Product Main",
  "tag": "div",
  "settings": [
