{{ 'cart-drawer.css' | asset_url | stylesheet_tag }}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@300;400&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  /* ─── Reset / Base ─────────────────────────────────────────────────────────── */
  .pp {
    font-family: 'DM Sans', sans-serif;
    background: #fff;
    color: #000;
  }

  .pp-container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media (max-width: 640px) { .pp-container { padding: 0 20px; } }

  /* ─── Breadcrumb ───────────────────────────────────────────────────────────── */
  .pp-breadcrumb {
    padding: 16px 0 0;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.35);
  }
  .pp-breadcrumb a { color: inherit; text-decoration: none; }
  .pp-breadcrumb a:hover { color: #000; }
  .pp-breadcrumb span { margin: 0 6px; }

  /* ─── Top Layout ───────────────────────────────────────────────────────────── */
  .pp-top {
    padding: 32px 0 80px;
  }

  .pp-layout {
    display: grid;
    grid-template-columns: 55% 1fr;
    gap: 72px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .pp-layout { grid-template-columns: 1fr; gap: 40px; }
    .pp-top { padding: 24px 0 60px; }
  }

  /* ─── Gallery ──────────────────────────────────────────────────────────────── */
  .pp-gallery {
    position: sticky;
    top: 80px;
  }

  @media (max-width: 900px) { .pp-gallery { position: static; } }

  .pp-gallery-main {
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
    margin-bottom: 12px;
  }

  .pp-gallery-main img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    transition: opacity 180ms ease;
  }

  .pp-gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
  }

  .pp-thumb {
    background: none;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 200ms;
    aspect-ratio: 1/1;
  }

  .pp-thumb.is-active,
  .pp-thumb:hover {
    border-color: #000;
  }

  .pp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ─── Info Column ──────────────────────────────────────────────────────────── */
  .pp-info {}

  .pp-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.35);
    margin-bottom: 10px;
  }

  .pp-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 5.5rem);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: 0.01em;
    color: #000;
    margin-bottom: 20px;
  }

  /* Rating row */
  .pp-rating {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
  }
  .pp-stars { font-size: 14px; letter-spacing: 2px; color: #000; }
  .pp-rating-text { font-size: 13px; color: rgba(0,0,0,0.5); }
  .pp-rating-sep { width: 1px; height: 14px; background: rgba(0,0,0,0.15); }

  /* Price */
  .pp-price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 6px;
  }
  .pp-price {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 2.4rem;
    color: #000;
    letter-spacing: 0.02em;
  }
  .pp-price-compare {
    font-size: 1rem;
    color: rgba(0,0,0,0.35);
    text-decoration: line-through;
  }
  .pp-price-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: #000;
    color: #fff;
    padding: 3px 8px;
  }

  .pp-shipping-note {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
    margin-bottom: 24px;
  }

  /* Divider */
  .pp-divider {
    height: 1px;
    background: rgba(0,0,0,0.08);
    margin: 24px 0;
  }

  /* Short desc */
  .pp-short-desc {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(0,0,0,0.65);
    margin-bottom: 24px;
  }

  /* Spec pills */
  .pp-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }
  .pp-spec-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(0,0,0,0.15);
    padding: 7px 14px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
  }
  .pp-spec-pill-icon { font-size: 13px; }

  /* Variant selector */
  .pp-variants { margin-bottom: 20px; }
  .pp-variant-group { margin-bottom: 14px; }
  .pp-variant-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 10px;
    color: rgba(0,0,0,0.5);
  }
  .pp-variant-opts { display: flex; gap: 8px; flex-wrap: wrap; }
  .pp-variant-btn {
    padding: 9px 20px;
    border: 1px solid rgba(0,0,0,0.2);
    background: transparent;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    transition: background 180ms, border-color 180ms, color 180ms;
    color: #000;
  }
  .pp-variant-btn:hover,
  .pp-variant-btn.is-selected {
    background: #000;
    color: #fff;
    border-color: #000;
  }

  /* Qty + ATC row */
  .pp-atc-row {
    display: flex;
    gap: 12px;
    margin-bottom: 14px;
  }

  .pp-qty {
    display: flex;
    align-items: center;
    border: 1px solid rgba(0,0,0,0.2);
    flex-shrink: 0;
  }
  .pp-qty-btn {
    width: 42px;
    height: 56px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 20px;
    font-weight: 300;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms;
  }
  .pp-qty-btn:hover { background: rgba(0,0,0,0.05); }
  .pp-qty-num {
    width: 36px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    border: none;
    outline: none;
    background: transparent;
    pointer-events: none;
  }

  .pp-atc-btn {
    flex: 1;
    height: 56px;
    background: #000;
    color: #fff;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: background 200ms;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .pp-atc-btn:hover { background: #1a1a1a; }
  .pp-atc-btn:active { background: #333; }

  /* Trust row */
  .pp-trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 14px 0;
    border-top: 1px solid rgba(0,0,0,0.07);
    border-bottom: 1px solid rgba(0,0,0,0.07);
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .pp-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.5);
    white-space: nowrap;
  }
  .pp-trust-item svg {
    width: 14px; height: 14px;
    stroke: rgba(0,0,0,0.4);
    fill: none;
    stroke-width: 2;
    flex-shrink: 0;
  }

  /* Guarantee line */
  .pp-guarantee {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    background: #f8f8f8;
    border-left: 3px solid #000;
    font-size: 13px;
    font-weight: 500;
    color: rgba(0,0,0,0.7);
  }
  .pp-guarantee svg {
    width: 18px; height: 18px;
    stroke: #000;
    fill: none;
    stroke-width: 2;
    flex-shrink: 0;
  }

  /* ─── Feature Strip ────────────────────────────────────────────────────────── */
  .pp-feature-strip {
    background: #000;
    padding: 0;
  }
  .pp-feature-strip-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  @media (max-width: 768px) {
    .pp-feature-strip-inner { grid-template-columns: repeat(2, 1fr); }
  }
  .pp-feature-item {
    padding: 36px 28px;
    border-right: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  @media (max-width: 540px) { .pp-feature-item { padding: 28px 20px; } }
  .pp-feature-item:last-child { border-right: none; }
  .pp-feature-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2.8rem;
    color: #fff;
    line-height: 1;
    margin-bottom: 6px;
  }
  .pp-feature-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  /* ─── Description Blocks ───────────────────────────────────────────────────── */
  .pp-desc-block {
    padding: 100px 0;
  }
  .pp-desc-block:nth-child(even) { background: #f9f9f9; }

  .pp-desc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  @media (max-width: 768px) {
    .pp-desc-grid { grid-template-columns: 1fr; gap: 40px; }
    .pp-desc-block { padding: 64px 0; }
    .pp-desc-block--reverse .pp-desc-img { order: -1; }
  }

  .pp-desc-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin-bottom: 14px;
  }
  .pp-desc-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #000;
    margin-bottom: 20px;
  }
  .pp-desc-rule {
    width: 36px; height: 2px;
    background: rgba(0,0,0,0.15);
    margin-bottom: 20px;
  }
  .pp-desc-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(0,0,0,0.6);
  }
  .pp-desc-img img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }
  .pp-desc-img-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #e8e8e8;
  }

  /* ─── GSM Dark Section ─────────────────────────────────────────────────────── */
  .pp-gsm {
    background: #000;
    padding: 100px 0;
    text-align: center;
  }
  @media (max-width: 768px) { .pp-gsm { padding: 64px 0; } }

  .pp-gsm-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 16px;
  }
  .pp-gsm-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 56px;
    line-height: 0.95;
  }
  .pp-gsm-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    max-width: 760px;
    margin: 0 auto;
    background: rgba(255,255,255,0.1);
  }
  @media (max-width: 600px) { .pp-gsm-cards { grid-template-columns: 1fr; } }
  .pp-gsm-card {
    background: #000;
    padding: 48px 32px;
  }
  .pp-gsm-card--polaris {
    background: #fff;
  }
  .pp-gsm-val {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2.8rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: 8px;
    line-height: 1;
  }
  .pp-gsm-card--polaris .pp-gsm-val { color: #000; }
  .pp-gsm-lbl {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }
  .pp-gsm-card--polaris .pp-gsm-lbl { color: rgba(0,0,0,0.5); }

  /* ─── Benefits Bar ─────────────────────────────────────────────────────────── */
  .pp-benefits {
    background: #fff;
    border-top: 1px solid rgba(0,0,0,0.07);
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }
  .pp-benefits-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 900px) { .pp-benefits-inner { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px)  { .pp-benefits-inner { grid-template-columns: 1fr; } }
  .pp-benefit-item {
    padding: 40px 32px;
    border-right: 1px solid rgba(0,0,0,0.07);
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }
  @media (max-width: 900px) {
    .pp-benefit-item:nth-child(2n) { border-right: none; }
  }
  @media (min-width: 901px) {
    .pp-benefit-item:last-child { border-right: none; }
  }
  .pp-benefit-icon {
    font-size: 22px;
    margin-bottom: 14px;
    display: block;
  }
  .pp-benefit-title {
    font-weight: 700;
    font-size: 14px;
    color: #000;
    margin-bottom: 8px;
    letter-spacing: 0.01em;
  }
  .pp-benefit-desc {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 13px;
    color: rgba(0,0,0,0.55);
    line-height: 1.65;
  }

  /* ─── Why Nova ──────────────────────────────────────────────────────────────── */
  .pp-why {
    background: #050505;
    padding: 100px 0;
  }
  @media (max-width: 768px) { .pp-why { padding: 64px 0; } }
  .pp-why-header {
    text-align: center;
    margin-bottom: 52px;
  }
  .pp-why-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 16px;
  }
  .pp-why-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    text-transform: uppercase;
    color: #fff;
    line-height: 0.95;
  }
  .pp-why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(255,255,255,0.07);
    max-width: 820px;
    margin: 0 auto;
  }
  @media (max-width: 560px) {
    .pp-why-grid { grid-template-columns: 1fr; }
  }
  .pp-why-col { background: #050505; }
  .pp-why-col-head {
    padding: 20px 32px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .pp-why-col--nova .pp-why-col-head {
    color: #fff;
    background: rgba(255,255,255,0.03);
  }
  .pp-why-col--other .pp-why-col-head { color: rgba(255,255,255,0.25); }
  .pp-why-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 32px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
  }
  .pp-why-row:last-child { border-bottom: none; }
  .pp-why-col--nova .pp-why-row  { color: rgba(255,255,255,0.8); }
  .pp-why-col--other .pp-why-row { color: rgba(255,255,255,0.25); }
  .pp-why-check { font-size: 13px; flex-shrink: 0; width: 16px; }
  .pp-why-col--nova .pp-why-check  { color: #fff; }
  .pp-why-col--other .pp-why-check { color: rgba(255,255,255,0.2); }

  /* ─── Reviews ──────────────────────────────────────────────────────────────── */
  .pp-reviews {
    background: #fafafa;
    padding: 100px 0;
    border-top: 1px solid rgba(0,0,0,0.07);
    overflow: hidden;
  }
  @media (max-width: 768px) { .pp-reviews { padding: 64px 0; } }

  .pp-reviews-header {
    text-align: center;
    margin-bottom: 52px;
    padding: 0 40px;
  }
  @media (max-width: 640px) { .pp-reviews-header { padding: 0 20px; } }
  .pp-reviews-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.3);
    margin-bottom: 16px;
  }
  .pp-reviews-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    text-transform: uppercase;
    color: #000;
    margin-bottom: 12px;
    line-height: 0.95;
  }
  .pp-reviews-rating {
    font-size: 13px;
    color: rgba(0,0,0,0.4);
    letter-spacing: 0.05em;
  }

  /* Reviews marquee */
  .pp-reviews-marquee-wrap { overflow: hidden; }
  .pp-reviews-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }
  .pp-reviews-track:hover { animation-play-state: paused; }
  .pp-review-card {
    flex-shrink: 0;
    width: 360px;
    background: #fff;
    padding: 36px 32px;
    border-right: 1px solid rgba(0,0,0,0.07);
    border-bottom: 1px solid rgba(0,0,0,0.07);
    box-sizing: border-box;
  }
  @media (max-width: 540px) { .pp-review-card { width: 280px; padding: 28px 22px; } }

  /* UGC carousel */
  .pp-ugc {
    background: #000;
    padding: 80px 0;
    overflow: hidden;
  }
  @media (max-width: 640px) { .pp-ugc { padding: 56px 0; } }
  .pp-ugc-header {
    text-align: center;
    margin-bottom: 40px;
    padding: 0 40px;
  }
  .pp-ugc-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 14px;
  }
  .pp-ugc-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3rem);
    text-transform: uppercase;
    color: #fff;
    line-height: 0.95;
  }
  .pp-ugc-track-wrap { overflow: hidden; }
  .pp-ugc-track {
    display: flex;
    gap: 10px;
    width: max-content;
    will-change: transform;
  }
  .pp-ugc-track:hover { animation-play-state: paused; }
  .pp-ugc-item {
    flex-shrink: 0;
    width: 220px;
    aspect-ratio: 9 / 16;
    position: relative;
    overflow: hidden;
    background: #111;
    display: block;
  }
  @media (max-width: 640px) { .pp-ugc-item { width: 160px; } }
  .pp-ugc-item img,
  .pp-ugc-item video,
  .pp-ugc-item .pp-ugc-vid {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block !important;
    position: absolute !important;
    top: 0; left: 0;
  }
  .pp-ugc-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 28px 12px 10px;
    background: linear-gradient(to top, rgba(0,0,0,0.72), transparent);
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.75);
  }
  .pp-ugc-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 10px;
    color: rgba(255,255,255,0.15);
    border: 1px dashed rgba(255,255,255,0.1);
  }
  .pp-ugc-placeholder svg { width: 26px; height: 26px; fill: none; stroke: currentColor; stroke-width: 1.5; }
  .pp-ugc-placeholder span { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; }
  .pp-review-top {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }
  .pp-review-avatar {
    width: 40px; height: 40px;
    background: #000;
    color: #fff;
    font-weight: 700;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    text-transform: uppercase;
  }
  .pp-review-name {
    font-weight: 700;
    font-size: 13px;
    color: #000;
    letter-spacing: 0.02em;
  }
  .pp-review-date {
    font-size: 11px;
    color: rgba(0,0,0,0.35);
    margin-top: 2px;
    letter-spacing: 0.05em;
  }
  .pp-review-stars {
    font-size: 13px;
    letter-spacing: 2px;
    color: #000;
    margin-bottom: 14px;
  }
  .pp-review-text {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(0,0,0,0.6);
    margin: 0;
  }

  /* ─── FAQ ──────────────────────────────────────────────────────────────────── */
  .pp-faq {
    padding: 100px 0;
    background: #f9f9f9;
    border-top: 1px solid rgba(0,0,0,0.07);
  }
  @media (max-width: 768px) { .pp-faq { padding: 64px 0; } }

  .pp-faq-inner { max-width: 720px; margin: 0 auto; }
  .pp-faq-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    text-transform: uppercase;
    color: #000;
    margin-bottom: 48px;
    text-align: center;
    line-height: 0.95;
  }
  .pp-faq-item {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .pp-faq-q {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    text-align: left;
    color: #000;
  }
  .pp-faq-icon {
    font-size: 22px;
    font-weight: 300;
    transition: transform 300ms;
    flex-shrink: 0;
    margin-left: 16px;
    color: rgba(0,0,0,0.4);
    line-height: 1;
  }
  .pp-faq-item.is-open .pp-faq-icon { transform: rotate(45deg); }
  .pp-faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 400ms ease;
  }
  .pp-faq-item.is-open .pp-faq-a { max-height: 500px; }
  .pp-faq-a-inner {
    padding: 0 0 24px;
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 15px;
    line-height: 1.8;
    color: rgba(0,0,0,0.6);
  }

  /* ─── Sticky Mobile ATC ────────────────────────────────────────────────────── */
  .pp-sticky {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    z-index: 900;
    transform: translateY(100%);
    transition: transform 300ms ease;
    gap: 16px;
  }
  .pp-sticky.is-visible { transform: translateY(0); }
  .pp-sticky-info { display: flex; flex-direction: column; min-width: 0; }
  .pp-sticky-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pp-sticky-price { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 2px; }
  .pp-sticky-btn {
    background: #fff;
    color: #000;
    border: none;
    padding: 13px 24px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 200ms;
  }
  .pp-sticky-btn:hover { opacity: 0.85; }
  @media (min-width: 901px) { .pp-sticky { display: none !important; } }

  /* ─── Fade-in ──────────────────────────────────────────────────────────────── */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 600ms ease, transform 600ms ease;
  }
  .fade-in.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div class="pp">

  {%- comment -%} Breadcrumb {%- endcomment -%}
  <div class="pp-container">
    <nav class="pp-breadcrumb">
      <a href="/">Home</a><span>/</span>
      <a href="/collections/all">Shop</a><span>/</span>
      {{ product.title }}
    </nav>
  </div>

  {%- comment -%} ── TOP: Gallery + Info ── {%- endcomment -%}
  <section class="pp-top">
    <div class="pp-container">
      <div class="pp-layout">

        {%- comment -%} Gallery {%- endcomment -%}
        <div class="pp-gallery">
          <div class="pp-gallery-main">
            {% if product.featured_image %}
              <img
                id="pp-main-img"
                src="{{ product.featured_image | image_url: width: 1000 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="eager"
                width="1000"
              >
            {% else %}
              <div style="aspect-ratio:1/1;background:#f0f0f0;"></div>
            {% endif %}
          </div>
          {% if product.images.size > 1 %}
            <div class="pp-gallery-thumbs">
              {% for image in product.images limit: 5 %}
                <button
                  class="pp-thumb {% if forloop.first %}is-active{% endif %}"
                  data-src="{{ image | image_url: width: 1000 }}"
                  data-alt="{{ image.alt | escape }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}">
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {%- comment -%} Info {%- endcomment -%}
        <div class="pp-info">
          <p class="pp-eyebrow">{{ section.settings.eyebrow | default: 'Premium Microfiber' }}</p>
          <h1 class="pp-title">{{ product.title }}</h1>

          {% if section.settings.show_rating %}
            <div class="pp-rating">
              <span class="pp-stars">★★★★★</span>
              <span class="pp-rating-sep"></span>
              <span class="pp-rating-text">{{ section.settings.avg_rating }} · {{ section.settings.review_count }} reviews</span>
            </div>
          {% endif %}

          <div class="pp-price-row">
            <span class="pp-price">{{ product.price | money }}</span>
            {% if section.settings.compare_price != blank %}
              <span class="pp-price-compare">{{ section.settings.compare_price }}</span>
              <span class="pp-price-badge">BEST VALUE</span>
            {% endif %}
          </div>
          <p class="pp-shipping-note">Free shipping on every order · No minimum</p>

          <div class="pp-divider"></div>

          <div class="pp-short-desc">{{ section.settings.short_description }}</div>

          {%- comment -%} Spec pills {%- endcomment -%}
          {% assign has_specs = false %}
          {% for block in section.blocks %}
            {% if block.type == 'spec' %}{% assign has_specs = true %}{% endif %}
          {% endfor %}
          {% if has_specs %}
            <div class="pp-specs">
              {% for block in section.blocks %}
                {% if block.type == 'spec' %}
                  <div class="pp-spec-pill" {{ block.shopify_attributes }}>
                    {% if block.settings.icon != blank %}<span class="pp-spec-pill-icon">{{ block.settings.icon }}</span>{% endif %}
                    {{ block.settings.label }}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

          {%- comment -%} Variants {%- endcomment -%}
          {% if product.variants.size > 1 %}
            <div class="pp-variants">
              {% for option in product.options_with_values %}
                <div class="pp-variant-group">
                  <label class="pp-variant-label">{{ option.name }}</label>
                  <div class="pp-variant-opts">
                    {% for value in option.values %}
                      <button
                        class="pp-variant-btn {% if forloop.first %}is-selected{% endif %}"
                        data-option="{{ option.position }}"
                        data-value="{{ value }}"
                      >{{ value }}</button>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          {%- comment -%} Qty + ATC {%- endcomment -%}
          {% form 'product', product, id: 'pp-product-form' %}
            <input type="hidden" name="id" id="pp-selected-variant" value="{{ product.first_available_variant.id }}">
            <div class="pp-atc-row">
              <div class="pp-qty">
                <button type="button" class="pp-qty-btn" id="pp-qty-minus" aria-label="Decrease quantity">−</button>
                <span class="pp-qty-num" id="pp-qty-display">1</span>
                <button type="button" class="pp-qty-btn" id="pp-qty-plus" aria-label="Increase quantity">+</button>
              </div>
              <button
                type="button"
                id="pp-atc-btn"
                class="pp-atc-btn"
                data-variant-id="{{ product.first_available_variant.id }}"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Add to Cart — {{ product.price | money }}
              </button>
            </div>
          {% endform %}

          {%- comment -%} Trust row {%- endcomment -%}
          <div class="pp-trust-row">
            <div class="pp-trust-item">
              <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><path d="m16 8 5 0 3 5v3h-8z"/><circle cx="6" cy="19" r="2"/><circle cx="19" cy="19" r="2"/></svg>
              Free Shipping
            </div>
            <div class="pp-trust-item">
              <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Secure Checkout
            </div>
            <div class="pp-trust-item">
              <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Ships in 1–3 Days
            </div>
          </div>

          <div class="pp-guarantee">
            <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            <span>30-day satisfaction guarantee. Not happy? We'll make it right.</span>
          </div>

        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Sticky Mobile ATC {%- endcomment -%}
  <div id="pp-sticky" class="pp-sticky">
    <div class="pp-sticky-info">
      <span class="pp-sticky-title">{{ product.title }}</span>
      <span class="pp-sticky-price">{{ product.price | money }}</span>
    </div>
