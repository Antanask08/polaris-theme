  </div>

  {%- comment -%} ── FEATURE STRIP ── {%- endcomment -%}
  <div class="pp-feature-strip">
    <div class="pp-feature-strip-inner">
      {% for block in section.blocks %}
        {% if block.type == 'feature_stat' %}
          <div class="pp-feature-item" {{ block.shopify_attributes }}>
            <div class="pp-feature-num">{{ block.settings.stat }}</div>
            <div class="pp-feature-label">{{ block.settings.stat_label }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {%- comment -%} ── BENEFITS BAR ── {%- endcomment -%}
  <div class="pp-benefits fade-in">
    <div class="pp-benefits-inner">
      <div class="pp-benefit-item">
        <span class="pp-benefit-icon">💧</span>
        <div class="pp-benefit-title">Absorbs 3x More</div>
        <div class="pp-benefit-desc">1200 GSM is more than double the density of most microfibers. One pass dries a full panel with no re-wipes.</div>
