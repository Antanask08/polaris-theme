<script>
(function () {
  /* ── Gallery ──────────────────────────────────────── */
  var mainImg = document.getElementById('pp-main-img');
  document.querySelectorAll('.pp-thumb').forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(function () {
          mainImg.src = thumb.dataset.src;
          mainImg.alt = thumb.dataset.alt;
          mainImg.style.opacity = '1';
        }, 150);
      }
      document.querySelectorAll('.pp-thumb').forEach(function (t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
    });
  });

  /* ── Quantity ─────────────────────────────────────── */
  var qtyDisplay = document.getElementById('pp-qty-display');
  var qty = 1;
  document.getElementById('pp-qty-plus') && document.getElementById('pp-qty-plus').addEventListener('click', function () {
    qty = Math.min(qty + 1, 99);
    qtyDisplay.textContent = qty;
  });
  document.getElementById('pp-qty-minus') && document.getElementById('pp-qty-minus').addEventListener('click', function () {
    qty = Math.max(qty - 1, 1);
    qtyDisplay.textContent = qty;
  });

  /* ── Variant selection ────────────────────────────── */
  document.querySelectorAll('.pp-variant-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var optPos = btn.dataset.option;
      document.querySelectorAll('.pp-variant-btn[data-option="' + optPos + '"]').forEach(function (b) {
        b.classList.remove('is-selected');
      });
      btn.classList.add('is-selected');
    });
  });

  /* ── ATC ──────────────────────────────────────────── */
  function handleAtc(btn) {
    var variantId = btn.dataset.variantId;
    if (!variantId) return;
    var origText = btn.textContent;
    btn.textContent = 'Adding…';
    btn.disabled = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty || 1 })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      btn.textContent = 'Added ✓';
      document.dispatchEvent(new CustomEvent('cart:open'));
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      setTimeout(function () {
        btn.textContent = origText;
        btn.disabled = false;
      }, 2000);
    })
    .catch(function (err) {
      console.error('ATC error', err);
      btn.textContent = origText;
      btn.disabled = false;
    });
  }

  var mainAtcBtn = document.getElementById('pp-atc-btn');
  if (mainAtcBtn) mainAtcBtn.addEventListener('click', function () { handleAtc(mainAtcBtn); });

  document.querySelectorAll('.pp-sticky-btn').forEach(function (btn) {
    btn.addEventListener('click', function () { handleAtc(btn); });
  });

  /* ── Sticky visibility ────────────────────────────── */
  var stickyBar = document.getElementById('pp-sticky');
  var topSection = document.querySelector('.pp-top');
  if (stickyBar && topSection) {
    new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        stickyBar.classList.toggle('is-visible', !e.isIntersecting);
      });
    }, { threshold: 0 }).observe(topSection);
  }

  /* ── FAQ ──────────────────────────────────────────── */
  document.querySelectorAll('.pp-faq-q').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.pp-faq-item');
      item.classList.toggle('is-open');
    });
  });

  /* ── Fade-in ──────────────────────────────────────── */
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(function (el) { obs.observe(el); });
  } else {
    document.querySelectorAll('.fade-in').forEach(function (el) { el.classList.add('is-visible'); });
  }

  /* ── Reviews infinite scroll ────────────────────── */
  (function () {
    var track = document.getElementById('pp-reviews-track');
    if (!track) return;

    var GAP = 0; // cards use border-right, no CSS gap needed
    var origCards = Array.from(track.querySelectorAll('.pp-review-card'));
    if (!origCards.length) return;

    function cloneSet() {
      origCards.forEach(function (card) {
        var clone = card.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        track.appendChild(clone);
      });
    }

    cloneSet();
    while (track.scrollWidth < window.innerWidth * 2.5) { cloneSet(); }

    var origWidth = 0;
    origCards.forEach(function (card) { origWidth += card.offsetWidth + GAP; });

    var styleEl = document.createElement('style');
    styleEl.textContent =
      '@keyframes rev-infinite{' +
        'from{transform:translateX(0)}' +
        'to{transform:translateX(-' + origWidth + 'px)}' +
      '}';
    document.head.appendChild(styleEl);

    track.style.animation = 'rev-infinite 50s linear infinite';

    track.addEventListener('mouseenter', function () {
      track.style.animationPlayState = 'paused';
    });
    track.addEventListener('mouseleave', function () {
      track.style.animationPlayState = 'running';
    });
    track.addEventListener('touchstart', function () {
      track.style.animationPlayState = 'paused';
    }, { passive: true });
    track.addEventListener('touchend', function () {
      track.style.animationPlayState = 'running';
    }, { passive: true });
  })();

  /* ── UGC infinite scroll ─────────────────────────── */
  (function () {
    var track = document.getElementById('pp-ugc-track');
    if (!track) return;

    var GAP = 10; // matches CSS gap: 10px

    // Grab the original items before any cloning
    var origItems = Array.from(track.children);
    if (!origItems.length) return;

    // Clone a full set of originals and append
    function cloneSet() {
      origItems.forEach(function (item) {
        var clone = item.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        // Re-trigger autoplay on any cloned videos
        var vids = clone.querySelectorAll('video');
        vids.forEach(function (v) { v.play && v.play(); });
        track.appendChild(clone);
      });
    }

    // Keep cloning until the track is at least 2.5x the viewport wide
    // so there's always enough content to scroll through without gaps
    cloneSet();
    while (track.scrollWidth < window.innerWidth * 2.5) {
      cloneSet();
    }

    // Calculate the pixel distance of exactly one original set
    // (item widths + gap after each item)
    var origWidth = 0;
    origItems.forEach(function (item) {
      origWidth += item.offsetWidth + GAP;
    });

    // Inject a precise keyframe and apply the animation
    var styleEl = document.createElement('style');
    styleEl.textContent =
      '@keyframes ugc-infinite{' +
        'from{transform:translateX(0)}' +
        'to{transform:translateX(-' + origWidth + 'px)}' +
      '}';
    document.head.appendChild(styleEl);

    var speed = 35; // seconds for one full set to scroll past
    track.style.animation = 'ugc-infinite ' + speed + 's linear infinite';

    // Pause on hover (desktop)
    track.addEventListener('mouseenter', function () {
      track.style.animationPlayState = 'paused';
    });
    track.addEventListener('mouseleave', function () {
      track.style.animationPlayState = 'running';
    });

    // Pause on touch (mobile)
    track.addEventListener('touchstart', function () {
      track.style.animationPlayState = 'paused';
    }, { passive: true });
    track.addEventListener('touchend', function () {
      track.style.animationPlayState = 'running';
    }, { passive: true });
  })();

})();
</script>

