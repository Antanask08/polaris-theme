<script>
(function() {
  /* ── Fiber pile ── */
  document.querySelectorAll('.pdp-pile').forEach(function(el) {
    var pct = parseFloat(el.dataset.pct);
    var tall = el.dataset.tall === '1';
    var html = '';
    for (var i = 0; i < 70; i++) {
      var j = Math.abs(Math.sin(i * 12.9898 + (tall ? 78.233 : 43.758))) * 0.6 + 0.4;
      html += '<span style="height:' + (pct * j).toFixed(1) + '%"></span>';
    }
    el.innerHTML = html;
  });

  /* ── Gallery ── */
  var slides = document.querySelectorAll('.pdp-gallery__slide');
  var thumbs = document.querySelectorAll('.pdp-gallery__thumb');
  var curEl = document.getElementById('pdp-cur');
  var total = slides.length;
  var idx = 0;

  function goTo(n) {
    if (total === 0) return;
    slides[idx].classList.add('pdp-gallery__slide--off');
    thumbs[idx].classList.remove('pdp-gallery__thumb--on');
    thumbs[idx].setAttribute('aria-selected', 'false');
    idx = (n + total) % total;
    slides[idx].classList.remove('pdp-gallery__slide--off');
    thumbs[idx].classList.add('pdp-gallery__thumb--on');
    thumbs[idx].setAttribute('aria-selected', 'true');
    if (curEl) curEl.textContent = String(idx + 1).padStart(2, '0');
  }

  thumbs.forEach(function(btn, i) {
    btn.addEventListener('click', function() { goTo(i); });
  });
  var prev = document.getElementById('pdp-prev');
  var next = document.getElementById('pdp-next');
  if (prev) prev.addEventListener('click', function() { goTo(idx - 1); });
  if (next) next.addEventListener('click', function() { goTo(idx + 1); });

  /* ── Pack selector ── */
  /* ── Pack selector ── */
  var packBtns = document.querySelectorAll('.pdp-pack-btn');
  var variantInput = document.getElementById('pdp-variant-input');
  var priceEl = document.getElementById('pdp-price');
  var perTowelEl = document.getElementById('pdp-per-towel');
  var atcBtn = document.getElementById('pdp-atc');
  var satbPrice = document.getElementById('pdp-satb-price');

  packBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      packBtns.forEach(function(b) { b.classList.remove('pdp-pack-btn--on'); });
      btn.classList.add('pdp-pack-btn--on');
      var price = btn.dataset.price;
      var per = btn.dataset.per;
      if (variantInput) variantInput.value = btn.dataset.variant;
      if (priceEl) priceEl.textContent = '$' + price;
      if (perTowelEl) perTowelEl.textContent = '$' + per + ' / towel';
      if (atcBtn) atcBtn.textContent = 'Add to bag — $' + price;
      if (satbPrice) satbPrice.textContent = '$' + price + ' · Free shipping';
    });
  });

  /* ── Qty ── */
  var qval = document.getElementById('pdp-qval');
  var qinput = document.getElementById('pdp-qinput');
  var qty = 1;

  function setQty(n) {
    qty = Math.max(1, n);
    if (qval) qval.textContent = qty;
    if (qinput) qinput.value = qty;
  }

  var qdec = document.getElementById('pdp-qdec');
  var qinc = document.getElementById('pdp-qinc');
  if (qdec) qdec.addEventListener('click', function() { setQty(qty - 1); });
  if (qinc) qinc.addEventListener('click', function() { setQty(qty + 1); });

  /* ── Add to cart: AJAX into drawer, native submit as fallback ── */
  var atc = document.getElementById('pdp-atc');
  var form = document.getElementById('pdp-form');
  if (form && atc) {
    form.addEventListener('submit', function(e) {
      var variantInput = document.getElementById('pdp-variant-input');
      var variantId = variantInput ? variantInput.value : null;
      var qInput = document.getElementById('pdp-qinput');
      var quantity = qInput ? parseInt(qInput.value, 10) || 1 : 1;
      if (!window.PolarisCart || !variantId) return;
      e.preventDefault();
      var orig = atc.textContent;
      atc.disabled = true;
      window.PolarisCart.addToCart(variantId, quantity).then(function() {
        atc.disabled = false;
        atc.textContent = '✓ Added to bag';
        atc.style.background = '#fff';
        atc.style.color = '#000';
        setTimeout(function() {
          atc.textContent = orig;
          atc.style.background = '';
          atc.style.color = '';
        }, 1800);
      }).catch(function() {
        atc.disabled = false;
        atc.textContent = orig;
        form.submit();
      });
    });
  }

  /* ── FAQ accordion ── */
  document.querySelectorAll('.pdp-faq__btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.pdp-faq__item');
      var isOpen = item.classList.contains('pdp-faq__item--open');
      document.querySelectorAll('.pdp-faq__item--open').forEach(function(o) {
        o.classList.remove('pdp-faq__item--open');
        o.querySelector('.pdp-faq__btn').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('pdp-faq__item--open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  /* ── Reviews clone for seamless loop (desktop only) ── */
  var revTrack = document.getElementById('pdp-rev-track');
  if (revTrack && window.innerWidth > 699) {
    var origCards = Array.from(revTrack.children);
    origCards.forEach(function(card) {
      revTrack.appendChild(card.cloneNode(true));
    });
  }

  /* ── Reviews mobile auto-scroll (3 s per card) ── */
  if (window.innerWidth <= 699) {
    var revWrap = document.querySelector('.pdp-rev-wrap');
    var revCards = revWrap ? revWrap.querySelectorAll('.pdp-rev-card') : [];
    if (revWrap && revCards.length) {
      var revIdx = 0;
      var revTimer;
      function revNext() {
        revIdx = (revIdx + 1) % revCards.length;
        revWrap.scrollTo({ left: revCards[revIdx].offsetLeft, behavior: 'smooth' });
      }
      function revStart() { revTimer = setInterval(revNext, 3000); }
      function revStop() { clearInterval(revTimer); }
      revStart();
      revWrap.addEventListener('touchstart', revStop, { passive: true });
      revWrap.addEventListener('touchend', function() {
        setTimeout(function() {
          var mid = revWrap.scrollLeft + revWrap.offsetWidth / 2;
          for (var i = 0; i < revCards.length; i++) {
            if (revCards[i].offsetLeft + revCards[i].offsetWidth >= mid) { revIdx = i; break; }
          }
          revStart();
        }, 600);
      }, { passive: true });
    }
  }

  /* ── UGC infinite marquee ── */
  (function() {
    var outer = document.querySelector('.pdp-ugc-outer');
    var track = document.querySelector('.pdp-ugc');
    if (!outer || !track) return;
    var origTiles = Array.from(track.querySelectorAll('.pdp-ugc__tile'));
    if (!origTiles.length) return;
    // Clone until track fills at least 3× outer width
    while (track.scrollWidth < outer.offsetWidth * 3) {
      origTiles.forEach(function(t) {
        var c = t.cloneNode(true);
        c.setAttribute('aria-hidden', 'true');
        track.appendChild(c);
      });
    }
    // One "set" = n tiles × (tileW + gap)
    var setW = origTiles.length * (origTiles[0].offsetWidth + 2);
    var pos = 0;
    function step() {
      pos -= 0.5;
      if (pos <= -setW) pos += setW;
      track.style.transform = 'translateX(' + pos + 'px)';
      track.style.webkitTransform = 'translateX(' + pos + 'px)';
      requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  })();

  /* ── Sticky ATB ── */
  var satb = document.getElementById('pdp-satb');
  var hero = document.getElementById('pdp-hero');
  if (satb && hero) {
    var obs = new IntersectionObserver(function(entries) {
      satb.classList.toggle('pdp-satb--on', !entries[0].isIntersecting);
    }, { rootMargin: '-200px 0px 0px 0px' });
    obs.observe(hero);
  }

  /* ── Scroll reveal ── */
  var reveals = document.querySelectorAll('.pdp-reveal');
  if ('IntersectionObserver' in window) {
    var revObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) { e.target.classList.add('pdp-reveal--in'); revObs.unobserve(e.target); }
      });
    }, { threshold: 0.08 });
    reveals.forEach(function(el) { revObs.observe(el); });
  } else {
    reveals.forEach(function(el) { el.classList.add('pdp-reveal--in'); });
  }
})();
</script>

