<style>
  .bts-section {
    background: #000;
    font-family: 'DM Sans', sans-serif;
  }

  /* ── Single-row layout: text left, images right ── */
  .bts-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .bts-text {
    padding: 72px 60px;
    border-right: 1px solid rgba(255,255,255,0.06);
  }

  @media (max-width: 900px) {
    .bts-inner { grid-template-columns: 1fr; }
    .bts-text { padding: 56px 28px; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }
  }

  .bts-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 20px;
  }

  .bts-headline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    text-transform: uppercase;
    line-height: 0.93;
    letter-spacing: 0.01em;
    color: #fff;
    margin-bottom: 24px;
  }

  .bts-rule {
    width: 32px;
    height: 2px;
    background: rgba(255,255,255,0.15);
    margin-bottom: 20px;
  }

  .bts-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.5);
    max-width: 380px;
  }

  /* ── Image grid — right side ── */
  .bts-photos {
    display: grid;
    gap: 2px;
    background: rgba(255,255,255,0.04);
  }

  .bts-photos--2 { grid-template-columns: repeat(2, 1fr); }
  .bts-photos--3 { grid-template-columns: repeat(3, 1fr); }
  .bts-photos--4 { grid-template-columns: repeat(2, 1fr); }

  .bts-photo {
    position: relative;
    overflow: hidden;
    background: #0a0a0a;
  }

  .bts-photo img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    transition: transform 600ms ease;
  }

  .bts-photo:hover img { transform: scale(1.04); }

  .bts-photo-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 16px 16px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    opacity: 0;
    transition: opacity 300ms;
  }

  .bts-photo:hover .bts-photo-caption { opacity: 1; }

  .bts-placeholder {
    aspect-ratio: 1 / 1;
    background: #0d0d0d;
    border: 1px dashed rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: rgba(255,255,255,0.15);
  }

  .bts-placeholder svg {
    width: 28px; height: 28px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1;
  }

  .bts-placeholder span {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=Barlow:wght@300&family=DM+Sans:wght@400;700&display=swap" rel="stylesheet">

<section class="bts-section fade-in">
  <div class="bts-inner">

    <div class="bts-text">
      <p class="bts-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="bts-headline">{{ section.settings.headline }}</h2>
      <div class="bts-rule"></div>
      <p class="bts-body">{{ section.settings.body }}</p>
    </div>

    {% assign photo_count = section.blocks | size %}
    {% if photo_count > 0 %}
      {% if photo_count <= 2 %}
        {% assign grid_class = 'bts-photos--2' %}
      {% elsif photo_count == 3 %}
        {% assign grid_class = 'bts-photos--3' %}
      {% else %}
        {% assign grid_class = 'bts-photos--4' %}
      {% endif %}

      <div class="bts-photos {{ grid_class }}">
        {% for block in section.blocks %}
          <div class="bts-photo" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.caption | default: 'Behind the scenes' }}"
                loading="lazy"
                width="600"
              >
              {% if block.settings.caption != blank %}
                <div class="bts-photo-caption">{{ block.settings.caption }}</div>
              {% endif %}
            {% else %}
              <div class="bts-placeholder">
                <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                <span>Add photo</span>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "BTS Gallery",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Behind the build"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Built in Chicago.\nNot a boardroom."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Polaris started with two guys who couldn't find detailing products they actually trusted. So they built their own. Every product is tested on real cars before it ever reaches yours."
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (shows on hover)",
          "default": "Behind the scenes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BTS Gallery"
    }
  ]
}
{% endschema %}
