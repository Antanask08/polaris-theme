<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@300;400&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<style>
  .bv-section {
    background: #000;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
  }

  /* ── Single-row: heading right, pillars left ── */
  .bv-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  @media (max-width: 900px) {
    .bv-inner { grid-template-columns: 1fr; }
  }

  /* ── Left: pillars ── */
  .bv-pillars {
    border-right: 1px solid rgba(255,255,255,0.06);
  }

  @media (max-width: 900px) {
    .bv-pillars {
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
  }

  .bv-pillar {
    padding: 36px 52px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .bv-pillar:last-child { border-bottom: none; }

  @media (max-width: 900px) {
    .bv-pillar { padding: 32px 28px; }
  }

  .bv-pillar-num {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.18);
    margin-bottom: 10px;
  }

  .bv-pillar-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #fff;
    margin-bottom: 10px;
    letter-spacing: 0.01em;
  }

  .bv-pillar-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.45);
  }

  /* ── Right: heading + body ── */
  .bv-manifesto {
    padding: 56px 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .bv-manifesto { padding: 48px 28px; }
  }

  .bv-eyebrow {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 20px;
  }

  .bv-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.8rem, 4.5vw, 4.5rem);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: #fff;
    margin-bottom: 24px;
  }

  .bv-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.85;
    color: rgba(255,255,255,0.5);
    max-width: 360px;
  }
</style>

<section class="bv-section fade-in">
  <div class="bv-inner">

    {% if section.blocks.size > 0 %}
      <div class="bv-pillars">
        {% for block in section.blocks %}
          {% if block.type == 'pillar' %}
            <div class="bv-pillar" {{ block.shopify_attributes }}>
              <span class="bv-pillar-num">0{{ forloop.index }}</span>
              <h3 class="bv-pillar-title">{{ block.settings.title }}</h3>
              <p class="bv-pillar-body">{{ block.settings.body }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="bv-manifesto">
      {% if section.settings.eyebrow != blank %}
        <span class="bv-eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="bv-heading">{{ section.settings.heading }}</h2>
      <p class="bv-body">{{ section.settings.body }}</p>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Brand Values",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "What We Stand For"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Manifesto heading",
      "default": "Not just a brand. A standard."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Manifesto body",
      "default": "We started Polaris because the car community deserved better. Better quality, honest pricing, and a brand that actually gives a damn about the people buying from it."
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Value Pillar",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Pillar title",
          "default": "Community First"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Pillar body",
          "default": "We started in the car scene, not a boardroom. Everything we build starts with what the community actually needs."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Values",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Community First",
            "body": "We started in the car scene, not a boardroom. Everything we build starts with what the community actually needs."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Tested on Ours",
            "body": "Every product goes on our own cars before it goes on yours. If it doesn't pass that test, it doesn't ship."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Priced Honestly",
            "body": "We price from what's fair, not what the market will tolerate. Quality shouldn't require a justification."
          }
        }
      ]
    }
  ]
}
{% endschema %}
