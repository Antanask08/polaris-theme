<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@300;400&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<style>
  .bv-section {
    background: #000;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
  }

  /* ── Top: manifesto ───────────────────────────── */
  .bv-manifesto {
    padding: 96px 60px 80px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
  }

  @media (max-width: 900px) {
    .bv-manifesto {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 64px 28px 56px;
    }
  }

  .bv-eyebrow {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 20px;
  }

  .bv-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 5.5rem);
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: #fff;
  }

  .bv-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(255,255,255,0.55);
    max-width: 400px;
  }

  /* ── Bottom: pillars ──────────────────────────── */
  .bv-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 900px) {
    .bv-pillars { grid-template-columns: 1fr; }
  }

  .bv-pillar {
    padding: 56px 52px 64px;
    border-right: 1px solid rgba(255,255,255,0.06);
    position: relative;
  }

  .bv-pillar:last-child { border-right: none; }

  @media (max-width: 900px) {
    .bv-pillar {
      padding: 40px 28px;
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .bv-pillar:last-child { border-bottom: none; }
  }

  .bv-pillar-num {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.18);
    margin-bottom: 32px;
  }

  .bv-pillar-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(1.8rem, 2.8vw, 2.5rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #fff;
    margin-bottom: 18px;
    letter-spacing: 0.01em;
  }

  .bv-pillar-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.5);
  }
</style>

<section class="bv-section fade-in">

  <div class="bv-manifesto">
    <div>
      {% if section.settings.eyebrow != blank %}
        <span class="bv-eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      <h2 class="bv-heading">{{ section.settings.heading }}</h2>
    </div>
    <div>
      <p class="bv-body">{{ section.settings.body }}</p>
    </div>
  </div>

  {% if section.blocks.size > 0 %}
    <div class="bv-pillars">
      {% for block in section.blocks %}
        {% if block.type == 'pillar' %}
          <div class="bv-pillar" {{ block.shopify_attributes }}>
            <span class="bv-pillar-num">0{{ forloop.index }}</span>
            <h3 class="bv-pillar-title">{{ block.settings.title }}</h3>
            <p class="bv-pillar-body">{{ block.settings.body }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

</section>

{% schema %}
{
  "name": "Brand Values",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "What We Stand For"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Manifesto heading",
      "default": "Not just a brand. A standard."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Manifesto body",
      "default": "We started Polaris because the car community deserved better. Better quality, honest pricing, and a brand that actually gives a damn about the people buying from it."
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Value Pillar",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Pillar title",
          "default": "Community First"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Pillar body",
          "default": "We started in the car scene, not a boardroom. Everything we build starts with what the community actually needs."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Values",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Community First",
            "body": "We started in the car scene, not a boardroom. Everything we build starts with what the community actually needs."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Tested on Ours",
            "body": "Every product goes on our own cars before it goes on yours. If it doesn't pass that test, it doesn't ship."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Priced Honestly",
            "body": "We price from what's fair, not what the market will tolerate. Quality shouldn't require a justification."
          }
        }
      ]
    }
  ]
}
{% endschema %}
