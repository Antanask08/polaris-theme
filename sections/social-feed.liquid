<style>
.social-feed {
  background: #fff;
  padding: 96px 0;
}

.social-feed .section-header {
  text-align: center;
  margin-bottom: 16px;
}

.social-feed-subtext {
  text-align: center;
  margin-bottom: 64px;
  opacity: 0.6;
  font-size: 14px;
  color: #000;
}

.social-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 48px;
}

.social-slot {
  position: relative;
}

.social-embed-wrap {
  overflow: hidden;
  aspect-ratio: 9 / 16;
}

.social-embed-wrap iframe {
  width: 100%;
  height: 100%;
  border: none;
}

.social-placeholder {
  aspect-ratio: 9 / 16;
  background: #f5f5f5;
  border: 1px solid rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  letter-spacing: 0.1em;
  color: rgba(0, 0, 0, 0.3);
}

.social-ctas {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

@media (max-width: 768px) {
  .social-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>

<section class="social-feed section--white fade-in">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.heading }}</h2>
      <p class="social-feed-subtext">{{ section.settings.subtext }}</p>
    </div>
    <div class="social-grid">
      {% for block in section.blocks %}
        {% if block.type == 'embed' %}
          <div class="social-slot" {{ block.shopify_attributes }}>
            {% if block.settings.embed_code != blank %}
              <div class="social-embed-wrap">{{ block.settings.embed_code }}</div>
            {% else %}
              <div class="social-placeholder">
                <span>@polariscarcare</span>
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="social-ctas">
      {% if section.settings.tiktok_url != blank %}
        <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" class="btn btn--primary">{{ section.settings.tiktok_label }}</a>
      {% endif %}
      {% if section.settings.instagram_url != blank %}
        <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" class="btn btn--secondary">{{ section.settings.instagram_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Feed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "@POLARISCARCARE"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Follow along on TikTok and Instagram"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok profile URL"
    },
    {
      "type": "text",
      "id": "tiktok_label",
      "label": "TikTok button label",
      "default": "FOLLOW US ON TIKTOK \u2197"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram profile URL"
    },
    {
      "type": "text",
      "id": "instagram_label",
      "label": "Instagram button label",
      "default": "FOLLOW ON INSTAGRAM \u2197"
    }
  ],
  "blocks": [
    {
      "type": "embed",
      "name": "Social Post",
      "limit": 6,
      "settings": [
        {
          "type": "textarea",
          "id": "embed_code",
          "label": "Embed code (TikTok or Instagram)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Feed"
    }
  ]
}
{% endschema %}
