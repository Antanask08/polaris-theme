<style>
  .sf-section {
    background: #fff;
    padding: 96px 48px;
    font-family: 'DM Sans', sans-serif;
  }

  @media (max-width: 640px) { .sf-section { padding: 64px 24px; } }

  .sf-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    flex-wrap: wrap;
  }

  .sf-left {}

  .sf-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 16px;
  }

  .sf-headline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #000;
    margin-bottom: 20px;
  }

  .sf-sub {
    font-size: 15px;
    color: #555;
    line-height: 1.6;
    max-width: 380px;
  }

  .sf-right {
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex-shrink: 0;
  }

  .sf-cta {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 28px;
    border: 1.5px solid #000;
    text-decoration: none;
    color: #000;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: background 200ms, color 200ms;
    min-width: 280px;
  }

  .sf-cta:hover {
    background: #000;
    color: #fff;
  }

  .sf-cta svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .sf-cta-arrow {
    margin-left: auto;
    font-size: 14px;
  }

  @media (max-width: 640px) {
    .sf-inner { flex-direction: column; }
    .sf-right { width: 100%; }
    .sf-cta { min-width: unset; width: 100%; }
  }
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">

<section class="sf-section fade-in">
  <div class="sf-inner">
    <div class="sf-left">
      <p class="sf-eyebrow">Follow along</p>
      <h2 class="sf-headline">{{ section.settings.heading }}</h2>
      <p class="sf-sub">{{ section.settings.subtext }}</p>
    </div>
    <div class="sf-right">
      {% if section.settings.tiktok_url != blank %}
        <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" class="sf-cta">
          <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
          {{ section.settings.tiktok_label }}
          <span class="sf-cta-arrow">↗</span>
        </a>
      {% endif %}
      {% if section.settings.instagram_url != blank %}
        <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" class="sf-cta">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          {{ section.settings.instagram_label }}
          <span class="sf-cta-arrow">↗</span>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Feed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "@POLARISCARCARE"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Body text",
      "default": "See the Nova in action. Real cars, real results. Follow us for tips, drops, and behind-the-scenes content."
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok profile URL"
    },
    {
      "type": "text",
      "id": "tiktok_label",
      "label": "TikTok button label",
      "default": "FOLLOW US ON TIKTOK"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram profile URL"
    },
    {
      "type": "text",
      "id": "instagram_label",
      "label": "Instagram button label",
      "default": "FOLLOW ON INSTAGRAM"
    }
  ],
  "presets": [
    {
      "name": "Social Feed"
    }
  ]
}
{% endschema %}
