<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">
  <link rel="canonical" href="{{ canonical_url }}">

  {% if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=Barlow:wght@300;400&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      min-height: 100%;
      background: #000;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
    }

    .pw-page {
      min-height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      padding: 0 48px;
    }

    @media (max-width: 640px) { .pw-page { padding: 0 24px; } }

    .pw-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 32px 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .pw-logo {
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #fff;
      text-decoration: none;
    }

    .pw-logo img { height: 30px; width: auto; }

    .pw-badge {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      border: 1px solid rgba(255,255,255,0.12);
      padding: 6px 14px;
    }

    .pw-main {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      padding: 80px 0;
    }

    @media (max-width: 900px) {
      .pw-main { grid-template-columns: 1fr; gap: 48px; padding: 56px 0; }
    }

    .pw-eyebrow {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 24px;
    }

    .pw-headline {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(4rem, 9vw, 8rem);
      text-transform: uppercase;
      letter-spacing: 0.01em;
      line-height: 0.93;
      color: #fff;
      margin-bottom: 32px;
    }

    .pw-rule { width: 40px; height: 2px; background: #fff; margin-bottom: 28px; }

    .pw-sub {
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      font-size: 1.05rem;
      line-height: 1.75;
      color: rgba(255,255,255,0.55);
      max-width: 400px;
    }

    .pw-right {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    .pw-field-label {
      display: block;
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 10px;
    }

    .pw-input-row {
      display: flex;
      border: 1px solid rgba(255,255,255,0.2);
    }

    .pw-input-row:focus-within { border-color: rgba(255,255,255,0.5); }

    .pw-input {
      flex: 1;
      min-width: 0;
      background: transparent;
      border: none;
      outline: none;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      padding: 15px 18px;
    }

    .pw-input::placeholder {
      color: rgba(255,255,255,0.2);
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .pw-btn {
      background: #fff;
      color: #000;
      border: none;
      padding: 15px 22px;
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      flex-shrink: 0;
    }

    .pw-fine {
      margin-top: 10px;
      font-size: 11px;
      color: rgba(255,255,255,0.2);
    }

    .pw-success {
      margin-top: 10px;
      font-size: 11px;
      color: rgba(255,255,255,0.6);
      display: none;
    }

    .pw-or {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.2);
    }
    .pw-or::before, .pw-or::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.1); }

    .pw-password-form {
      display: flex;
      border: 1px solid rgba(255,255,255,0.2);
      align-items: stretch;
    }

    .pw-password-form:focus-within { border-color: rgba(255,255,255,0.5); }

    .pw-password-input {
      flex: 1;
      min-width: 0;
      background: transparent;
      border: none;
      outline: none;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      padding: 15px 18px;
    }

    .pw-password-input::placeholder {
      color: rgba(255,255,255,0.2);
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .pw-password-submit {
      background: #fff;
      color: #000;
      border: none;
      padding: 15px 22px;
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      flex-shrink: 0;
    }

    .pw-bottom {
      padding: 24px 0;
      border-top: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .pw-copy { font-size: 11px; color: rgba(255,255,255,0.2); }

    .pw-socials { display: flex; gap: 18px; align-items: center; }

    .pw-social { color: rgba(255,255,255,0.35); text-decoration: none; display: flex; transition: color 200ms; }
    .pw-social:hover { color: #fff; }
    .pw-social svg { width: 18px; height: 18px; fill: currentColor; }
  </style>
</head>

<body>
  <div class="pw-page">

    <div class="pw-top">
      <a href="/" class="pw-logo">
        {% if settings.logo != blank %}
          <img src="{{ settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}">
        {% else %}
          POLARIS CAR CARE
        {% endif %}
      </a>
      <span class="pw-badge">Coming Soon</span>
    </div>

    <div class="pw-main">

      <div>
        <p class="pw-eyebrow">Polaris Car Care &mdash; Chicago, Illinois</p>
        <h1 class="pw-headline">Built<br>for the<br>ones<br>who care.</h1>
        <div class="pw-rule"></div>
        <p class="pw-sub">Premium detailing tools for the car community. Something big is coming &mdash; be the first to know.</p>
      </div>

      <div class="pw-right">

        <!-- Email capture -->
        <div>
          <span class="pw-field-label">Get early access + 10% off</span>
          <input type="hidden" id="pw-auth-token" value="{{ form_authenticity_token }}">
          <div class="pw-input-row" id="pw-email-row">
            <input class="pw-input" type="email" id="pw-email-input" placeholder="Your email address" autocomplete="email">
            <button class="pw-btn" id="pw-email-btn" type="button">Notify Me</button>
          </div>
          <p class="pw-fine" id="pw-fine">No spam. Unsubscribe anytime.</p>
          <p class="pw-success" id="pw-success">You're on the list. We'll be in touch soon.</p>
        </div>

        <div class="pw-or">or enter with password</div>

        <!-- Store password form -->
        <div>
          <span class="pw-field-label">Store password</span>
          {% form 'storefront_password', class: 'pw-password-form' %}
            {{ form.errors | default_errors }}
            <input
              type="password"
              name="password"
              class="pw-password-input"
              placeholder="Password"
              autocomplete="current-password"
            >
            <button type="submit" class="pw-password-submit">Enter</button>
          {% endform %}
        </div>

      </div>
    </div>

    <div class="pw-bottom">
      <p class="pw-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="pw-socials">
        {% if settings.tiktok_url != blank %}
          <a href="{{ settings.tiktok_url }}" target="_blank" rel="noopener" class="pw-social" aria-label="TikTok">
            <svg viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
          </a>
        {% endif %}
        {% if settings.instagram_url != blank %}
          <a href="{{ settings.instagram_url }}" target="_blank" rel="noopener" class="pw-social" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

  </div>

  <script>
    document.getElementById('pw-email-btn').addEventListener('click', function() {
      var email = document.getElementById('pw-email-input').value.trim();
      if (!email || !email.includes('@')) return;

      var btn = this;
      btn.textContent = '...';
      btn.disabled = true;

      var data = new URLSearchParams();
      data.append('form_type', 'customer');
      data.append('utf8', '✓');
      data.append('authenticity_token', document.getElementById('pw-auth-token').value);
      data.append('customer[email]', email);
      data.append('customer[tags]', 'newsletter,password-page');

      fetch('/contact#contact_form', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: data.toString()
      }).then(function() {
        document.getElementById('pw-email-row').style.opacity = '0.3';
        document.getElementById('pw-fine').style.display = 'none';
        document.getElementById('pw-success').style.display = 'block';
      }).catch(function() {
        btn.textContent = 'Notify Me';
        btn.disabled = false;
      });
    });
  </script>
</body>
</html>
