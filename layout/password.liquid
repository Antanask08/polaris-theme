<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  <meta name="description" content="{{ shop.description }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=Barlow:wght@300;400&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">

  {% if settings.favicon != blank %}
    <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32 }}" type="image/png">
  {% endif %}

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: #000;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      overflow: hidden;
    }

    /* ── Background ── */
    .pw-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
    }

    .pw-bg-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.18;
    }

    .pw-bg-gradient {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(0,0,0,0.3) 0%,
        rgba(0,0,0,0.55) 50%,
        rgba(0,0,0,0.85) 100%
      );
    }

    /* ── Layout ── */
    .pw-page {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      padding: 0 24px;
    }

    /* ── Top bar ── */
    .pw-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 32px 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .pw-logo {
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 15px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #fff;
      text-decoration: none;
    }

    .pw-logo img {
      height: 32px;
      width: auto;
    }

    .pw-badge {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      border: 1px solid rgba(255,255,255,0.15);
      padding: 6px 14px;
    }

    /* ── Center content ── */
    .pw-center {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      max-width: 720px;
      padding: 80px 0;
    }

    .pw-eyebrow {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 28px;
    }

    .pw-headline {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(3.5rem, 10vw, 8rem);
      text-transform: uppercase;
      letter-spacing: 0.02em;
      line-height: 0.95;
      color: #fff;
      margin-bottom: 32px;
    }

    .pw-headline span {
      display: block;
    }

    .pw-divider {
      width: 48px;
      height: 2px;
      background: #fff;
      margin-bottom: 32px;
    }

    .pw-subhead {
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      font-size: clamp(1rem, 1.8vw, 1.2rem);
      line-height: 1.7;
      color: rgba(255,255,255,0.6);
      max-width: 520px;
      margin-bottom: 48px;
    }

    /* ── Email form ── */
    .pw-form-label {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 12px;
      display: block;
    }

    .pw-form-row {
      display: flex;
      width: 100%;
      max-width: 480px;
      border: 1px solid rgba(255,255,255,0.25);
    }

    .pw-form-row:focus-within {
      border-color: rgba(255,255,255,0.6);
    }

    .pw-input {
      flex: 1;
      background: transparent;
      border: none;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      letter-spacing: 0.05em;
      padding: 15px 18px;
      outline: none;
      min-width: 0;
    }

    .pw-input::placeholder {
      color: rgba(255,255,255,0.25);
      text-transform: uppercase;
      font-size: 11px;
      letter-spacing: 0.15em;
    }

    .pw-submit {
      background: #fff;
      color: #000;
      border: none;
      padding: 15px 24px;
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      white-space: nowrap;
      transition: background 150ms ease;
      flex-shrink: 0;
    }

    .pw-submit:hover {
      background: rgba(255,255,255,0.88);
    }

    .pw-fine-print {
      margin-top: 14px;
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      letter-spacing: 0.05em;
      color: rgba(255,255,255,0.25);
    }

    /* ── Bottom bar ── */
    .pw-bottom {
      padding: 28px 0;
      border-top: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .pw-copyright {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.25);
    }

    .pw-socials {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .pw-social-link {
      color: rgba(255,255,255,0.4);
      text-decoration: none;
      transition: color 200ms;
      display: flex;
      align-items: center;
    }

    .pw-social-link:hover {
      color: #fff;
    }

    .pw-social-link svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }

    /* ── Decorative line ── */
    .pw-deco-line {
      position: fixed;
      top: 0;
      right: 80px;
      width: 1px;
      height: 100vh;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.06) 30%, rgba(255,255,255,0.06) 70%, transparent);
      pointer-events: none;
      z-index: 0;
    }

    @media (max-width: 640px) {
      .pw-center {
        padding: 60px 0;
      }
      .pw-badge { display: none; }
      .pw-deco-line { display: none; }
      .pw-bottom {
        flex-direction: column-reverse;
        align-items: flex-start;
        gap: 12px;
      }
    }
  </style>
</head>
<body>

  <!-- Decorative vertical line -->
  <div class="pw-deco-line"></div>

  <!-- Background image placeholder (dark overlay) -->
  <div class="pw-bg">
    {% if settings.logo != blank %}
      <!-- background handled via overlay -->
    {% endif %}
    <div class="pw-bg-gradient"></div>
  </div>

  <div class="pw-page">

    <!-- Top bar -->
    <div class="pw-topbar">
      <a href="/" class="pw-logo">
        {% if settings.logo != blank %}
          <img src="{{ settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}">
        {% else %}
          POLARIS CAR CARE
        {% endif %}
      </a>
      <span class="pw-badge">Coming Soon</span>
    </div>

    <!-- Center -->
    <div class="pw-center">
      <p class="pw-eyebrow">Polaris Car Care — Chicago, Illinois</p>
      <h1 class="pw-headline">
        <span>Built for</span>
        <span>the ones</span>
        <span>who care.</span>
      </h1>
      <div class="pw-divider"></div>
      <p class="pw-subhead">Premium detailing tools for the car community. Be the first to know when we launch — get 10% off your first order.</p>

      {{ content_for_layout }}

      {% unless content_for_layout contains 'form' %}
        <span class="pw-form-label">Get early access</span>
        <div class="pw-form-row">
          <input class="pw-input" type="email" placeholder="Your email address" autocomplete="email">
          <button class="pw-submit" type="button">Notify Me</button>
        </div>
        <p class="pw-fine-print">No spam. Ever.</p>
      {% endunless %}
    </div>

    <!-- Bottom bar -->
    <div class="pw-bottom">
      <p class="pw-copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="pw-socials">
        {% if settings.tiktok_url != blank %}
          <a href="{{ settings.tiktok_url }}" target="_blank" rel="noopener" class="pw-social-link" aria-label="TikTok">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
            </svg>
          </a>
        {% endif %}
        {% if settings.instagram_url != blank %}
          <a href="{{ settings.instagram_url }}" target="_blank" rel="noopener" class="pw-social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>

  </div>

</body>
</html>
