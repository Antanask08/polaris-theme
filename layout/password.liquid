<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=Barlow:wght@300;400&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">

  {% if settings.favicon != blank %}
    <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32 }}" type="image/png">
  {% endif %}

  {{ content_for_header }} 

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: #000 !important;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
    }

    /* ── Kill Shopify defaults ── */
    body > .shopify-section,
    #shopify-section-password-header,
    .password-page,
    .password-login {
      all: unset !important;
      display: block !important;
    }

    /* Shopify wraps content_for_layout in a div with inline styles — override */
    body > div[style] {
      background: none !important;
      min-height: unset !important;
    }

    /* ── Layout shell ── */
    .pw-shell {
      min-height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      padding: 0 40px;
      position: relative;
    }

    @media (max-width: 640px) {
      .pw-shell { padding: 0 24px; }
    }

    /* ── Vertical deco line ── */
    .pw-shell::before {
      content: '';
      position: fixed;
      top: 0;
      right: 100px;
      width: 1px;
      height: 100vh;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.06) 30%, rgba(255,255,255,0.06) 70%, transparent);
      pointer-events: none;
    }

    /* ── Top bar ── */
    .pw-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 32px 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .pw-logo {
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #fff;
      text-decoration: none;
    }

    .pw-logo img { height: 30px; width: auto; }

    .pw-tag {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      border: 1px solid rgba(255,255,255,0.12);
      padding: 6px 14px;
    }

    /* ── Main content ── */
    .pw-main {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      padding: 80px 0;
    }

    @media (max-width: 900px) {
      .pw-main {
        grid-template-columns: 1fr;
        gap: 56px;
        padding: 56px 0;
      }
    }

    /* ── Left: headline ── */
    .pw-left {}

    .pw-eyebrow {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 24px;
    }

    .pw-headline {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(4rem, 9vw, 8rem);
      text-transform: uppercase;
      letter-spacing: 0.01em;
      line-height: 0.93;
      color: #fff;
      margin-bottom: 32px;
    }

    .pw-rule {
      width: 40px;
      height: 2px;
      background: #fff;
      margin-bottom: 28px;
    }

    .pw-sub {
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      font-size: 1.05rem;
      line-height: 1.75;
      color: rgba(255,255,255,0.55);
      max-width: 400px;
    }

    /* ── Right: forms ── */
    .pw-right {
      display: flex;
      flex-direction: column;
      gap: 40px;
    }

    /* ── Email signup form ── */
    .pw-signup-label {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 12px;
      display: block;
    }

    .pw-email-row {
      display: flex;
      border: 1px solid rgba(255,255,255,0.2);
      transition: border-color 200ms;
    }

    .pw-email-row:focus-within {
      border-color: rgba(255,255,255,0.55);
    }

    .pw-email-input {
      flex: 1;
      min-width: 0;
      background: transparent;
      border: none;
      outline: none;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      padding: 15px 18px;
      letter-spacing: 0.04em;
    }

    .pw-email-input::placeholder {
      color: rgba(255,255,255,0.22);
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
    }

    .pw-email-btn {
      background: #fff;
      color: #000;
      border: none;
      padding: 15px 22px;
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      flex-shrink: 0;
      transition: background 150ms;
    }

    .pw-email-btn:hover { background: rgba(255,255,255,0.88); }

    .pw-fine {
      margin-top: 10px;
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      color: rgba(255,255,255,0.2);
      letter-spacing: 0.04em;
    }

    /* ── Divider ── */
    .pw-or {
      display: flex;
      align-items: center;
      gap: 16px;
      color: rgba(255,255,255,0.2);
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }
    .pw-or::before,
    .pw-or::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(255,255,255,0.1);
    }

    /* ── Shopify password form — restyle completely ── */
    #login_form,
    .pw-password-form form,
    form[action="/password"] {
      display: flex !important;
      flex-direction: column !important;
      gap: 0 !important;
      background: none !important;
      border: none !important;
      padding: 0 !important;
      box-shadow: none !important;
      border-radius: 0 !important;
    }

    .pw-password-label {
      font-family: 'DM Sans', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 12px;
      display: block;
    }

    /* Shopify's label inside the password form */
    #login_form label,
    form[action="/password"] label,
    .pw-password-form label {
      font-family: 'DM Sans', sans-serif !important;
      font-size: 10px !important;
      font-weight: 700 !important;
      letter-spacing: 0.25em !important;
      text-transform: uppercase !important;
      color: rgba(255,255,255,0.35) !important;
      margin-bottom: 12px !important;
      display: block !important;
      background: none !important;
    }

    /* Password input row */
    #login_form .input-group,
    form[action="/password"] .input-group,
    .pw-password-form .input-group {
      display: flex !important;
      border: 1px solid rgba(255,255,255,0.2) !important;
      background: none !important;
    }

    #login_form input[type="password"],
    form[action="/password"] input[type="password"],
    .pw-password-form input[type="password"] {
      flex: 1 !important;
      min-width: 0 !important;
      background: transparent !important;
      border: none !important;
      outline: none !important;
      color: #fff !important;
      font-family: 'DM Sans', sans-serif !important;
      font-size: 13px !important;
      padding: 15px 18px !important;
      border-radius: 0 !important;
      box-shadow: none !important;
    }

    #login_form input[type="submit"],
    #login_form button[type="submit"],
    form[action="/password"] input[type="submit"],
    form[action="/password"] button[type="submit"],
    .pw-password-form input[type="submit"],
    .pw-password-form button[type="submit"] {
      background: #fff !important;
      color: #000 !important;
      border: none !important;
      padding: 15px 22px !important;
      font-family: 'DM Sans', sans-serif !important;
      font-weight: 700 !important;
      font-size: 11px !important;
      letter-spacing: 0.15em !important;
      text-transform: uppercase !important;
      cursor: pointer !important;
      border-radius: 0 !important;
      box-shadow: none !important;
    }

    /* Owner link */
    #login_form p,
    form[action="/password"] ~ p,
    .shopify-section p {
      font-family: 'DM Sans', sans-serif !important;
      font-size: 11px !important;
      color: rgba(255,255,255,0.25) !important;
      margin-top: 12px !important;
      background: none !important;
    }

    #login_form p a,
    form[action="/password"] ~ p a,
    .shopify-section p a {
      color: rgba(255,255,255,0.5) !important;
    }

    /* ── Bottom bar ── */
    .pw-bottom {
      padding: 24px 0;
      border-top: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .pw-copy {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      letter-spacing: 0.06em;
      color: rgba(255,255,255,0.2);
    }

    .pw-socials {
      display: flex;
      gap: 18px;
      align-items: center;
    }

    .pw-social {
      color: rgba(255,255,255,0.35);
      text-decoration: none;
      display: flex;
      align-items: center;
      transition: color 200ms;
    }

    .pw-social:hover { color: #fff; }

    .pw-social svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
    }
  </style>
</head>
<body>

<div class="pw-shell">

  <!-- Top bar -->
  <div class="pw-top">
    <a href="/" class="pw-logo">
      {% if settings.logo != blank %}
        <img src="{{ settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" width="160" height="auto">
      {% else %}
        POLARIS CAR CARE
      {% endif %}
    </a>
    <span class="pw-tag">Coming Soon</span>
  </div>

  <!-- Main -->
  <div class="pw-main">

    <!-- Left: Brand -->
    <div class="pw-left">
      <p class="pw-eyebrow">Polaris Car Care &mdash; Chicago, Illinois</p>
      <h1 class="pw-headline">Built<br>for the<br>ones<br>who care.</h1>
      <div class="pw-rule"></div>
      <p class="pw-sub">Premium detailing tools for the car community. Something big is coming — be the first to know.</p>
    </div>

    <!-- Right: Forms -->
    <div class="pw-right">

      <!-- Email signup -->
      <div class="pw-signup">
        <span class="pw-signup-label">Get early access + 10% off</span>
        <div class="pw-email-row">
          <input class="pw-email-input" type="email" placeholder="Your email address" autocomplete="email">
          <button class="pw-email-btn" type="button">Notify Me</button>
        </div>
        <p class="pw-fine">No spam. Unsubscribe anytime.</p>
      </div>

      <div class="pw-or">or enter with password</div>

      <!-- Shopify password form -->
      <div class="pw-password-form">
        {{ content_for_layout }}
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="pw-bottom">
    <p class="pw-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <div class="pw-socials">
      {% if settings.tiktok_url != blank %}
        <a href="{{ settings.tiktok_url }}" target="_blank" rel="noopener" class="pw-social" aria-label="TikTok">
          <svg viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>
        </a>
      {% endif %}
      {% if settings.instagram_url != blank %}
        <a href="{{ settings.instagram_url }}" target="_blank" rel="noopener" class="pw-social" aria-label="Instagram">
          <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
      {% endif %}
    </div>
  </div>

</div>


</body>
</html>
