<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  <meta name="description" content="{{ shop.description }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

  {% if settings.favicon != blank %}
    <link rel="shortcut icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png">
  {% endif %}

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: #000;
      color: #fff;
      font-family: 'Inter', sans-serif;
    }

    .password-page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 24px;
      text-align: center;
    }

    .password-logo {
      margin-bottom: 48px;
    }

    .password-logo img {
      height: 40px;
      width: auto;
      filter: brightness(0) invert(1);
    }

    .password-logo-text {
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 20px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #fff;
    }

    .password-headline {
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: clamp(2.5rem, 7vw, 5rem);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      line-height: 1.1;
      margin-bottom: 20px;
    }

    .password-subhead {
      font-size: 16px;
      line-height: 1.6;
      opacity: 0.65;
      max-width: 480px;
      margin: 0 auto 48px;
    }

    .password-email-form {
      width: 100%;
      max-width: 420px;
      margin: 0 auto 64px;
    }

    .password-email-label {
      display: block;
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      opacity: 0.5;
      margin-bottom: 16px;
    }

    .password-input-row {
      display: flex;
      gap: 0;
      border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .password-email-input {
      flex: 1;
      background: transparent;
      border: none;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      padding: 14px 16px;
      outline: none;
    }

    .password-email-input::placeholder {
      color: rgba(255, 255, 255, 0.35);
      text-transform: uppercase;
      font-size: 12px;
      letter-spacing: 0.1em;
    }

    .password-submit {
      background: #fff;
      color: #000;
      border: none;
      padding: 14px 24px;
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 200ms;
      white-space: nowrap;
    }

    .password-submit:hover {
      background: rgba(255, 255, 255, 0.9);
    }

    .password-footer {
      position: absolute;
      bottom: 32px;
      left: 0;
      right: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }

    .password-copyright {
      font-size: 12px;
      opacity: 0.35;
      letter-spacing: 0.1em;
    }

    .password-socials {
      display: flex;
      gap: 20px;
    }

    .password-social-link {
      color: rgba(255, 255, 255, 0.5);
      text-decoration: none;
      transition: color 200ms;
    }

    .password-social-link:hover {
      color: #fff;
    }

    .password-social-link svg {
      width: 20px;
      height: 20px;
      fill: currentColor;
    }
  </style>
</head>
<body>

<div class="password-page">

  <div class="password-logo">
    {% if settings.logo_white != blank %}
      <img src="{{ settings.logo_white | img_url: 'medium' }}" alt="{{ shop.name }}">
    {% else %}
      <div class="password-logo-text">{{ shop.name }}</div>
    {% endif %}
  </div>

  {{ content_for_layout }}

</div>

<div class="password-footer">
  <div class="password-socials">
    {% if settings.tiktok_url != blank %}
      <a href="{{ settings.tiktok_url }}" target="_blank" rel="noopener" class="password-social-link" aria-label="TikTok">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
        </svg>
      </a>
    {% endif %}
    {% if settings.instagram_url != blank %}
      <a href="{{ settings.instagram_url }}" target="_blank" rel="noopener" class="password-social-link" aria-label="Instagram">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
        </svg>
      </a>
    {% endif %}
  </div>
  <p class="password-copyright">© {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
</div>

</body>
</html>
