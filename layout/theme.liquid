              <text x="7" y="15.5" font-family="Arial, sans-serif" font-size="9" fill="#FFFFFF">&#xf8ff;</text>
              <text x="16" y="15.5" font-family="Arial, sans-serif" font-size="7" fill="#FFFFFF">Pay</text>
            </svg>
            <!-- Google Pay -->
            <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" aria-label="Google Pay">
              <rect width="38" height="24" rx="4" fill="#FFFFFF"/>
              <text x="5" y="16" font-family="Arial, sans-serif" font-size="8" font-weight="bold" fill="#4285F4">G</text>
              <text x="13" y="16" font-family="Arial, sans-serif" font-size="8" fill="#333333">Pay</text>
