          <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
          <span>Chicago, IL &mdash; Built for the ones who care.</span>
        </div>
      </div>
    </footer>

    <!-- Cart Drawer (snippet) -->
    {%- render 'cart-drawer' -%}

    <!-- Theme JS -->
    <script src="{{ 'theme.js' | asset_url }}" defer></script>

    <script>
      // Infinite marquee — clone spans until track fills 4x viewport, then set speed
      (function () {
        var track = document.getElementById('marquee-track');
        if (!track) return;
        var original = track.children[0];
        var limit = 60;
        var i = 0;
        while (track.scrollWidth < window.innerWidth * 4 && i < limit) {
          var clone = original.cloneNode(true);
          clone.setAttribute('aria-hidden', 'true');
          track.appendChild(clone);
          i++;
        }
        // ~80px per second scroll speed
        var dur = (track.scrollWidth / 2) / 80;
        track.style.animationDuration = Math.max(dur, 8) + 's';
      })();
    </script>

    <script>
      // Announcement bar hide/show on scroll
      (function () {
        var bar = document.getElementById('announcement-bar');
        var header = document.getElementById('site-header');
        var lastScrollY = window.scrollY;
        var ticking = false;

        function onScroll() {
          var currentScrollY = window.scrollY;

          if (currentScrollY > lastScrollY && currentScrollY > 80) {
            bar.classList.add('is-hidden');
            // Move header to top when announcement hides
            header.style.top = '0px';
          } else {
            bar.classList.remove('is-hidden');
            header.style.top = '';
          }

          // Homepage header transparency
          if (document.body.classList.contains('page-home')) {
            if (currentScrollY > 60) {
              header.classList.add('header-scrolled');
            } else {
              header.classList.remove('header-scrolled');
            }
          }

          lastScrollY = currentScrollY;
          ticking = false;
        }

        window.addEventListener('scroll', function () {
          if (!ticking) {
            window.requestAnimationFrame(onScroll);
            ticking = true;
          }
        }, { passive: true });

        // Set initial state for non-home pages
        if (!document.body.classList.contains('page-home')) {
          header.classList.add('header-scrolled');
        }
      })();

      // Mobile nav drawer
      (function () {
        var hamburger = document.getElementById('hamburger');
        var navClose = document.getElementById('nav-close');
        var drawer = document.getElementById('nav-drawer');
        var overlay = document.getElementById('nav-overlay');

        function openDrawer() {
          drawer.classList.add('is-open');
          overlay.classList.add('is-open');
          drawer.setAttribute('aria-hidden', 'false');
          overlay.setAttribute('aria-hidden', 'false');
          hamburger.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        }

        function closeDrawer() {
          drawer.classList.remove('is-open');
          overlay.classList.remove('is-open');
          drawer.setAttribute('aria-hidden', 'true');
          overlay.setAttribute('aria-hidden', 'true');
          hamburger.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        }

        if (hamburger) hamburger.addEventListener('click', openDrawer);
        if (navClose) navClose.addEventListener('click', closeDrawer);
        if (overlay) overlay.addEventListener('click', closeDrawer);

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeDrawer();
        });
      })();

      // Fade-in on scroll (Intersection Observer)
      (function () {
        var fadeEls = document.querySelectorAll('.fade-in');
        if (!fadeEls.length) return;

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        fadeEls.forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>

  </body>
</html>
